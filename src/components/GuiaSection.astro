---
import GuiaCard from './GuiaCard.astro';
import OptimizedImage from './OptimizedImage.astro';
import { getProfessionalsByUnit, type Professional } from '../data/professionals';

interface Props {
  unit: Professional['unit'];
  label?: string;
  heading?: string;
  subtext?: string;
  max?: number;
}

const {
  unit,
  label = 'quem cuida de você',
  heading = 'Guias,<br>não <em>heróis.</em>',
  subtext,
  max = 4,
} = Astro.props;

const all = getProfessionalsByUnit(unit);
const shown = all.slice(0, max);
---

<section class="u-bg-warm" aria-label="Quem cuida de você">
  <div class="w">
    <div class="lbl r u-mb-16">{label}</div>
    <h2 class="h2 r d1 u-mb-12" set:html={heading} />
    {
      subtext && (
        <p class="body r d2" style="max-width:520px;margin-bottom:40px">
          {subtext}
        </p>
      )
    }
    {
      shown.length === 1 ? (
        <div
          class="g2 g2c r d1"
          style="margin-top:24px;background:var(--color-white);border:1px solid var(--color-stone);padding:clamp(28px,4vw,56px);gap:clamp(28px,4vw,64px)"
        >
          <div class="lux-frame" style="max-width:380px">
            <OptimizedImage
              src={shown[0].photo}
              alt={`${shown[0].name}, ${shown[0].role}`}
              width={760}
              height={1000}
              class="lux-frame-img"
            />
          </div>
          <div>
            {shown[0].personalTouch && (
              <p style="font-family:var(--font-serif);font-style:italic;font-size:clamp(19px,2vw,26px);font-weight:300;color:var(--color-ink);line-height:1.5;margin-bottom:22px">
                "{shown[0].personalTouch}"
              </p>
            )}
            <p style="font-size:16px;font-weight:500;color:var(--color-ink);margin-bottom:4px">
              {shown[0].name}
            </p>
            <p style="font-size:11px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:4px">
              {shown[0].role}
            </p>
            {shown[0].registration && (
              <p style="font-size:11px;font-weight:300;color:var(--color-ink-soft);margin-bottom:18px">
                {shown[0].registration}
              </p>
            )}
            <a href={`/profissionais/${shown[0].slug}`} class="ghost" style="display:inline-flex">
              ver perfil completo <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      ) : (
        <div class="g4" style="margin-top:24px">
          {shown.map((p, i) => (
            <GuiaCard
              name={p.name}
              role={p.role}
              photo={p.photo}
              slug={p.slug}
              personalTouch={p.personalTouch}
              registration={p.registration}
              delay={`d${Math.min(i, 3)}`}
            />
          ))}
        </div>
      )
    }
    <div class="r d3" style="margin-top:28px">
      <a
        href="/profissionais"
        style="font-size:11px;font-weight:500;color:var(--color-brand-text);letter-spacing:.04em;text-decoration:none"
        >conhecer toda a equipe →</a
      >
    </div>
  </div>
</section>
