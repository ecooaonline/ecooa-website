---
const MAPS = 'https://maps.google.com/maps?q=Rua+Mariante+180+Porto+Alegre+RS';
const WAZE = 'https://waze.com/ul?q=Rua+Mariante+180+Porto+Alegre';
---

<div style="background:var(--color-ink);border:none;padding:44px 40px">
  <p class="label-sm" style="color:var(--color-brand-deep);margin-bottom:20px">como nos encontrar</p>
  <p style="font-size:17px;font-weight:400;color:rgba(255,255,255,.82);margin-bottom:4px">Rua Mariante, 180</p>
  <p style="font-size:14px;font-weight:300;color:rgba(255,255,255,.5);margin-bottom:2px">9º andar · Moinhos de Vento</p>
  <p style="font-size:13px;font-weight:300;color:rgba(255,255,255,.38);margin-bottom:3px">Porto Alegre, RS · CEP 90430-180</p>
  <div class="ml">
    <a href={MAPS} target="_blank" rel="noopener noreferrer" aria-label="Abrir no Google Maps">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" stroke="currentColor" stroke-width="1.2" fill="none"/></svg>
      google maps
    </a>
    <a href={WAZE} target="_blank" rel="noopener noreferrer" aria-label="Abrir no Waze">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="10" r="7" stroke="currentColor" stroke-width="1.2"/><path d="M12 17v4M8 21h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
      waze
    </a>
  </div>
  <p class="label-sm" style="color:var(--color-brand-deep);margin-top:26px;margin-bottom:10px">horários</p>
  <p style="font-size:14px;font-weight:300;color:rgba(255,255,255,.55);line-height:1.9">
    Segunda a Sexta: 9h às 20h<br>
    Sábado: a consultar<br>
    <span style="font-size:11px;color:rgba(255,255,255,.26)">Atendimento com agendamento prévio</span>
  </p>
</div>
