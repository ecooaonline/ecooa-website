---
interface Props {
  items: Array<{
    id: string;
    text: string;
    level: number; // 1-3 (h1-h3)
  }>;
}

const { items } = Astro.props;

if (!items || items.length === 0) {
  throw new Error('TableOfContents requires items array');
}
---

<nav class="toc" aria-label="Índice do conteúdo">
  <div class="toc-header">
    <p class="toc-title">Neste artigo</p>
  </div>
  <ul class="toc-list">
    {items.map((item) => (
      <li class={`toc-item level-${item.level}`}>
        <a href={`#${item.id}`} class="toc-link">
          {item.text}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .toc {
    background: var(--color-warm);
    border: 1px solid var(--color-stone);
    border-radius: 8px;
    padding: 20px;
    margin: 32px 0;
  }

  .toc-header {
    margin-bottom: 16px;
  }

  .toc-title {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin: 0;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc-item {
    margin: 8px 0;
  }

  .toc-item.level-1 {
    margin-left: 0;
  }

  .toc-item.level-2 {
    margin-left: 16px;
  }

  .toc-item.level-3 {
    margin-left: 32px;
  }

  .toc-link {
    font-size: 13px;
    font-weight: 300;
    color: var(--color-ink);
    text-decoration: none;
    display: inline-block;
    padding: 4px 0;
    transition: color 0.2s ease;
    border-bottom: 1px solid transparent;
  }

  .toc-link:hover {
    color: var(--color-brand-text);
    border-bottom-color: var(--color-brand-text);
  }

  @media (max-width: 768px) {
    .toc {
      padding: 16px;
      margin: 24px 0;
    }

    .toc-title {
      font-size: 10px;
    }

    .toc-link {
      font-size: 12px;
    }

    .toc-item.level-2 {
      margin-left: 12px;
    }

    .toc-item.level-3 {
      margin-left: 24px;
    }
  }
</style>
