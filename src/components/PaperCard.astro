---
// Cartão-papel premium da referência: nome da área em serif itálico, submarca
// discreta, hairline, frase poética curta, seta e fotografia espiando na base.
import OptimizedImage from './OptimizedImage.astro';

interface Props {
  href: string;
  title: string;
  sub: string;
  desc: string;
  image?: string;
  imageAlt?: string;
  delay?: string;
}

const { href, title, sub, desc, image, imageAlt = '', delay = '' } = Astro.props;
---

<a href={href} class={`paper-card r ${delay}`}>
  <span class="seal" aria-hidden="true"></span>
  <span class="paper-card-title">{title}</span>
  <span class="paper-card-sub">{sub}</span>
  <span class="paper-card-rule" aria-hidden="true"></span>
  <span class="paper-card-desc">{desc}</span>
  <span class="paper-card-arrow" aria-hidden="true">⟶</span>
  {
    image && (
      <span class="paper-card-photo">
        <OptimizedImage src={image} alt={imageAlt} width={600} height={400} class="u-cover" />
      </span>
    )
  }
</a>
