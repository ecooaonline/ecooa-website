---
import EcooaLogo from './EcooaLogo.astro';

interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

interface NavLink {
  href: string;
  label: string;
  children?: { href: string; label: string }[];
}

const links: NavLink[] = [
  { href: '/quem-somos', label: 'quem somos' },
  {
    href: '/ecooa-med',
    label: 'medicina',
    children: [
      { href: '/ecooa-med#metodo-gehrke', label: 'método gehrke 360°' },
      { href: '/ecooa-med#protocolos', label: 'protocolos' },
      { href: '/ecooa-med#descobrir-meu-nivel', label: 'descobrir meu nível' },
    ],
  },
  {
    href: '/ecooa-esthetic',
    label: 'estética',
    children: [
      { href: '/ecooa-esthetic#transplante-capilar', label: 'transplante capilar' },
      { href: '/ecooa-esthetic#procedimentos', label: 'procedimentos' },
    ],
  },
  {
    href: '/ecooa-mind',
    label: 'saúde mental',
    children: [
      { href: '/ecooa-mind#como-funciona', label: 'como funciona' },
      { href: '/match', label: 'encontrar minha psicóloga' },
    ],
  },
  {
    href: '/ecooa-working',
    label: 'nutrição',
    children: [
      { href: '/ecooa-working#programas', label: 'programas' },
      { href: '/ecooa-working#bioimpedancia', label: 'bioimpedância' },
    ],
  },
  { href: '/profissionais', label: 'profissionais' },
  { href: '/match', label: 'match' },
  { href: '/blog', label: 'blog' },
  { href: '/mentorias', label: 'mentorias' },
  { href: '/contato', label: 'contato' },
];
---

<header>
  <nav class="nav" id="nav" aria-label="Menu principal">
    <a class="nav-logo" href="/" aria-label="ecooa, Página inicial">
      <EcooaLogo height={24} />
    </a>

    <div class="nav-right">
      <a
        href="https://instagram.com/somos.ecooa"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-ig"
        aria-label="Instagram @somos.ecooa"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="2" width="20" height="20" rx="5"></rect>
          <circle cx="12" cy="12" r="5"></circle>
          <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"></circle>
        </svg>
      </a>
      <button
        class="nav-toggle"
        aria-expanded="false"
        aria-controls="nav-menu"
        aria-label="Abrir menu"
      >
        <span></span><span></span><span></span>
      </button>
    </div>

    <ul class="nav-links" id="nav-menu" role="list">
      {
        links.map((link) => (
          <li class={link.children ? 'has-sub' : undefined}>
            <a
              href={link.href}
              aria-current={currentPage === link.href.slice(1) ? 'page' : undefined}
            >
              {link.label}
            </a>
            {link.children && (
              <ul class="nav-sub" role="list">
                {link.children.map((child) => (
                  <li>
                    <a href={child.href}>{child.label}</a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
      <li class="nav-cta-mobile-wrapper">
        <a href="/agendamento" class="nav-cta-mobile">agendar avaliação com nossa equipe</a>
      </li>
    </ul>

    <a href="/agendamento" class="nav-cta">agendar avaliação com nossa equipe</a>
  </nav>
</header>
