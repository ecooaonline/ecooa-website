---
import EcooaLogo from './EcooaLogo.astro';

interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

const links = [
  { href: '/quem-somos', label: 'quem somos' },
  { href: '/ecooa-med', label: 'medicina' },
  { href: '/ecooa-esthetic', label: 'estética' },
  { href: '/ecooa-mind', label: 'saúde mental' },
  { href: '/ecooa-working', label: 'nutrição' },
  { href: '/profissionais', label: 'profissionais' },
  { href: '/blog', label: 'blog' },
  { href: '/mentorias', label: 'mentorias' },
  { href: '/contato', label: 'contato' },
];
---

<header>
  <nav class="nav" id="nav" aria-label="Menu principal">
    <a class="nav-logo" href="/" aria-label="ecooa, Página inicial">
      <EcooaLogo height={24} />
    </a>

    <div class="nav-right">
      <a href="https://instagram.com/somos.ecooa" target="_blank" rel="noopener noreferrer" class="nav-ig" aria-label="Instagram @somos.ecooa">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5"/>
          <circle cx="12" cy="12" r="5"/>
          <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/>
        </svg>
      </a>
      <button class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Abrir menu">
        <span></span><span></span><span></span>
      </button>
    </div>

    <ul class="nav-links" id="nav-menu" role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            aria-current={currentPage === link.href.slice(1) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="nav-cta-mobile-wrapper">
        <a href="/agendamento" class="nav-cta-mobile">agendar avaliação com nossa equipe</a>
      </li>
    </ul>

    <a href="/agendamento" class="nav-cta">agendar avaliação com nossa equipe</a>
  </nav>
</header>
