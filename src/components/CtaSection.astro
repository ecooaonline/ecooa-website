---
import WavePattern from './WavePattern.astro';

interface Props {
  heading: string;
  subtext: string;
  image?: string;
}

const { heading, subtext, image } = Astro.props;
const WA = 'https://wa.me/5551991460909?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20uma%20avalia%C3%A7%C3%A3o%20com%20a%20equipe%20ecooa';
---

<section class={`cf ${image ? 'cf-img' : ''}`} aria-label="Chamada para ação">
  {image ? (
    <img src={image} alt="ecooa — Moinhos de Vento, Porto Alegre" loading="lazy" decoding="async" width="1000" height="1709" class="cf-bg" />
  ) : (
    <svg class="wsv" style="opacity:.04" viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <g fill="none" stroke="white" stroke-width="1"><WavePattern count={8} y0={80} step={55} /></g>
    </svg>
  )}
  <p class="cf-lbl r">ecooa · Porto Alegre</p>
  <h2 class="cf-h r d1" set:html={heading} />
  <p class="cf-s r d2">{subtext}</p>
  <div class="cf-bt r d3">
    <a href={WA} target="_blank" rel="noopener noreferrer" class="bw">falar pelo whatsapp</a>
    <a href="/agendamento" class="bow">agendar avaliação com nossa equipe</a>
  </div>
</section>

<style>
  .cf-img {
    position: relative;
    overflow: hidden;
  }
  .cf-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: .13;
    z-index: 0;
  }
</style>
