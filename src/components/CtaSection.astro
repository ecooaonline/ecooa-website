---
import WavePattern from './WavePattern.astro';

interface Props {
  heading: string;
  subtext: string;
  image?: string;
}

import { WA_DEFAULT, ADDRESS_NEIGHBORHOOD, ADDRESS_CITY } from '../data/constants';

const { heading, subtext, image } = Astro.props;
const WA = WA_DEFAULT;
---

<section class={`cf ${image ? 'cf-img' : ''}`} aria-label="Chamada para ação">
  {image ? (
    <img src={image} alt={`ecooa, ${ADDRESS_NEIGHBORHOOD}, ${ADDRESS_CITY}`} loading="lazy" decoding="async" width="1000" height="1709" class="cf-bg" />
  ) : (
    <svg class="wsv" style="opacity:.04" viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <g fill="none" stroke="white" stroke-width="1"><WavePattern count={8} y0={80} step={55} /></g>
    </svg>
  )}
  <p class="cf-lbl r">ecooa · Porto Alegre</p>
  <h2 class="cf-h r d1" set:html={heading} />
  <p class="cf-s r d2">{subtext}</p>
  <div class="cf-bt r d3">
    <a href={WA} target="_blank" rel="noopener noreferrer" class="bw" data-intent="cta-section">falar pelo whatsapp</a>
    <a href="/agendamento" class="bow">agendar avaliação</a>
  </div>
  <p class="cf-rt r d3">respondemos em minutos</p>
</section>

<style>
  .cf-rt {
    font-size: 10px;
    font-weight: 400;
    color: rgba(255,255,255,.45);
    letter-spacing: .06em;
    margin-top: 10px;
    text-align: center;
  }
  .cf-img {
    position: relative;
    overflow: hidden;
  }
  .cf-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: .13;
    z-index: 0;
  }
</style>
