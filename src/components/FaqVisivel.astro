---
import { WA_BASE } from '../data/constants';

interface Faq {
  q: string;
  a: string;
}

interface Props {
  faqs: Faq[];
  label?: string;
  heading?: string;
}

const {
  faqs,
  label = 'perguntas frequentes',
  heading = 'Dúvidas<br><em>frequentes.</em>',
} = Astro.props;

// Fonte única: o mesmo array alimenta o accordion visível e o JSON-LD FAQPage.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section class="u-bg-warm" aria-label="Perguntas frequentes">
  <div class="w">
    <div class="lbl r u-mb-16">{label}</div>
    <h2 class="h2 r d1 u-mb-40" set:html={heading} />
    <div class="faq-section">
      {
        faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-q">{faq.q}</summary>
            <p class="faq-a">{faq.a}</p>
            <a
              href={`${WA_BASE}?text=${encodeURIComponent(`Olá, tenho uma dúvida: ${faq.q}`)}`}
              target="_blank"
              rel="noopener noreferrer"
              data-intent="faq-whatsapp"
              style="display:inline-block;margin-top:10px;font-size:11px;font-weight:500;color:var(--color-brand-text);letter-spacing:.04em;text-decoration:none"
            >
              tirar essa dúvida no whatsapp →
            </a>
          </details>
        ))
      }
    </div>
  </div>
</section>
