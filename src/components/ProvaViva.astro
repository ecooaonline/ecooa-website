---
import { GOOGLE_REVIEWS } from '../data/constants';

interface Props {
  items?: string[];
}

const {
  items = [
    'cuidando de Porto Alegre desde 2021',
    '30+ profissionais que dividem o seu caso',
    'consultas com tempo de verdade',
  ],
} = Astro.props;
---

<section
  aria-label="Prova social"
  style="background:var(--color-warm);border-bottom:1px solid var(--color-stone);padding:18px var(--section-px)"
>
  <div style="display:flex;flex-wrap:wrap;gap:10px 28px;align-items:center;justify-content:center">
    <a
      href={GOOGLE_REVIEWS}
      target="_blank"
      rel="noopener noreferrer"
      style="display:flex;align-items:center;gap:7px;text-decoration:none"
    >
      <span style="color:var(--color-gold);font-size:13px;letter-spacing:1.5px" aria-hidden="true"
        >★★★★★</span
      >
      <span style="font-size:13px;font-weight:500;color:var(--color-ink)">5.0 no Google</span>
    </a>
    {
      items.map((item) => (
        <span style="font-size:12px;font-weight:300;color:var(--color-ink-soft);letter-spacing:.02em">
          {item}
        </span>
      ))
    }
  </div>
</section>
