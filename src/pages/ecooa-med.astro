---
const categoryLabels: { [key: string]: string } = {
  medicina: 'Medicina',
  estetica: 'Estética',
  nutricao: 'Nutrição',
  'saude-mental': 'Saúde Mental',
  longevidade: 'Longevidade',
  ecooa: 'ecooa',
};
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import WavePattern from '../components/WavePattern.astro';
import Marquee from '../components/Marquee.astro';
import HeroEditorial from '../components/HeroEditorial.astro';
import MaskedWordBand from '../components/MaskedWordBand.astro';
import FaqVisivel from '../components/FaqVisivel.astro';
import EspelhoSection from '../components/EspelhoSection.astro';
import ProtocoloCard from '../components/ProtocoloCard.astro';
import RiskReversalBadge from '../components/RiskReversalBadge.astro';
import PrimeiroPassoCTA from '../components/PrimeiroPassoCTA.astro';
import ProvaViva from '../components/ProvaViva.astro';
import GuiaSection from '../components/GuiaSection.astro';
import JornadaTimeline from '../components/JornadaTimeline.astro';
import MetodoQuiz from '../components/MetodoQuiz.astro';
import DisclaimerMedico from '../components/DisclaimerMedico.astro';
import { WA_DEFAULT } from '../data/constants';
import { medAreas } from '../data/specialties';
import { getCollection } from 'astro:content';

const medFaqs = [
  {
    q: 'Quanto custa uma consulta na ecooa.med?',
    a: 'Os valores variam conforme o profissional e o protocolo. O Protocolo Peso Seguro, por exemplo, tem valor de entrada especial para a consulta de avaliação. Entre em contato pelo WhatsApp para informações atualizadas.',
  },
  {
    q: 'Preciso de indicação para agendar?',
    a: 'Não. Você pode agendar diretamente pelo WhatsApp ou pelo site, sem necessidade de encaminhamento.',
  },
  {
    q: 'A ecooa.med atende por plano de saúde?',
    a: 'Nosso atendimento é particular. Trabalhamos com valores acessíveis e condições especiais para acompanhamento contínuo.',
  },
  {
    q: 'Como funciona o Protocolo Peso Seguro?',
    a: 'Começa com uma consulta de avaliação com valor de entrada especial. Inclui anamnese completa, solicitação de exames laboratoriais para avaliar a segurança no uso de canetas emagrecedoras, e acompanhamento médico recorrente durante todo o tratamento. O objetivo é resultado real com segurança clínica.',
  },
  {
    q: 'As consultas médicas recebem plano alimentar junto?',
    a: 'Não. A ecooa e o Dr. Gustavo acreditam e respeitam cada área da saúde, e entendem que plano alimentar é prescrito por nutricionista. Contamos com mais de 10 nutricionistas na equipe, com conhecimento especializado e direcionado para cada necessidade.',
  },
];

const medProtocolsSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'MedicalProcedure',
      '@id': 'https://www.somosecooa.com.br/ecooa-med#metodo-gehrke-360',
      name: 'Método Gehrke 360°',
      procedureType: 'https://schema.org/DiagnosticProcedure',
      howPerformed:
        'Avaliação metabólica estratificada em três níveis (Reset, Equilíbrio, Performance) com base em biomarcadores, anamnese completa e exames laboratoriais. Cada nível orienta um protocolo individualizado de intervenção.',
      description:
        'Método exclusivo de classificação metabólica que identifica o momento de saúde do paciente e direciona o protocolo adequado: Reset para múltiplas alterações, Equilíbrio para ajustes finos, Performance para otimização avançada.',
      url: 'https://www.somosecooa.com.br/ecooa-med',
      performer: { '@id': 'https://www.somosecooa.com.br/#organization' },
      bodyLocation: 'Sistêmico',
      preparation: 'Jejum conforme painel laboratorial solicitado.',
    },
    {
      '@type': 'MedicalProcedure',
      '@id': 'https://www.somosecooa.com.br/ecooa-med#protocolo-peso-seguro',
      name: 'Protocolo Peso Seguro',
      procedureType: 'https://schema.org/TherapeuticProcedure',
      howPerformed:
        'Consulta de avaliação com valor de entrada especial. Análise de exames, histórico e viabilidade clínica para uso supervisionado de agonistas de GLP-1 (semaglutida, tirzepatida) com acompanhamento médico recorrente.',
      description:
        'Emagrecimento clínico com acompanhamento médico contínuo e monitoramento laboratorial. Foco em segurança e resultado sustentável.',
      url: 'https://www.somosecooa.com.br/ecooa-med',
      performer: { '@id': 'https://www.somosecooa.com.br/#organization' },
      followup: 'Retornos periódicos para ajuste de dose e monitoramento.',
    },
    {
      '@type': 'MedicalProcedure',
      '@id': 'https://www.somosecooa.com.br/ecooa-med#protocolo-tricometabolico',
      name: 'Protocolo Tricometabólico',
      procedureType: 'https://schema.org/DiagnosticProcedure',
      howPerformed:
        'Investigação das causas metabólicas da queda capilar: perfil hormonal, estresse oxidativo, micronutrientes. Quando indicado, inclui mapeamento genético para predisposição hereditária.',
      description:
        'Abordagem clínica que trata a raiz metabólica da queda de cabelo, não apenas o sintoma. Integra endocrinologia, nutrição e tricologia.',
      url: 'https://www.somosecooa.com.br/ecooa-med',
      performer: { '@id': 'https://www.somosecooa.com.br/#organization' },
      bodyLocation: 'Couro cabeludo / sistêmico',
    },
    {
      '@type': 'MedicalProcedure',
      '@id': 'https://www.somosecooa.com.br/ecooa-med#bioimplantes-metabolicos',
      name: 'Bioimplantes Metabólicos',
      procedureType: 'https://schema.org/TherapeuticProcedure',
      howPerformed:
        'Aplicação subcutânea de implantes bioabsorvíveis de liberação estável, individualizada por avaliação clínica e laboratorial prévia.',
      description:
        'Implantes subcutâneos bioabsorvíveis com liberação farmacocinética estável, indicados para reposição hormonal feminina e masculina quando clinicamente apropriados.',
      url: 'https://www.somosecooa.com.br/ecooa-med',
      performer: { '@id': 'https://www.somosecooa.com.br/#organization' },
      bodyLocation: 'Tecido subcutâneo',
    },
  ],
};

const WA = WA_DEFAULT;

const allMedPosts = await getCollection(
  'blog',
  ({ data }) => !data.draft && data.category === 'medicina'
);
const medPosts = allMedPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Medicina, Emagrecimento e Canetas Emagrecedoras | ecooa · Porto Alegre"
  description="Medicina humanizada em Moinhos de Vento, Porto Alegre. Emagrecimento, saúde capilar, equilíbrio hormonal e longevidade com preços especiais."
  currentPage="ecooa-med"
  ogImage="/clinic/med.webp"
  breadcrumbs={[{ name: 'ecooa.med', url: '/ecooa-med' }]}
>
  <HeroEditorial
    label="ecooa.med · medicina"
    title='Você sente que algo<br />não está bem. Mesmo com<br /><em>exames "normais".</em>'
    sub="Consultas de 50 minutos, investigação metabólica e hormonal profunda e um plano com começo, meio e acompanhamento. É o Método Gehrke 360°."
    ctaHref={WA}
    ctaLabel="quero avaliar meu caso"
    ctaIntent="med-hero"
    badges={['respondemos em minutos', 'consultas de 50+ minutos']}
    image="/clinic/med.webp"
    imageAlt="Consultório médico da ecooa.med em Moinhos de Vento"
    imageCaption="consultório ecooa.med"
    vertical="medicina que ecooa"
  />

  <Marquee />

  <ProvaViva
    items={[
      'consultas de 50+ minutos',
      'cuidando de Porto Alegre desde 2021',
      '30+ profissionais que dividem o seu caso',
    ]}
  />

  <MaskedWordBand word="vida" image="/clinic/med.webp" label="medicina que ecooa" />

  <script type="application/ld+json" set:html={JSON.stringify(medProtocolsSchema)} />

  <EspelhoSection
    label="qual dessas frases podia ser sua?"
    items={[
      {
        text: 'faço tudo certo e a balança não sai do lugar',
        waText:
          'Olá, faço tudo certo e não consigo emagrecer. Gostaria de saber mais sobre o Protocolo Peso Seguro',
        intent: 'med-espelho-balanca',
      },
      {
        text: 'meu cabelo fica no travesseiro toda manhã',
        waText:
          'Olá, meu cabelo está caindo muito e gostaria de avaliação com o Protocolo Tricometabólico',
        intent: 'med-espelho-cabelo',
      },
      {
        text: 'vivo cansada e nenhum exame explica',
        waText: 'Olá, vivo cansada e nenhum exame explica. Gostaria de uma investigação completa',
        intent: 'med-espelho-cansaco',
      },
      {
        text: 'minha libido sumiu e ninguém pergunta sobre isso',
        waText: 'Olá, gostaria de uma avaliação hormonal completa',
        intent: 'med-espelho-libido',
      },
      {
        text: 'entrei na menopausa e não me reconheço',
        waText: 'Olá, estou na menopausa e gostaria de uma avaliação de saúde hormonal feminina',
        intent: 'med-espelho-menopausa',
      },
      {
        text: 'não sei o que tenho, só sei que não estou bem',
        waText: 'Olá, tenho algumas queixas de saúde e gostaria de orientação da equipe ecooa',
        intent: 'med-espelho-neutra',
      },
    ]}
    closing="Cada uma dessas frases tem uma investigação por trás. A gente começa por ela."
  />

  <!-- Empatia -->
  <section
    style="background:var(--color-cream);padding:64px var(--section-px)"
    aria-label="Entendemos você"
  >
    <div class="u-narrow">
      <p class="body r" style="color:var(--color-ink-soft);line-height:1.9;font-size:14px">
        Você já tentou dietas, passou por médicos que mal olharam os seus exames, ouviu que "está
        tudo normal" mesmo sentindo que algo não vai bem. Cansaço constante, dificuldade para
        emagrecer, insônia, queda de libido. Você sabe que pode estar melhor.
      </p>
      <p
        class="body r d1"
        style="color:var(--color-ink);line-height:1.9;font-size:14px;margin-top:14px;font-weight:400"
      >
        Na ecooa.med, a gente ouve o que os exames dizem e o que você sente. Porque medicina de
        verdade começa pela escuta.
      </p>
    </div>
  </section>

  <!-- Foto do espaço -->
  <section
    style="background:var(--color-cream);padding:0;overflow:hidden"
    aria-label="Nosso espaço"
  >
    <div style="position:relative;width:100%;aspect-ratio:16/6;overflow:hidden">
      <OptimizedImage
        src="/clinic/med.webp"
        alt="Consultório médico da ecooa.med em Moinhos de Vento"
        width={1000}
        height={667}
        class="u-cover"
      />
    </div>
  </section>

  <!-- Abordagem -->
  <section class="u-bg-warm" aria-label="Nossa abordagem">
    <div class="w">
      <div class="g2 g2c">
        <div>
          <div class="lbl r">nossa abordagem</div>
          <h2 class="h2 r d1 u-mt-15">
            Uma rede de<br />especialistas que<br /><em>se entendem.</em>
          </h2>
          <p class="body r d2 u-mt-18">
            Liderada pelo Dr. Gustavo Gehrke, a ecooa.med reúne médicos de metabolismo e hormônios,
            emagrecimento, testes genéticos, implantes subcutâneos e medicina clínica. Uma equipe
            que acredita que a medicina deve ser integral, humanizada e ética. Sem pressa a cada
            atendimento, com escuta total e trabalho multiprofissional em torno do seu caso.
          </p>
          <p class="body r d3 u-mt-13">
            Aqui o seu caso não é dividido em silos. Quando a nutrição, a estética ou a saúde mental
            podem acelerar o seu resultado, a conexão acontece dentro da própria clínica, sem que
            você precise repetir sua história.
          </p>
        </div>
        <div class="r d2">
          <div
            style="background:var(--color-cream);padding:40px 34px;border:1px solid var(--color-stone)"
          >
            <div class="lbl u-mb-20">áreas de atuação</div>
            {
              medAreas.map((area) => (
                <div class="lr">
                  <>
                    <span class="u-dot" />
                    <span class="body-md">{area}</span>
                  </>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <GuiaSection
    unit="med"
    heading="Quem vai<br>te <em>guiar.</em>"
    subtext="O Dr. Gustavo Gehrke lidera a medicina da casa, com tempo de verdade para o seu caso e integrado às nutricionistas e psicólogas do ecossistema."
  />

  <!-- Método Gehrke 360° -->
  <section
    style="background:var(--color-ink);padding:86px 60px"
    aria-label="Método Gehrke 360°"
    id="metodo-gehrke"
  >
    <div class="w">
      <div class="lbl lbl-lt r u-mb-16">método exclusivo</div>
      <h2 class="h2 h2-w r d1 u-mb-20">Método Gehrke <em>360°</em></h2>
      <p class="body body-lt r d2" style="max-width:620px;margin-bottom:48px">
        Cada paciente chega em um momento diferente. O Método Gehrke 360° classifica seu estado
        metabólico atual em três níveis, e a partir disso constrói um protocolo sob medida, com a
        profundidade que cada caso exige.
      </p>
      <div class="gehrke-tiers">
        <div class="gehrke-tier r d1">
          <div class="gehrke-tier-num">01</div>
          <h3 class="gehrke-tier-name">Reset</h3>
          <p class="gehrke-tier-desc">
            Para quem chega com múltiplas alterações metabólicas. Exames fora do padrão, sintomas
            acumulados, histórico de tentativas sem resultado. Protocolo intensivo para ajustar
            hormônios, metabolismo, inflamação e sono. Retornos frequentes até a estabilização
            completa.
          </p>
        </div>
        <div class="gehrke-tier r d2">
          <div class="gehrke-tier-num">02</div>
          <h3 class="gehrke-tier-name">Equilíbrio</h3>
          <p class="gehrke-tier-desc">
            Para quem está funcionando, mas sente que pode melhorar. Pequenos ajustes hormonais,
            nutricionais ou de estilo de vida para pavimentar um envelhecimento saudável. Manutenção
            ativa com acompanhamento periódico e metas claras.
          </p>
        </div>
        <div class="gehrke-tier r d3">
          <div class="gehrke-tier-num">03</div>
          <h3 class="gehrke-tier-name">Performance</h3>
          <p class="gehrke-tier-desc">
            Para quem já está equilibrado e quer operar no limite superior. Otimização metabólica
            avançada, composição corporal de elite, performance cognitiva e física. Protocolos de
            precisão com biomarcadores, genética e acompanhamento de alta frequência.
          </p>
        </div>
      </div>
    </div>
  </section>

  <JornadaTimeline
    label="o mapa da sua investigação"
    heading="O que acontece depois<br>da primeira <em>conversa.</em>"
    steps={[
      {
        marker: 'semana 1',
        title: 'Escuta de 50 minutos',
        desc: 'Você conta sua história inteira, sem pressa. Saímos da consulta com o pedido de exames desenhado para o seu caso.',
      },
      {
        marker: 'semana 3',
        title: 'Devolutiva dos exames',
        desc: 'Cada resultado explicado em bom português: o que está bom, o que merece atenção e por quê.',
      },
      {
        marker: 'mês 1',
        title: 'Protocolo no seu nível',
        desc: 'Reset, quando o corpo pede recomeço. Equilíbrio, para constância, sono e disposição. Performance, quando o bom já não basta.',
      },
      {
        marker: 'mês 3',
        title: 'Reavaliação com dados',
        desc: 'Exames comparados lado a lado com os anteriores, para você ver a evolução em números, não em impressões.',
      },
    ]}
  />

  <MetodoQuiz />

  <!-- Protocolos -->
  <section class="u-bg-cream" aria-label="Protocolos ecooa.med" id="protocolos">
    <div class="w">
      <div class="lbl r u-mb-16">protocolos ecooa.med</div>
      <h2 class="h2 r d1 u-mb-44">Um mapa para<br /><em>cada caso.</em></h2>
      <div class="g3">
        <ProtocoloCard
          numero="01"
          nome="Protocolo Peso Seguro"
          paraQuem="Para quem já tentou de tudo e quer emagrecer com segurança e acompanhamento de verdade."
          inclui="Avaliação metabólica completa, canetas emagrecedoras (análogos de GLP-1, como semaglutida e tirzepatida) quando indicadas, e nutrição integrada ao acompanhamento médico."
          traducao="primeiro os exames dizem se é seguro para você; depois o acompanhamento contínuo protege o resultado."
          waText="Olá, gostaria de saber mais sobre o Protocolo Peso Seguro"
          intent="med-protocolo-peso-seguro"
        />
        <ProtocoloCard
          numero="02"
          nome="Protocolo Tricometabólico"
          delay="d1"
          paraQuem="Para queda de cabelo que ninguém leva a sério, tratada de dentro para fora."
          inclui="Investigação de perfil hormonal, metabolismo, estresse oxidativo e nutrientes. Quando indicado, mapeamento genético para personalizar o tratamento."
          traducao="a queda é tratada na causa, não só no sintoma."
          waText="Olá, gostaria de avaliação com o Protocolo Tricometabólico"
          intent="med-protocolo-tricometabolico"
        />
        <ProtocoloCard
          numero="03"
          nome="Bioimplantes Metabólicos"
          delay="d2"
          paraQuem="Para reposição hormonal feminina e masculina, quando clinicamente indicada."
          inclui="Implantes subcutâneos bioabsorvíveis de liberação estável, com avaliação clínica e laboratorial prévia e protocolos individualizados."
          traducao="hormônios liberados aos poucos, sem a montanha-russa das doses diárias."
          waText="Olá, gostaria de avaliação hormonal e bioimplantes metabólicos"
          intent="med-protocolo-bioimplantes"
        />
        <ProtocoloCard
          numero="04"
          nome="Saúde Hormonal Feminina"
          paraQuem="Para a menopausa e os ciclos que viraram inimigos, em todas as fases da vida da mulher."
          inclui="Avaliação hormonal completa, manejo clínico com bioimplantes de liberação lenta quando indicados, e acompanhamento contínuo."
          waText="Olá, gostaria de uma avaliação de saúde hormonal feminina"
          intent="med-protocolo-hormonal-feminina"
        />
        <ProtocoloCard
          numero="05"
          nome="Saúde Hormonal Masculina"
          delay="d1"
          paraQuem="Para energia, força e libido em baixa."
          inclui="Avaliação completa da saúde hormonal masculina, protocolos individualizados para vitalidade e composição corporal, incluindo bioimplantes quando aplicável."
          waText="Olá, gostaria de uma avaliação de saúde hormonal masculina"
          intent="med-protocolo-hormonal-masculina"
        />
        <ProtocoloCard
          numero="06"
          nome="Performance e Esporte"
          delay="d2"
          paraQuem="Para quem treina de verdade e quer extrair o máximo do corpo com inteligência."
          inclui="Protocolos seguros e monitorados de força, recuperação e composição corporal, com exames e acompanhamento de alta frequência."
          waText="Olá, gostaria de avaliação para performance e otimização metabólica"
          intent="med-protocolo-performance"
        />
        <ProtocoloCard
          numero="07"
          nome="Longevidade e Vitalidade"
          paraQuem="Para quem quer envelhecer com energia, autonomia e lucidez."
          inclui="Ciência aplicada ao envelhecimento saudável: micronutrientes, estratégias preventivas e acompanhamento baseado em exames e evidência clínica."
          waText="Olá, gostaria de um acompanhamento de longevidade e vitalidade"
          intent="med-protocolo-longevidade"
        />
        <ProtocoloCard
          numero="08"
          nome="Check-up 360"
          delay="d1"
          paraQuem="Para quem quer um retrato completo do próprio corpo hoje."
          inclui="Avaliação abrangente do metabolismo, saúde cardiovascular, função da tireoide e perfil inflamatório, com cada exame explicado um a um."
          waText="Olá, gostaria de agendar uma avaliação pelo Método Gehrke 360°"
          intent="med-protocolo-checkup"
        />
      </div>
    </div>
  </section>

  <!-- Nosso Espaço -->
  <section
    style="background:var(--color-warm);padding:0;overflow:hidden"
    aria-label="Espaço ecooa.med"
  >
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;padding:4px">
      <div class="u-img-169 r">
        <OptimizedImage
          src="/clinic/recepcao.webp"
          alt="Recepção da ecooa em Moinhos de Vento"
          width={1000}
          height={1233}
          class="u-cover"
        />
      </div>
      <div class="u-img-169 r d1">
        <OptimizedImage
          src="/clinic/cafe.webp"
          alt="Café da ecooa"
          width={1200}
          height={799}
          class="u-cover"
        />
      </div>
    </div>
  </section>

  <!-- Como funciona -->
  <section class="u-bg-cream" aria-label="Como funciona">
    <div class="w">
      <div class="lbl r u-mb-16">sua jornada</div>
      <h2 class="h2 r d1 u-mb-44">como <em>funciona</em></h2>
      <div
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:32px;max-width:960px;margin:0 auto"
      >
        <div class="r u-tac">
          <span class="step-num">1</span>
          <h3 class="it-t">Agendamento</h3>
          <p class="it-d">
            Entre em contato pelo WhatsApp. Respondemos em minutos e encontramos o melhor horário
            para você.
          </p>
        </div>
        <div class="r d1 u-tac">
          <span class="step-num">2</span>
          <h3 class="it-t">Avaliação completa</h3>
          <p class="it-d">
            Consulta com tempo real de escuta, análise de exames e entendimento dos seus objetivos.
            Traga seus exames antigos, mesmo os que ouviram que estavam normais.
          </p>
        </div>
        <div class="r d2 u-tac">
          <span class="step-num">3</span>
          <h3 class="it-t">Protocolo personalizado</h3>
          <p class="it-d">
            Plano construído com base nos seus dados, na sua rotina e no que você quer alcançar.
          </p>
        </div>
        <div class="r d3 u-tac">
          <span class="step-num">4</span>
          <h3 class="it-t">Acompanhamento</h3>
          <p class="it-d">
            Retornos periódicos para ajustar o protocolo e sustentar a sua evolução.
          </p>
        </div>
      </div>
    </div>
  </section>

  <FaqVisivel faqs={medFaqs} heading="Dúvidas sobre a<br><em>ecooa.med.</em>" />

  <!-- Depoimentos -->
  <section class="u-bg-cream" aria-label="Depoimentos de pacientes">
    <div class="w">
      <div class="lbl r u-mb-16">depoimentos</div>
      <h2 class="h2 r d1 u-mb-44">o que nossos pacientes <em>dizem</em></h2>
      <div class="grid-auto-260">
        <div class="r card-w">
          <p class="q-serif">
            "A consulta durou quase uma hora. O médico olhou todos os meus exames anteriores, pediu
            novos e montou um plano que fez sentido. Em dois meses já senti diferença na
            disposição."
          </p>
          <p class="sm-soft">L. R.</p>
        </div>
        <div class="r d1 card-w">
          <p class="q-serif">
            "Passei anos ouvindo que meus exames estavam normais, mesmo me sentindo mal. Aqui
            olharam tudo com profundidade e finalmente encontraram o que precisava ser ajustado."
          </p>
          <p class="sm-soft">D. B.</p>
        </div>
        <div class="r d2 card-w">
          <p class="q-serif">
            "Comecei o acompanhamento para emagrecer e o protocolo foi completamente personalizado.
            O retorno é rápido e o médico realmente acompanha a evolução."
          </p>
          <p class="sm-soft">P. A.</p>
        </div>
      </div>
      <p
        class="r d3"
        style="text-align:center;margin-top:24px;font-size:11px;font-weight:300;color:var(--color-ink-soft);letter-spacing:.02em"
      >
        Depoimentos reais publicados com autorização dos pacientes.
      </p>
    </div>
  </section>

  <!-- Artigos relacionados -->
  {
    medPosts.length > 0 && (
      <section class="u-bg-warm" aria-label="Artigos relacionados">
        <div class="w">
          <div class="lbl r u-mb-16">do nosso blog</div>
          <h2 class="h2 r d1 u-mb-44">
            artigos <em>relacionados</em>
          </h2>
          <div class="grid-auto-260">
            {medPosts.map((post, i) => (
              <a
                href={`/blog/${post.id}`}
                class={`r d${i}`}
                style="display:block;background:var(--color-cream);border:1px solid var(--color-stone);padding:28px 24px;text-decoration:none;transition:border-color .2s ease"
              >
                <p style="font-size:11px;font-weight:400;color:var(--color-brand-text);letter-spacing:.04em;text-transform:lowercase;margin-bottom:10px">
                  {categoryLabels[post.data.category] || post.data.category}
                </p>
                <h3 style="font-size:15px;font-weight:400;color:var(--color-ink);line-height:1.5;margin-bottom:8px">
                  {post.data.title}
                </h3>
                <p style="font-size:12px;font-weight:300;line-height:1.7;color:var(--color-ink-soft)">
                  {post.data.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="u-bg-warm" aria-label="Aviso médico" style="padding:32px var(--section-px) 8px">
    <DisclaimerMedico />
  </section>

  <!-- Link discreto B2B -->
  <section class="u-bg-warm" aria-label="Para médicos" style="padding:24px var(--section-px)">
    <p
      class="r"
      style="text-align:center;font-size:12px;font-weight:300;color:var(--color-ink-soft)"
    >
      É médico e quer atender na ecooa? <a
        href="/para-profissionais"
        style="color:var(--color-brand-text);text-underline-offset:3px;text-decoration:underline"
        >Conheça a ecooa para profissionais →</a
      >
    </p>
  </section>

  <PrimeiroPassoCTA
    heading="Traga seus exames.<br><em>A gente explica o resto.</em>"
    subtext="Agende sua avaliação e descubra o que os seus exames dizem sobre você, explicado em bom português."
    waText="Olá, quero agendar uma avaliação na ecooa.med. Tenho exames antigos para levar."
    label="quero avaliar meu caso"
    intent="med-primeiro-passo"
    badges={['respondemos em minutos', 'consultas de 50+ minutos', 'seg a sex, 9h às 20h']}
  />
</BaseLayout>
