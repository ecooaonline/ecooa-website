---
import BaseLayout from '../layouts/BaseLayout.astro';
import WavePattern from '../components/WavePattern.astro';
import Marquee from '../components/Marquee.astro';
import QuizSection from '../components/QuizSection.astro';
import B2BBanner from '../components/B2BBanner.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_DEFAULT, FORM_ACTION } from '../data/constants';
import { getCollection } from 'astro:content';

const medFaqs = [
  { q: "Quanto custa uma consulta na ecooa.med?", a: "Os valores variam conforme o profissional e o tipo de consulta. Para emagrecimento e acompanhamento com canetas emagrecedoras, oferecemos consultas com preços especiais. Entre em contato pelo WhatsApp para informações atualizadas." },
  { q: "Preciso de indicação para agendar?", a: "Não. Você pode agendar diretamente pelo WhatsApp ou pelo site, sem necessidade de encaminhamento." },
  { q: "A ecooa.med atende por plano de saúde?", a: "Nosso atendimento é particular. Trabalhamos com valores acessíveis e condições especiais para acompanhamento contínuo." },
  { q: "Como funciona a consulta para avaliação do uso de canetas emagrecedoras?", a: "A consulta inclui anamnese completa, solicitação de exames laboratoriais específicos para avaliar a segurança no uso, e acompanhamento médico recorrente durante todo o processo. O objetivo é garantir que o tratamento seja seguro, eficaz e adaptado ao seu perfil clínico, com preços facilitados." },
  { q: "As consultas médicas recebem plano alimentar junto?", a: "Não. A ecooa e o Dr. Gustavo acreditam e respeitam cada área da saúde, e entendem que plano alimentar é prescrito por nutricionista. Contamos com mais de 10 nutricionistas na equipe, com conhecimento especializado e direcionado para cada necessidade." },
];

const medFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": medFaqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const WA = WA_DEFAULT;

const allMedPosts = await getCollection('blog', ({data}) => !data.draft && data.category === 'medicina');
const medPosts = allMedPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);
---

<BaseLayout
  title="Medicina, Emagrecimento e Canetas Emagrecedoras | ecooa · Porto Alegre"
  description="Medicina humanizada em Moinhos de Vento, Porto Alegre. Emagrecimento com canetas (semaglutida, tirzepatida), saúde capilar, hormônios e longevidade com preços especiais."
  currentPage="ecooa-med"
  ogImage="/clinic/med.webp"
  breadcrumbs={[{ name: "ecooa.med", url: "/ecooa-med" }]}
>

<!-- Hero -->
<div class="ph" style="background:var(--color-ink)">
  <svg class="wsv" style="opacity:.05" viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true"><g fill="none" stroke="white" stroke-width="1"><WavePattern count={8} x0={-100} y0={80} step={55} width={1600} /></g></svg>
  <div class="ph-c">
    <div class="lbl lbl-lt r">ecooa.med</div>
    <h1 class="h1 h1-w r d1" style="margin-top:18px">Medicina humanizada.<br>Diagnóstico preciso.<br><em>Resultado real.</em></h1>
    <p class="body body-lt r d2" style="margin-top:16px;max-width:500px">Medicina de precisão que começa pela escuta. Protocolos construídos com base nos seus dados, no seu histórico e, principalmente, nos seus objetivos.</p>
    <a href={WA} target="_blank" rel="noopener noreferrer" class="bw r d3" style="margin-top:28px;display:inline-block">falar pelo whatsapp</a>
    <p class="r d3" style="font-size:10px;font-weight:400;color:rgba(255,255,255,.4);margin-top:8px;letter-spacing:.04em">respondemos em minutos</p>
    <p class="r d3" style="font-size:11px;font-weight:300;color:rgba(255,255,255,.3);margin-top:14px;letter-spacing:.02em;text-align:center;max-width:400px">Consultas de 50+ minutos. Vagas limitadas para garantir atendimento completo.</p>
  </div>
</div>

<Marquee />

<script type="application/ld+json" set:html={JSON.stringify(medFaqSchema)} />

<QuizSection options={[
  { title: "emagrecer", subtitle: "com acompanhamento médico", waText: "Olá, gostaria de avaliação para emagrecimento com acompanhamento médico" },
  { title: "canetas", subtitle: "emagrecedoras", waText: "Olá, gostaria de avaliação para uso de canetas emagrecedoras" },
  { title: "hormônios", subtitle: "desregulados", waText: "Olá, gostaria de avaliação hormonal com a equipe ecooa.med" },
  { title: "queda capilar", subtitle: "tratamento médico", waText: "Olá, gostaria de avaliação médica para queda de cabelo" },
  { title: "check-up", subtitle: "completo", waText: "Olá, gostaria de agendar um check-up metabólico completo" },
  { title: "não sei", subtitle: "por onde começar", waText: "Olá, tenho algumas queixas de saúde e gostaria de orientação da equipe ecooa" },
]} />

<!-- Empatia -->
<section style="background:var(--color-cream);padding:64px var(--section-px)" aria-label="Entendemos você">
  <div style="max-width:640px;margin:0 auto;text-align:center">
    <p class="body r" style="color:var(--color-ink-soft);line-height:1.9;font-size:14px">Você já tentou dietas, passou por médicos que mal olharam os seus exames, ouviu que "está tudo normal" mesmo sentindo que algo não vai bem. Cansaço constante, dificuldade para emagrecer, insônia, queda de libido. Você sabe que pode estar melhor.</p>
    <p class="body r d1" style="color:var(--color-ink);line-height:1.9;font-size:14px;margin-top:14px;font-weight:400">Na ecooa.med, a gente ouve o que os exames dizem e o que você sente. Porque medicina de verdade começa pela escuta.</p>
  </div>
</section>

<!-- Foto do espaço -->
<section style="background:var(--color-cream);padding:0;overflow:hidden" aria-label="Nosso espaço">
  <div style="position:relative;width:100%;aspect-ratio:16/6;overflow:hidden">
    <img src="/clinic/med.webp" alt="Consultório médico da ecooa.med em Moinhos de Vento" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;display:block"  width="1000" height="667" />
  </div>
</section>

<!-- Abordagem -->
<section style="background:var(--color-warm)" aria-label="Nossa abordagem">
  <div class="w">
    <div class="g2 g2c">
      <div>
        <div class="lbl r">nossa abordagem</div>
        <h2 class="h2 r d1" style="margin-top:15px">Uma rede de<br>especialistas que<br><em>se entendem.</em></h2>
        <p class="body r d2" style="margin-top:18px">Liderada por Gustavo Gehrke, a ecooa.med tem o objetivo de unir profissionais que atuam nas mais diversas áreas, como metabolismo e hormônios, emagrecimento, testes genéticos, implantes subcutâneos, medicina clínica e especialidades médicas. Nasce uma rede para médicos que acreditam que a medicina deve ser integral, humanizada e ética. Sem pressa a cada atendimento, com escuta total ao paciente e trabalho multiprofissional.</p>
        <p class="body r d3" style="margin-top:13px">Disponibilizamos nossos consultórios médicos para profissionais que desejam atender em um espaço premium no Moinhos de Vento, com um ambiente acolhedor, sofisticado e repleto de profissionais para networking de carreira. <a href="/contato" style="color:var(--color-brand-text);cursor:pointer;text-underline-offset:3px;text-decoration:underline">Entre em contato</a> ou preencha o formulário abaixo.</p>
        <div class="lbl r" style="margin-top:24px;margin-bottom:10px">para profissionais de saúde</div>
        <p style="font-size:12px;font-weight:300;color:var(--color-ink-soft);line-height:1.7;margin-bottom:14px">Você é médico e quer atender na ecooa? Preencha seus dados que entraremos em contato.</p>
        <form action={FORM_ACTION} method="POST" class="b2b-form ecooa-form" style="margin-top:0" id="form-b2b-med" data-ok-target="#form-b2b-med-ok" data-success-text="Recebemos seu interesse. Entraremos em contato em breve.">
          <input type="hidden" name="_formType" value="b2b-medicina" />
          <input type="text" name="nome" placeholder="Nome completo" required class="b2b-input b2b-light" aria-label="Nome completo" />
          <input type="tel" name="whatsapp" placeholder="WhatsApp" required class="b2b-input b2b-light" aria-label="Número de WhatsApp" />
          <input type="email" name="email" placeholder="E-mail" required class="b2b-input b2b-light" aria-label="E-mail profissional" />
          <button type="submit" class="bd" style="align-self:flex-start">enviar interesse</button>
          <p id="form-b2b-med-ok" style="display:none;font-size:13px;font-weight:400;color:var(--color-brand-text);margin-top:4px">Recebemos seu interesse. Entraremos em contato em breve.</p>
        </form>
        <script>
          import { initFormSubmit } from '../scripts/form-submit';
          initFormSubmit();
        </script>
      </div>
      <div class="r d2">
        <div style="background:var(--color-cream);padding:40px 34px;border:1px solid var(--color-stone)">
          <div class="lbl" style="margin-bottom:20px">áreas de atuação</div>
          <div style="display:flex;align-items:center;gap:13px;padding:10px 0;border-bottom:1px solid var(--color-stone)"><span style="width:5px;height:5px;border-radius:50%;background:var(--color-brand-mid);flex-shrink:0"></span><span style="font-size:13px;font-weight:400;color:var(--color-ink)">Medicina Metabólica e Endocrinologia</span></div>
          <div style="display:flex;align-items:center;gap:13px;padding:10px 0;border-bottom:1px solid var(--color-stone)"><span style="width:5px;height:5px;border-radius:50%;background:var(--color-brand-mid);flex-shrink:0"></span><span style="font-size:13px;font-weight:400;color:var(--color-ink)">Nutrologia e Emagrecimento</span></div>
          <div style="display:flex;align-items:center;gap:13px;padding:10px 0;border-bottom:1px solid var(--color-stone)"><span style="width:5px;height:5px;border-radius:50%;background:var(--color-brand-mid);flex-shrink:0"></span><span style="font-size:13px;font-weight:400;color:var(--color-ink)">Envelhecimento Saudável e Estilo de Vida</span></div>
          <div style="display:flex;align-items:center;gap:13px;padding:10px 0;border-bottom:1px solid var(--color-stone)"><span style="width:5px;height:5px;border-radius:50%;background:var(--color-brand-mid);flex-shrink:0"></span><span style="font-size:13px;font-weight:400;color:var(--color-ink)">Performance Cognitiva e Física</span></div>
          <div style="display:flex;align-items:center;gap:13px;padding:10px 0;border-bottom:1px solid var(--color-stone)"><span style="width:5px;height:5px;border-radius:50%;background:var(--color-brand-mid);flex-shrink:0"></span><span style="font-size:13px;font-weight:400;color:var(--color-ink)">Hipertrofia e Composição Corporal</span></div>
          <div style="display:flex;align-items:center;gap:13px;padding:10px 0;border-bottom:1px solid var(--color-stone)"><span style="width:5px;height:5px;border-radius:50%;background:var(--color-brand-mid);flex-shrink:0"></span><span style="font-size:13px;font-weight:400;color:var(--color-ink)">Hormonologia e Saúde Feminina e Masculina</span></div>
          <div style="display:flex;align-items:center;gap:13px;padding:10px 0;border-bottom:1px solid var(--color-stone)"><span style="width:5px;height:5px;border-radius:50%;background:var(--color-brand-mid);flex-shrink:0"></span><span style="font-size:13px;font-weight:400;color:var(--color-ink)">Implantes Subcutâneos Bioabsorvíveis</span></div>
          <div style="display:flex;align-items:center;gap:13px;padding:10px 0;border-bottom:1px solid var(--color-stone)"><span style="width:5px;height:5px;border-radius:50%;background:var(--color-brand-mid);flex-shrink:0"></span><span style="font-size:13px;font-weight:400;color:var(--color-ink)">Medicina do Esporte e Anabolismo Fisiológico</span></div>
          <div style="display:flex;align-items:center;gap:13px;padding:10px 0;border-bottom:1px solid var(--color-stone)"><span style="width:5px;height:5px;border-radius:50%;background:var(--color-brand-mid);flex-shrink:0"></span><span style="font-size:13px;font-weight:400;color:var(--color-ink)">Medicina Preventiva e Checkup Metabólico</span></div>
          <div style="display:flex;align-items:center;gap:13px;padding:10px 0;border-bottom:1px solid var(--color-stone)"><span style="width:5px;height:5px;border-radius:50%;background:var(--color-brand-mid);flex-shrink:0"></span><span style="font-size:13px;font-weight:400;color:var(--color-ink)">Testes Genéticos</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Metodologia -->
<section style="background:var(--color-ink);padding:86px 60px" aria-label="Metodologia">
  <div class="g2">
    <div>
      <div class="lbl lbl-lt r" style="margin-bottom:16px">metodologia</div>
      <h2 class="h2 h2-w r d1" style="margin-bottom:20px">Como <em>funciona</em><br>na prática.</h2>
      <p class="body body-lt r d2">Cada consulta começa com tempo real de escuta. Depois vêm os exames, a análise e o protocolo. Sempre nessa ordem, sempre centrado em você.</p>
    </div>
    <div class="st st-dk r d2">
      <div class="sr"><span class="sn">01</span><div><div class="st-t">Anamnese e escuta ativa</div><div class="st-b">Tempo real de escuta, sem pressa. Entendemos sua história, sintomas e objetivos antes de qualquer prescrição.</div></div></div>
      <div class="sr"><span class="sn">02</span><div><div class="st-t">Diagnóstico metabólico e genético</div><div class="st-b">Análise de biomarcadores, painel hormonal, composição corporal e, quando indicado, mapeamento genético para decisões ainda mais precisas.</div></div></div>
      <div class="sr"><span class="sn">03</span><div><div class="st-t">Protocolo baseado nos seus objetivos</div><div class="st-b">Construído com os dados colhidos e o que você quer alcançar. Pode incluir suplementação, injetáveis modernos, implantes bioabsorvíveis ou combinações multidisciplinares.</div></div></div>
      <div class="sr"><span class="sn">04</span><div><div class="st-t">Acompanhamento humanizado</div><div class="st-b">Retornos periódicos para ajustar o protocolo conforme sua evolução. Você não anda sozinho.</div></div></div>
    </div>
  </div>
</section>

<!-- Protocolos -->
<section style="background:var(--color-cream)" aria-label="Protocolos ecooa.med">
  <div class="w">
    <div class="lbl r" style="margin-bottom:16px">protocolos ecooa.med</div>
    <h2 class="h2 r d1" style="margin-bottom:44px">Programas que<br><em>entregam resultados.</em></h2>
    <div class="g3">
      <div class="ec r"><p class="ec-n">01</p><h3 class="ec-t">Saúde Hormonal Feminina</h3><p class="ec-d">Equilíbrio hormonal ao longo de todas as fases da vida da mulher. Inclui manejo clínico com implantes bioabsorvíveis de liberação lenta quando indicados clinicamente, com base em protocolos médicos atuais.</p></div>
      <div class="ec r"><p class="ec-n">02</p><h3 class="ec-t">Saúde Hormonal Masculina</h3><p class="ec-d">Avaliação completa da saúde hormonal masculina com protocolos individualizados para vitalidade, libido, composição corporal e bem-estar, incluindo terapia hormonal bioabsorvível quando aplicável.</p></div>
      <div class="ec r"><p class="ec-n">03</p><h3 class="ec-t">Emagrecimento com preços especiais</h3><p class="ec-d">Consultas com valores facilitados para emagrecimento, incluindo acompanhamento com canetas emagrecedoras (semaglutida, tirzepatida), protocolos manipulados e integração com nutrição.</p></div>
      <div class="ec r"><p class="ec-n">04</p><h3 class="ec-t">Acompanhamento com canetas emagrecedoras</h3><p class="ec-d">Consulta de anamnese completa, exames laboratoriais específicos para avaliar segurança no uso, e acompanhamento recorrente durante todo o processo, com preços facilitados.</p></div>
      <div class="ec r"><p class="ec-n">05</p><h3 class="ec-t">Saúde Capilar</h3><p class="ec-d">Investigação clínica da queda de cabelo com exames hormonais, metabólicos e, quando indicado, testes genéticos. Protocolos individualizados para tratamento e prevenção da alopecia.</p></div>
      <div class="ec r"><p class="ec-n">06</p><h3 class="ec-t">Performance e Esporte</h3><p class="ec-d">Para quem treina e quer extrair o máximo do corpo com inteligência. Protocolos de anabolismo fisiológico, NADH, aminoácidos, recuperação e composição corporal.</p></div>
      <div class="ec r"><p class="ec-n">07</p><h3 class="ec-t">Longevidade e Vitalidade</h3><p class="ec-d">Ciência aplicada ao envelhecimento saudável: peptídeos bioativos, micronutrientes e estratégias preventivas baseadas em biomarcadores e evidência clínica.</p></div>
      <div class="ec r"><p class="ec-n">08</p><h3 class="ec-t">Medicina Metabólica e Checkup</h3><p class="ec-d">Avaliação abrangente do metabolismo, saúde cardiovascular, função tireoidiana e perfil inflamatório para uma visão real do seu estado de saúde.</p></div>
    </div>
  </div>
</section>

<!-- Nosso Espaço -->
<section style="background:var(--color-warm);padding:0;overflow:hidden" aria-label="Espaço ecooa.med">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;padding:4px">
    <div style="aspect-ratio:16/9;overflow:hidden" class="r"><img src="/clinic/recepcao.webp" alt="Recepção da ecooa em Moinhos de Vento" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;display:block"  width="1000" height="1233" /></div>
    <div style="aspect-ratio:16/9;overflow:hidden" class="r d1"><img src="/clinic/cafe.webp" alt="Café da ecooa" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;display:block"  width="1200" height="799" /></div>
  </div>
</section>

<B2BBanner />

<!-- Perguntas frequentes -->
<section style="background:var(--color-warm)" aria-label="Perguntas frequentes">
  <div class="w">
    <div class="lbl r" style="margin-bottom:16px">perguntas frequentes</div>
    <h2 class="h2 r d1" style="margin-bottom:40px">Dúvidas sobre a<br><em>ecooa.med.</em></h2>
    <div class="faq-section">
      {medFaqs.map((faq) => (
        <details class="faq-item">
          <summary class="faq-q">{faq.q}</summary>
          <p class="faq-a">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- Como funciona -->
<section style="background:var(--color-cream)" aria-label="Como funciona">
  <div class="w">
    <div class="lbl r" style="margin-bottom:16px">sua jornada</div>
    <h2 class="h2 r d1" style="margin-bottom:44px">como <em>funciona</em></h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:32px;max-width:960px;margin:0 auto">
      <div class="r" style="text-align:center">
        <span style="display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:50%;border:1px solid var(--color-stone);font-family:var(--font-primary);font-size:16px;font-weight:400;color:var(--color-brand-text);margin-bottom:14px">1</span>
        <h3 style="font-size:15px;font-weight:400;color:var(--color-ink);margin-bottom:6px">Agendamento</h3>
        <p style="font-size:12px;font-weight:300;line-height:1.75;color:var(--color-ink-soft)">Entre em contato pelo WhatsApp. Respondemos em minutos e encontramos o melhor horário para você.</p>
      </div>
      <div class="r d1" style="text-align:center">
        <span style="display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:50%;border:1px solid var(--color-stone);font-family:var(--font-primary);font-size:16px;font-weight:400;color:var(--color-brand-text);margin-bottom:14px">2</span>
        <h3 style="font-size:15px;font-weight:400;color:var(--color-ink);margin-bottom:6px">Avaliação completa</h3>
        <p style="font-size:12px;font-weight:300;line-height:1.75;color:var(--color-ink-soft)">Consulta com tempo real de escuta, análise de exames e entendimento dos seus objetivos.</p>
      </div>
      <div class="r d2" style="text-align:center">
        <span style="display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:50%;border:1px solid var(--color-stone);font-family:var(--font-primary);font-size:16px;font-weight:400;color:var(--color-brand-text);margin-bottom:14px">3</span>
        <h3 style="font-size:15px;font-weight:400;color:var(--color-ink);margin-bottom:6px">Protocolo personalizado</h3>
        <p style="font-size:12px;font-weight:300;line-height:1.75;color:var(--color-ink-soft)">Plano construído com base nos seus dados, na sua rotina e no que você quer alcançar.</p>
      </div>
      <div class="r d3" style="text-align:center">
        <span style="display:inline-flex;align-items:center;justify-content:center;width:48px;height:48px;border-radius:50%;border:1px solid var(--color-stone);font-family:var(--font-primary);font-size:16px;font-weight:400;color:var(--color-brand-text);margin-bottom:14px">4</span>
        <h3 style="font-size:15px;font-weight:400;color:var(--color-ink);margin-bottom:6px">Acompanhamento</h3>
        <p style="font-size:12px;font-weight:300;line-height:1.75;color:var(--color-ink-soft)">Retornos periódicos para ajustar o protocolo e garantir que os resultados se mantenham.</p>
      </div>
    </div>
  </div>
</section>

<!-- Depoimentos -->
<section style="background:var(--color-cream)" aria-label="Depoimentos de pacientes">
  <div class="w">
    <div class="lbl r" style="margin-bottom:16px">depoimentos</div>
    <h2 class="h2 r d1" style="margin-bottom:44px">o que nossos pacientes <em>dizem</em></h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px">
      <div class="r" style="background:var(--color-white);border:1px solid var(--color-stone);padding:32px 28px">
        <p style="font-family:var(--font-serif);font-style:italic;font-size:14px;line-height:1.8;color:var(--color-ink);margin-bottom:16px">"A consulta durou quase uma hora. O médico olhou todos os meus exames anteriores, pediu novos e montou um plano que fez sentido. Em dois meses já senti diferença na disposição."</p>
        <p style="font-size:12px;font-weight:400;color:var(--color-ink-soft)">L. R.</p>
      </div>
      <div class="r d1" style="background:var(--color-white);border:1px solid var(--color-stone);padding:32px 28px">
        <p style="font-family:var(--font-serif);font-style:italic;font-size:14px;line-height:1.8;color:var(--color-ink);margin-bottom:16px">"Passei anos ouvindo que meus exames estavam normais, mesmo me sentindo mal. Aqui olharam tudo com profundidade e finalmente encontraram o que precisava ser ajustado."</p>
        <p style="font-size:12px;font-weight:400;color:var(--color-ink-soft)">D. B.</p>
      </div>
      <div class="r d2" style="background:var(--color-white);border:1px solid var(--color-stone);padding:32px 28px">
        <p style="font-family:var(--font-serif);font-style:italic;font-size:14px;line-height:1.8;color:var(--color-ink);margin-bottom:16px">"Comecei o acompanhamento para emagrecer e o protocolo foi completamente personalizado. O retorno é rápido e o médico realmente acompanha a evolução."</p>
        <p style="font-size:12px;font-weight:400;color:var(--color-ink-soft)">P. A.</p>
      </div>
    </div>
    <p class="r d3" style="text-align:center;margin-top:24px;font-size:11px;font-weight:300;color:var(--color-ink-soft);letter-spacing:.02em">Depoimentos reais publicados com autorização dos pacientes.</p>
  </div>
</section>

<!-- Artigos relacionados -->
{medPosts.length > 0 && (
<section style="background:var(--color-warm)" aria-label="Artigos relacionados">
  <div class="w">
    <div class="lbl r" style="margin-bottom:16px">do nosso blog</div>
    <h2 class="h2 r d1" style="margin-bottom:44px">artigos <em>relacionados</em></h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px">
      {medPosts.map((post, i) => (
        <a href={`/blog/${post.id}`} class={`r d${i}`} style="display:block;background:var(--color-cream);border:1px solid var(--color-stone);padding:28px 24px;text-decoration:none;transition:border-color .2s ease">
          <p style="font-size:11px;font-weight:400;color:var(--color-brand-text);letter-spacing:.04em;text-transform:lowercase;margin-bottom:10px">{post.data.category}</p>
          <h3 style="font-size:15px;font-weight:400;color:var(--color-ink);line-height:1.5;margin-bottom:8px">{post.data.title}</h3>
          <p style="font-size:12px;font-weight:300;line-height:1.7;color:var(--color-ink-soft)">{post.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>
)}

<CtaSection heading='Comece pela<br><em>avaliação.</em>' subtext="Agende sua primeira consulta e descubra como a medicina humanizada pode mudar sua qualidade de vida." />

