---
import BaseLayout from '../layouts/BaseLayout.astro';
import WavePattern from '../components/WavePattern.astro';
---

<BaseLayout
  title="Página não encontrada"
  description="A página que você procura não existe ou foi movida."
>

<div class="ph" style="background:var(--color-cream);min-height:60vh">
  <svg class="wsv u-op-26" viewBox="0 0 1440 400" preserveAspectRatio="xMidYMid slice" aria-hidden="true"><g fill="none" stroke="#C4BBB8" stroke-width="1"><WavePattern count={7} x0={-100} y0={80} step={55} width={1600} /></g></svg>
  <div class="ph-c">
    <div class="lbl r">404</div>
    <h1 class="h1 r d1 u-mt-18">Página não<br><em>encontrada.</em></h1>
    <p class="body r d2" style="margin-top:16px;max-width:440px">A página que você procura não existe ou foi movida. Veja se algum destes caminhos te ajuda:</p>
    <div style="display:flex;flex-direction:column;gap:12px;margin-top:28px" class="r d3">
      <a href="/" class="bd" style="text-align:center;max-width:280px">voltar para o início</a>
      <div style="display:flex;gap:12px;flex-wrap:wrap">
        <a href="/ecooa-med" class="ghost">medicina</a>
        <a href="/ecooa-esthetic" class="ghost">estética</a>
        <a href="/ecooa-mind" class="ghost">saúde mental</a>
        <a href="/ecooa-working" class="ghost">nutrição</a>
      </div>
      <a href="/blog" style="font-size:12px;font-weight:300;color:var(--color-ink-soft);margin-top:8px;text-decoration:underline;text-underline-offset:3px">ou leia nosso blog →</a>
    </div>
  </div>
</div>

</BaseLayout>
