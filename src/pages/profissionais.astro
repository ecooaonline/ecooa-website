    <div class="lbl r" style="margin-bottom:9px">ecooa.working</div>
    <h3 style="font-size:22px;font-weight:300;color:var(--color-ink);margin-bottom:36px;letter-spacing:-.02em" class="r d1">Nutrição especializada</h3>
    <div class="g4" style="margin-bottom:72px">
      <ProfessionalCard clickable name="Jessica Stein" role="Nutricionista · Veganos e Vegetarianos · Introdução Alimentar para Veganos · Análise Bioquímica · Emagrecimento" bg="linear-gradient(145deg,#DDD8D5,#C4BBB8)" ig="@jessicastein.nutri" photo="/team/jessica.webp" description="Nutricionista referência em nutrição vegana e vegetariana, com expertise em análise bioquímica e emagrecimento." tags={["Nutrição Vegana", "Emagrecimento", "Análise Bioquímica"]} />
      <ProfessionalCard clickable name="Maria Luísa Beltran" role="Nutricionista · Performance Esportiva · Composição Corporal · Veganos e Vegetarianos" bg="linear-gradient(145deg,#D8D3CF,#BEB5B2)" ig="@marialuisabeltran.nutri" photo="/team/maria-luisa.webp" description="Nutricionista esportiva com foco em performance e composição corporal. Atleta de Crossfit." tags={["Performance Esportiva", "Composição Corporal", "Nutrição Vegana"]} />
      <ProfessionalCard clickable name="Adriano Lenz" role="Nutricionista · Ortomolecular · Metabolômica · Nutrigenômica" bg="linear-gradient(145deg,#E2DDD9,#C8C0BC)" ig="@adrianolenz" photo="/team/adriano.webp" description="Nutricionista com abordagem ortomolecular, metabolômica e nutrigenômica. Protocolos personalizados baseados em genética." tags={["Ortomolecular", "Metabolômica", "Nutrigenômica"]} />
      <ProfessionalCard clickable name="Giancarla Rochemback" role="Nutricionista · Performance Esportiva · Composição Corporal" bg="linear-gradient(145deg,#D5D0CC,#BAB2AE)" ig="@gi_rochemback" photo="/team/giancarla.webp" description="Nutricionista focada em performance esportiva e otimização de composição corporal." tags={["Performance Esportiva", "Composição Corporal"]} />
      <ProfessionalCard clickable name="Vitoria Serpa" role="Nutricionista · Performance Esportiva · Composição Corporal" bg="linear-gradient(145deg,#DDD8D5,#C4BBB8)" ig="@vitoriaserpa" photo="/team/vitoria-serpa.webp" description="Nutricionista esportiva especializada em composição corporal e performance de alta intensidade." tags={["Performance Esportiva", "Composição Corporal"]} />
      <ProfessionalCard clickable name="Lara Caye" role="Nutricionista · Performance Esportiva · Composição Corporal" bg="linear-gradient(145deg,#D8D3CF,#BEB5B2)" ig="@laracaye" photo="/team/lara-caye.webp" description="Nutricionista com foco em performance esportiva e resultados de composição corporal." tags={["Performance Esportiva", "Composição Corporal"]} />
      <ProfessionalCard clickable name="Gabrieli Klagenberg" role="Nutricionista · Nutrição Comportamental" bg="linear-gradient(145deg,#E2DDD9,#C8C0BC)" ig="@gabrieliklagenberg" photo="/team/gabrielli.webp" description="Nutricionista com abordagem comportamental. Trabalho integrado entre alimentação, emoções e hábitos." tags={["Nutrição Comportamental", "Hábitos Alimentares"]} />
      <ProfessionalCard clickable name="Daniel Forster" role="Nutricionista" bg="linear-gradient(145deg,#D5D0CC,#BAB2AE)" ig="@daniel.nutricionista" photo="/team/daniel-forster.webp" description="Nutricionista com abordagem integrada e personalizada para diferentes objetivos de saúde." tags={["Nutrição Clínica", "Personalizada"]} />
      <ProfessionalCard clickable name="Marvin Marques" role="Nutricionista" bg="linear-gradient(145deg,#DDD8D5,#C4BBB8)" ig="@nutrimarvin" photo="/team/marvin.webp" description="Nutricionista com atendimento personalizado e foco em resultados práticos e sustentáveis." tags={["Nutrição", "Resultados Sustentáveis"]} />
      <ProfessionalCard clickable name="Camila Cadore" role="Nutricionista" bg="linear-gradient(145deg,#D8D3CF,#BEB5B2)" ig="@nutricamilacadore" photo="/team/camila-cadore.webp" description="Nutricionista com abordagem humanizada e personalizada para cada fase da vida." tags={["Nutrição", "Personalizada"]} />
      <ProfessionalCard clickable name="Nasser Salem" role="Nutricionista" bg="linear-gradient(145deg,#E2DDD9,#C8C0BC)" ig="@nutri.nasser_" photo="/team/nasser.webp" description="Nutricionista com foco em resultados e acompanhamento contínuo." tags={["Nutrição", "Acompanhamento"]} />
      <ProfessionalCard clickable name="Verena Cattani" role="Nutricionista" bg="linear-gradient(145deg,#D5D0CC,#BAB2AE)" ig="@nutriverena" photo="/team/verena.webp" description="Nutricionista com atendimento integrado ao ecossistema ecooa." tags={["Nutrição", "Integrada"]} />
