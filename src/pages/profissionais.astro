      <ProfessionalCard clickable name="Leticia de Melo" role="Biomédica · Estética · HOF" bg="linear-gradient(145deg,#E2DDD9,#C8C0BC)" ig="@draleticiademelo" photo="/team/leticia.webp" description="Biomédica especialista em estética facial e harmonização orofacial com técnica refinada." tags={["Biomedicina Estética", "HOF", "Estética Facial"]} />
      <ProfessionalCard clickable name="Jennifer Adam" role="Biomédica · Estética · HOF" bg="linear-gradient(145deg,#D5D0CC,#BAB2AE)" ig="@dra.jenniferadam" photo="/team/jennifer-adam.webp" description="Biomédica com atuação em estética avançada e harmonização orofacial." tags={["Biomedicina Estética", "HOF", "Estética Avançada"]} />
      <ProfessionalCard clickable name="Jamylle Farias" role="Odontóloga · Estética · HOF" bg="linear-gradient(145deg,#DDD8D5,#C4BBB8)" ig="@drajamyllefarias" photo="/team/jamylle.webp" description="Odontóloga com especialização em estética e harmonização orofacial. Resultados naturais e sofisticados." tags={["Odontologia", "HOF", "Estética"]} />
      <ProfessionalCard clickable slug="adriana" name="Adriana" role="Terapeuta Integrativa · Biorressonância" bg="linear-gradient(145deg,#D8D3CF,#BEB5B2)" photo="/team/ortomolecular.webp" description="Terapeuta integrativa com foco em biorressonância. Abordagem complementar para equilíbrio e bem-estar." tags={["Terapia Integrativa", "Biorressonância", "Bem-estar"]} />
    </div>

    <!-- Nutrição -->
