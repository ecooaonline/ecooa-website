---
import BaseLayout from '../layouts/BaseLayout.astro';
import WavePattern from '../components/WavePattern.astro';
import Marquee from '../components/Marquee.astro';
import ProfessionalCard from '../components/ProfessionalCard.astro';
import B2BBanner from '../components/B2BBanner.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_BASE } from '../data/constants';
import { professionals } from '../data/professionals';

const WA = WA_BASE;

const SITE_URL = 'https://www.somosecooa.com.br';

// Ordem editorial dos cards por seção (definida pela gestão da clínica).
// Para reordenar, mude apenas estas listas; os dados dos cards (nome, cargo,
// registro, foto, tags) vêm de professionals.ts.
const MED_ORDER = [
  'gustavo-gehrke',
  'yale-jeronimo',
  'larissa-wiebbelling',
  'vitoria-machado',
  'renata-bohn',
];
const ESTHETIC_ORDER_A = [
  'danusa-pires',
  'viviane-fagundes',
  'natalie-queiroz',
  'leticia-de-melo',
  'cris-neumann',
  'susan-flach',
  'jennifer-adam',
];
// Eduarda e Tais (cards sem foto, aguardando material) entram entre A e B.
const ESTHETIC_ORDER_B = ['karine-ellwanger', 'jamylle-farias', 'adriana'];
const WORKING_ORDER = [
  'jessica-stein',
  'maria-luisa-beltran',
  'adriano-lenz',
  'giancarla-rochemback',
  'vitoria-serpa',
  'lara-caye',
  'daniel-forster',
  'camila-cadore',
  'marvin-marques',
  'gabrieli-klagenberg',
  'nasser-salem',
  'verena-cattani',
];
const MIND_ORDER = ['manuela-vanti', 'augusto-kauer', 'francielle-beria'];
const CARD_BG = 'linear-gradient(145deg,#DDD8D5,#C4BBB8)';

function inOrder(slugs: string[]) {
  return slugs
    .map((slug) => professionals.find((p) => p.slug === slug))
    .filter((p): p is (typeof professionals)[number] => Boolean(p));
}

function isPhysician(role: string) {
  return /\bMédic[oa]\b/i.test(role);
}

function medicalSpecialty(role: string): string | null {
  const lower = role.toLowerCase();
  if (lower.includes('dermato') || lower.includes('capilar') || lower.includes('tricolog'))
    return 'Dermatology';
  if (lower.includes('psiquiatr')) return 'Psychiatric';
  if (lower.includes('cardiolog')) return 'Cardiovascular';
  if (lower.includes('endocrin')) return 'Endocrine';
  if (
    lower.includes('ortomolecular') ||
    lower.includes('metabol') ||
    lower.includes('hormôn') ||
    lower.includes('longevidade') ||
    lower.includes('emagrecimento')
  )
    return 'PrimaryCare';
  return 'PrimaryCare';
}

const schemaMembers = professionals.map((p) => {
  const base = {
    name: p.name,
    description: p.description,
    worksFor: { '@type': 'MedicalBusiness', name: 'ecooa' },
    image: `${SITE_URL}${p.photo}`,
    url: `${SITE_URL}/profissionais/${p.slug}`,
  };
  if (isPhysician(p.role)) {
    return { '@type': 'Physician', ...base, medicalSpecialty: medicalSpecialty(p.role) };
  }
  return { '@type': 'Person', ...base, jobTitle: p.role.split('·')[0].trim() };
});
---

<BaseLayout
  title="Profissionais"
  description="Especialistas da ecooa. Médicos, nutricionistas, psicólogos e profissionais de estética em Moinhos de Vento, Porto Alegre."
  currentPage="profissionais"
  ogImage="/clinic/reuniao-edit.webp"
  breadcrumbs={[{ name: 'Profissionais', url: '/profissionais' }]}
>
  <!-- Hero -->
  <div class="ph u-bg-cream">
    <svg
      class="wsv u-op-26"
      viewBox="0 0 1440 500"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
      ><g fill="none" stroke="#C4BBB8" stroke-width="1"
        ><WavePattern count={8} x0={-100} y0={80} step={55} width={1600} /></g
      ></svg
    >
    <div class="ph-c">
      <div class="lbl r">corpo clínico</div>
      <h1 class="h1 r d1 u-mt-18">Especialistas que<br /><em>definem padrões.</em></h1>
      <p class="body r d2" style="margin-top:16px;max-width:480px">
        Uma equipe multidisciplinar reunida em torno de um propósito: oferecer o melhor cuidado
        possível, com humanidade e excelência técnica.
      </p>
      <a
        href="/match"
        class="bo r d3"
        style="margin-top:20px;display:inline-flex;align-items:center;gap:8px"
        data-intent="profissionais-match"
      >
        não sabe com quem agendar? use o ecooa.match
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>

  <!-- Professionals Structured Data -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'MedicalOrganization',
      name: 'ecooa',
      url: `${SITE_URL}/profissionais`,
      member: schemaMembers,
    })}
  />

  <Marquee />

  <!-- Profissionais -->
  <section class="u-bg-warm" aria-label="Equipe de profissionais">
    <div class="w">
      <!-- Medicina -->
      <div class="div" style="margin:0 0 64px"></div>
      <div class="lbl r" style="margin-bottom:9px">ecooa.med</div>
      <h2
        style="font-size:22px;font-weight:300;color:var(--color-ink);margin-bottom:32px;letter-spacing:-.02em"
        class="r d1"
      >
        Medicina
      </h2>
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:36px" class="r">
        <span class="tag-pill">Medicina Metabólica</span>
        <span class="tag-pill">Dermatologia Clínica</span>
        <span class="tag-pill">Dermatologia Estética</span>
        <span class="tag-pill">Tricologia Médica</span>
        <span class="tag-pill">Transplante Capilar</span>
      </div>
      <div class="g4" style="margin-bottom:72px">
        {
          inOrder(MED_ORDER).map((p) => (
            <ProfessionalCard
              clickable
              slug={p.slug}
              name={p.name}
              role={p.role}
              bg={CARD_BG}
              ig={p.ig}
              photo={p.photo}
              description={p.description}
              tags={p.tags}
            />
          ))
        }
      </div>

      <!-- Estética -->
      <div class="div" style="margin:0 0 64px"></div>
      <div class="lbl r u-mb-18">ecooa.esthetic</div>
      <h2 class="sr-only">Estética</h2>
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:36px" class="r">
        <span class="tag-pill">Tricologia</span>
        <span class="tag-pill">Biomedicina Estética</span>
        <span class="tag-pill">Harmonização Orofacial</span>
        <span class="tag-pill">Fisioterapia Dermatofuncional</span>
        <span class="tag-pill">Osteopatia</span>
      </div>
      <div class="g4" style="margin-bottom:72px">
        {
          inOrder(ESTHETIC_ORDER_A).map((p) => (
            <ProfessionalCard
              clickable
              slug={p.slug}
              name={p.name}
              role={p.role}
              bg={CARD_BG}
              ig={p.ig}
              photo={p.photo}
              description={p.description}
              tags={p.tags}
            />
          ))
        }
        <ProfessionalCard
          name="Eduarda Schoenmeier"
          role="Biomédica Esteta · Harmonização Facial e Corporal"
          bg={CARD_BG}
          registration="CRBM 7243"
        />
        <ProfessionalCard
          name="Tais de la Rosa"
          role="Farmacêutica · Skin Expert"
          bg={CARD_BG}
          registration="CRF-RS 588527"
        />

        {
          inOrder(ESTHETIC_ORDER_B).map((p) => (
            <ProfessionalCard
              clickable
              slug={p.slug}
              name={p.name}
              role={p.role}
              bg={CARD_BG}
              ig={p.ig}
              photo={p.photo}
              description={p.description}
              tags={p.tags}
            />
          ))
        }
      </div>

      <!-- Nutrição -->
      <div class="div" style="margin:0 0 64px"></div>
      <div class="lbl r" style="margin-bottom:9px">ecooa.working</div>
      <h2
        style="font-size:22px;font-weight:300;color:var(--color-ink);margin-bottom:36px;letter-spacing:-.02em"
        class="r d1"
      >
        Nutrição especializada
      </h2>
      <div class="g4" style="margin-bottom:72px">
        {
          inOrder(WORKING_ORDER).map((p) => (
            <ProfessionalCard
              clickable
              slug={p.slug}
              name={p.name}
              role={p.role}
              bg={CARD_BG}
              ig={p.ig}
              photo={p.photo}
              description={p.description}
              tags={p.tags}
            />
          ))
        }
      </div>

      <!-- Saúde Mental -->
      <div class="div" style="margin:0 0 64px"></div>
      <div class="lbl r" style="margin-bottom:9px">ecooa.mind</div>
      <h2
        style="font-size:22px;font-weight:300;color:var(--color-ink);margin-bottom:18px;letter-spacing:-.02em"
        class="r d1"
      >
        Saúde mental
      </h2>
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:36px" class="r">
        <span class="tag-pill">Psicologia</span>
        <span class="tag-pill">Psiquiatria</span>
        <span class="tag-pill">Terapia Holística</span>
      </div>
      <div class="g4 u-mb-64">
        {
          inOrder(MIND_ORDER).map((p) => (
            <ProfessionalCard
              clickable
              slug={p.slug}
              name={p.name}
              role={p.role}
              bg={CARD_BG}
              ig={p.ig}
              photo={p.photo}
              description={p.description}
              tags={p.tags}
            />
          ))
        }
      </div>
    </div>
  </section>

  <B2BBanner />

  <CtaSection
    heading="Conheça nossa<br><em>equipe pessoalmente.</em>"
    subtext="Agende sua avaliação e descubra qual profissional da ecooa é o ideal para o seu momento."
  />

  <!-- Modal overlay -->
  <div
    class="pro-modal-overlay"
    id="pro-modal-overlay"
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-labelledby="pm-name"
  >
    <div class="pro-modal" id="pro-modal">
      <button class="pro-modal-close" id="pro-modal-close" aria-label="Fechar">✕</button>
      <img
        class="pro-modal-photo"
        id="pm-photo"
        src=""
        alt=""
        loading="lazy"
        decoding="async"
        width="480"
        height="640"
      />
      <div class="pro-modal-info">
        <p class="pro-modal-name" id="pm-name"></p>
        <p class="pro-modal-role" id="pm-role"></p>
        <p class="pro-modal-desc" id="pm-desc"></p>
        <div class="pro-modal-tags" id="pm-tags"></div>
        <div class="pro-modal-actions">
          <a id="pm-wa" href="#" target="_blank" rel="noopener noreferrer" class="bd"
            >agendar avaliação</a
          >
          <a
            id="pm-ig"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="ghost"
            style="justify-content:center"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true"
              ><rect
                x="2"
                y="2"
                width="20"
                height="20"
                rx="6"
                stroke="currentColor"
                stroke-width="1.5"></rect><circle
                cx="12"
                cy="12"
                r="4"
                stroke="currentColor"
                stroke-width="1.5"></circle><circle cx="17" cy="7" r=".8" fill="currentColor"
              ></circle></svg
            >
            <span id="pm-ig-label"></span>
          </a>
          <a id="pm-profile" href="#" class="ghost" style="justify-content:center;font-size:11px"
            >ver perfil completo →</a
          >
        </div>
      </div>
    </div>
  </div>

  <script>
    const overlay = document.getElementById('pro-modal-overlay')!;
    const modal = document.getElementById('pro-modal')!;
    const closeBtn = document.getElementById('pro-modal-close')!;
    const pmPhoto = document.getElementById('pm-photo') as HTMLImageElement;
    const pmName = document.getElementById('pm-name')!;
    const pmRole = document.getElementById('pm-role')!;
    const pmDesc = document.getElementById('pm-desc')!;
    const pmTags = document.getElementById('pm-tags')!;
    const pmWa = document.getElementById('pm-wa') as HTMLAnchorElement;
    const pmIg = document.getElementById('pm-ig') as HTMLAnchorElement;
    const pmIgLabel = document.getElementById('pm-ig-label')!;
    const pmProfile = document.getElementById('pm-profile') as HTMLAnchorElement;

    function openModal(card: HTMLElement) {
      const name = card.dataset.name || '';
      const role = card.dataset.role || '';
      const photo = card.dataset.photo || '';
      const ig = card.dataset.ig || '';
      const igUrl = card.dataset.igUrl || '';
      const wa = card.dataset.wa || '';
      const desc = card.dataset.desc || '';
      const tags = card.dataset.tags ? card.dataset.tags.split('|') : [];

      pmPhoto.src = photo;
      pmPhoto.alt = name;
      pmName.textContent = name;
      pmRole.textContent = role;
      pmDesc.textContent = desc;
      pmTags.textContent = '';
      tags.forEach((t) => {
        const span = document.createElement('span');
        span.className = 'pro-modal-tag';
        span.textContent = t;
        pmTags.appendChild(span);
      });
      pmWa.href = wa;
      pmWa.setAttribute('data-professional-name', name);
      if (igUrl) {
        pmIg.href = igUrl;
        pmIgLabel.textContent = ig;
        pmIg.style.display = '';
      } else {
        pmIg.style.display = 'none';
      }
      const slug = card.dataset.slug || '';
      if (slug) {
        pmProfile.href = `/profissionais/${slug}`;
        pmProfile.style.display = '';
      } else {
        pmProfile.style.display = 'none';
      }

      overlay.classList.add('active');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    }

    let lastOpenerCard: HTMLElement | null = null;

    function closeModal() {
      overlay.classList.remove('active');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lastOpenerCard?.focus?.();
      lastOpenerCard = null;
    }

    // Click on card
    document.querySelectorAll('[data-modal="professional"]').forEach((card) => {
      card.addEventListener('click', () => {
        lastOpenerCard = card as HTMLElement;
        openModal(card as HTMLElement);
      });
      card.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          lastOpenerCard = card as HTMLElement;
          openModal(card as HTMLElement);
        }
      });
    });

    // Close
    closeBtn.addEventListener('click', closeModal);
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (!overlay.classList.contains('active')) return;
      if (e.key === 'Escape') {
        closeModal();
        return;
      }
      if (e.key === 'Tab') {
        const focusable = Array.from(
          modal.querySelectorAll<HTMLElement>(
            'button:not([disabled]),a[href],input:not([disabled]),[tabindex]:not([tabindex="-1"])'
          )
        ).filter((el) => el.offsetParent !== null);
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });
  </script>
</BaseLayout>
