---
import BaseLayout from '../layouts/BaseLayout.astro';
import WavePattern from '../components/WavePattern.astro';
import Marquee from '../components/Marquee.astro';
import ProfessionalCard from '../components/ProfessionalCard.astro';
import B2BBanner from '../components/B2BBanner.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_BASE } from '../data/constants';

const WA = WA_BASE;
---

<BaseLayout
  title="Profissionais"
  description="Conheça os especialistas da ecooa. Equipe multidisciplinar de médicos, nutricionistas, psicólogos e profissionais de estética em Moinhos de Vento, Porto Alegre."
  currentPage="profissionais"
  ogImage="/clinic/reuniao-edit.webp"
  breadcrumbs={[{ name: "Profissionais", url: "/profissionais" }]}
>

<!-- Hero -->
<div class="ph" style="background:var(--color-cream)">
  <svg class="wsv" style="opacity:.26" viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true"><g fill="none" stroke="#C4BBB8" stroke-width="1"><WavePattern count={8} x0={-100} y0={80} step={55} width={1600} /></g></svg>
  <div class="ph-c">
    <div class="lbl r">corpo clínico</div>
    <h1 class="h1 r d1" style="margin-top:18px">Especialistas que<br><em>definem padrões.</em></h1>
    <p class="body r d2" style="margin-top:16px;max-width:480px">Uma equipe multidisciplinar reunida em torno de um propósito: oferecer o melhor cuidado possível, com humanidade e excelência técnica.</p>
  </div>
</div>

<!-- Professionals Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "MedicalOrganization",
  "name": "ecooa",
  "url": "https://www.somosecooa.com.br/profissionais",
  "member": [
    { "@type": "Physician", "name": "Gustavo Gehrke", "medicalSpecialty": "General Practice", "description": "Medicina de alta performance com foco em diagnóstico metabólico, equilíbrio hormonal e emagrecimento.", "worksFor": { "@type": "MedicalBusiness", "name": "ecooa" }, "image": "https://www.somosecooa.com.br/team/gustavo.webp" },
    { "@type": "Physician", "name": "Yale Jeronimo", "medicalSpecialty": "Dermatology", "description": "Médica tricologista com expertise em diagnóstico e tratamento de alopecias.", "worksFor": { "@type": "MedicalBusiness", "name": "ecooa" }, "image": "https://www.somosecooa.com.br/team/yale.webp" },
    { "@type": "Physician", "name": "Larissa Wiebbelling", "medicalSpecialty": "Dermatology", "description": "Médica especialista em transplante e implante capilar com técnicas avançadas FUE e Sapphire.", "worksFor": { "@type": "MedicalBusiness", "name": "ecooa" }, "image": "https://www.somosecooa.com.br/team/larissa.webp" },
    { "@type": "Physician", "name": "Vitoria Machado", "medicalSpecialty": "Dermatology", "description": "Médica dermatologista com foco em estética e rejuvenescimento facial.", "worksFor": { "@type": "MedicalBusiness", "name": "ecooa" }, "image": "https://www.somosecooa.com.br/team/vitoria.webp" },
    { "@type": "Physician", "name": "Renata Bohn", "medicalSpecialty": "Dermatology", "description": "Dermatologista com atuação em dermatologia clínica e estética.", "worksFor": { "@type": "MedicalBusiness", "name": "ecooa" }, "image": "https://www.somosecooa.com.br/team/renata.webp" },
    { "@type": "Person", "name": "Jessica Stein", "jobTitle": "Nutricionista", "description": "Nutricionista referência em nutrição vegana e vegetariana.", "worksFor": { "@type": "MedicalBusiness", "name": "ecooa" }, "image": "https://www.somosecooa.com.br/team/jessica.webp" },
    { "@type": "Person", "name": "Maria Luisa Beltran", "jobTitle": "Nutricionista Esportiva", "description": "Nutricionista esportiva com foco em performance e composição corporal.", "worksFor": { "@type": "MedicalBusiness", "name": "ecooa" }, "image": "https://www.somosecooa.com.br/team/maria-luisa.webp" },
    { "@type": "Person", "name": "Manuela Vanti", "jobTitle": "Psicóloga Clínica", "description": "Psicóloga clínica com abordagem em Terapia Cognitivo-Comportamental.", "worksFor": { "@type": "MedicalBusiness", "name": "ecooa" }, "image": "https://www.somosecooa.com.br/team/manuela.webp" }
  ]
})} />

<Marquee />

<!-- Profissionais -->
<section style="background:var(--color-warm)" aria-label="Equipe de profissionais">
  <div class="w">

    <!-- Medicina -->
    <div class="div" style="margin:0 0 64px"></div>
    <div class="lbl r" style="margin-bottom:9px">ecooa.med</div>
    <h3 style="font-size:22px;font-weight:300;color:var(--color-ink);margin-bottom:32px;letter-spacing:-.02em" class="r d1">Medicina</h3>
    <div class="g4" style="margin-bottom:72px">
      <ProfessionalCard clickable name="Gustavo Gehrke" role="Médico Generalista · Metabolismo · Hormônios · Emagrecimento · Estilo de Vida" bg="linear-gradient(145deg,#DDD8D5,#C4BBB8)" ig="@gustavogehrke" photo="/team/gustavo.webp" description="Medicina de alta performance com foco em diagnóstico metabólico preciso, equilíbrio hormonal e emagrecimento saudável." tags={["Metabolismo", "Hormônios", "Emagrecimento", "Longevidade", "Estilo de Vida"]} />
    </div>

    <!-- Estética -->
    <div class="div" style="margin:0 0 64px"></div>
    <div class="lbl r" style="margin-bottom:18px">ecooa.esthetic</div>
    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:36px" class="r">
      <span style="font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-ink);border:1px solid var(--color-stone);padding:6px 14px">Dermatologia Clínica</span>
      <span style="font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-ink);border:1px solid var(--color-stone);padding:6px 14px">Dermatologia Estética</span>
      <span style="font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-ink);border:1px solid var(--color-stone);padding:6px 14px">Tricologia</span>
      <span style="font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-ink);border:1px solid var(--color-stone);padding:6px 14px">Transplante Capilar</span>
      <span style="font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-ink);border:1px solid var(--color-stone);padding:6px 14px">Biomedicina Estética</span>
      <span style="font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-ink);border:1px solid var(--color-stone);padding:6px 14px">Fisioterapia Dermatofuncional</span>
      <span style="font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-ink);border:1px solid var(--color-stone);padding:6px 14px">Osteopatia</span>
