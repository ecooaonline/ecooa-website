---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import HeroEditorial from '../components/HeroEditorial.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_BASE, FORM_ACTION, ADDRESS_NEIGHBORHOOD } from '../data/constants';
import { medAreas } from '../data/specialties';

const WA_B2B = `${WA_BASE}?text=${encodeURIComponent('Olá, sou profissional de saúde e gostaria de saber mais sobre atender na ecooa')}`;

// As 9 bandeiras da casa: manifesto intacto, grade 3x3.
const bandeiras = [
  'É possível ter o seu próprio negócio',
  'Acredite e viva o processo',
  'Trabalho em equipe nos leva mais longe',
  'Acreditamos em inovação em saúde',
  'Priorizamos e cultivamos a excelência',
  'Acreditamos em uma gestão humanizada',
  'Não aceitamos exploração',
  'Acreditamos no multidisciplinar',
  'Competição não define meu lugar',
];
---

<BaseLayout
  title="Para Profissionais de Saúde"
  description="Atenda na ecooa: consultórios premium em Moinhos de Vento, Porto Alegre, para médicos, nutricionistas, psicólogos e profissionais da estética. Ecossistema multidisciplinar com recepção dedicada."
  currentPage="para-profissionais"
  ogImage="/clinic/respire.webp"
  breadcrumbs={[{ name: 'Para Profissionais', url: '/para-profissionais' }]}
>
  <HeroEditorial
    label="para profissionais de saúde"
    title="Atenda na<br /><em>ecooa.</em>"
    sub={`Consultórios premium em ${ADDRESS_NEIGHBORHOOD} para médicos, nutricionistas, psicólogos e profissionais da estética. Um ecossistema que valoriza a sua prática e conecta você a uma rede multidisciplinar.`}
    ctaHref={WA_B2B}
    ctaLabel="falar pelo whatsapp"
    ctaIntent="b2b-hero"
    secondaryHref="#interesse"
    secondaryLabel="enviar interesse"
    image="/clinic/recepcao.webp"
    imageAlt="Recepção da ecooa em Moinhos de Vento"
    imageCaption="recepção · 9º andar · moinhos de vento"
    vertical="um espaço para quem cuida"
  />

  <!-- Por que a ecooa + o espaço -->
  <section
    style="background:var(--color-warm);padding:104px var(--section-px)"
    aria-label="Por que atender na ecooa"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="g2 g2c">
        <div>
          <div class="lbl r">por que a ecooa</div>
          <h2 class="h2 r d1" style="margin-top:15px">
            Um espaço que eleva<br />a sua <em>prática.</em>
          </h2>
          <p class="body r d2" style="margin-top:18px;max-width:480px">
            A ecooa nasceu para unir profissionais que acreditam que a saúde deve ser integral,
            humanizada e ética. Aqui, você atende em um ambiente sofisticado, com estrutura completa
            e ao lado de uma equipe que compartilha casos, conhecimento e propósito.
          </p>
        </div>
        <div class="st r d2">
          <div class="sr">
            <span class="sn">01</span><div>
              <div class="st-t">Valor para o profissional</div><div class="st-b">
                O ambiente sofisticado eleva a percepção do seu trabalho, fortalece sua marca
                pessoal e atrai pacientes que valorizam excelência.
              </div>
            </div>
          </div>
          <div class="sr">
            <span class="sn">02</span><div>
              <div class="st-t">Networking multidisciplinar</div><div class="st-b">
                Médicos, nutricionistas, psicólogos e profissionais da estética no mesmo
                ecossistema, com encaminhamentos internos e trabalho em equipe.
              </div>
            </div>
          </div>
          <div class="sr">
            <span class="sn">03</span><div>
              <div class="st-t">Infraestrutura premium</div><div class="st-b">
                9 salas equipadas, recepção dedicada, café e áreas comuns que refletem o padrão
                ecooa em Moinhos de Vento.
              </div>
            </div>
          </div>
        </div>
      </div>
      <div
        class="r d3"
        style="margin-top:72px;display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:26px"
      >
        <figure class="lux-frame" style="margin:0">
          <OptimizedImage
            src="/clinic/recepcao.webp"
            alt="Recepção da ecooa"
            width={1000}
            height={1233}
            class="lux-frame-img"
          />
          <figcaption class="lux-caption">recepção dedicada</figcaption>
        </figure>
        <figure class="lux-frame" style="margin:0">
          <OptimizedImage
            src="/clinic/respire.webp"
            alt="Sala Respire da ecooa"
            width={1200}
            height={799}
            class="lux-frame-img"
          />
          <figcaption class="lux-caption">sala respire</figcaption>
        </figure>
        <figure class="lux-frame" style="margin:0">
          <OptimizedImage
            src="/clinic/cafe.webp"
            alt="Café da ecooa"
            width={1200}
            height={799}
            class="lux-frame-img"
          />
          <figcaption class="lux-caption">café ecooa</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Bandeiras: manifesto em pontuação escura -->
  <section
    style="background:var(--color-ink);padding:104px var(--section-px)"
    aria-label="Nossas bandeiras"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl lbl-lt r" style="margin-bottom:16px">o que nos move</div>
      <h2 class="h2 h2-w r d1" style="margin-bottom:56px">Nossas <em>bandeiras.</em></h2>
      <div class="band-grid r d2">
        {
          bandeiras.map((b, i) => (
            <div class="band-cell">
              <p class="band-num">{String(i + 1).padStart(2, '0')}</p>
              <p class="band-text">{b}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Processo 1-2-3 -->
  <section
    style="background:var(--color-cream);padding:104px var(--section-px)"
    aria-label="Como funciona"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl r" style="justify-content:center;margin-bottom:16px">como funciona</div>
      <h2 class="h2 r d1 u-tac" style="margin-bottom:56px">
        Do primeiro contato<br />à <em>parceria.</em>
      </h2>
      <div
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:32px;max-width:800px;margin:0 auto"
      >
        <div class="r u-tac">
          <span class="step-num">1</span>
          <h3 class="it-t">Contato inicial</h3>
          <p class="it-d">Nos fale sobre você e sua prática pelo WhatsApp ou pelo formulário.</p>
        </div>
        <div class="r d1 u-tac">
          <span class="step-num">2</span>
          <h3 class="it-t">Visita ao espaço</h3>
          <p class="it-d">Conheça pessoalmente a estrutura, a equipe e a cultura ecooa.</p>
        </div>
        <div class="r d2 u-tac">
          <span class="step-num">3</span>
          <h3 class="it-t">Alinhamento e contrato</h3>
          <p class="it-d">Definimos juntos o melhor modelo de uso e formalizamos a parceria.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Rede médica + formulário de interesse -->
  <section
    id="interesse"
    style="background:var(--color-warm);padding:104px var(--section-px)"
    aria-label="Áreas de atuação e formulário de interesse"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="g2 g2c">
        <div>
          <div class="lbl r">áreas médicas na ecooa.med</div>
          <h2 class="h2 r d1" style="margin-top:15px">
            Uma rede de<br />especialistas que<br /><em>se entendem.</em>
          </h2>
          <p class="body r d2" style="margin-top:18px">
            Liderada pelo Dr. Gustavo Gehrke, a ecooa.med une médicos que atuam nas mais diversas
            áreas. Sem pressa a cada atendimento, com escuta total ao paciente e trabalho
            multiprofissional.
          </p>
          <p class="body r d3" style="margin-top:13px">
            Você é médico e quer atender na ecooa? Preencha o formulário abaixo ou <a
              href={WA_B2B}
              target="_blank"
              rel="noopener noreferrer"
              style="color:var(--color-brand-text);text-underline-offset:3px;text-decoration:underline"
              >fale pelo WhatsApp</a
            >.
          </p>
          <form
            action={FORM_ACTION}
            method="POST"
            class="b2b-form r d4 ecooa-form"
            id="form-b2b-med"
            data-ok-target="#form-b2b-med-ok"
            data-success-text="Recebemos seu interesse. Entraremos em contato em breve."
          >
            <input type="hidden" name="_formType" value="b2b-medicina" />
            <input type="hidden" name="_next" value="" />
            <input
              type="text"
              name="_honeypot"
              style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
            <input type="hidden" name="_loadedAt" value="" />
            <input
              type="text"
              name="nome"
              placeholder="Nome completo"
              required
              minlength="2"
              class="b2b-input b2b-light"
              aria-label="Nome completo"
            />
            <input
              type="tel"
              name="whatsapp"
              placeholder="WhatsApp: (51) 99999-9999"
              required
              pattern="[\s()+\-0-9]{10,20}"
              class="b2b-input b2b-light"
              aria-label="Número de WhatsApp"
            />
            <input
              type="email"
              name="email"
              placeholder="E-mail"
              required
              class="b2b-input b2b-light"
              aria-label="E-mail profissional"
            />
            <div style="display:flex;align-items:flex-start;gap:10px">
              <input
                type="checkbox"
                id="b2b-med-consent"
                name="consent"
                required
                style="margin-top:4px;cursor:pointer;min-width:16px"
              />
              <label
                for="b2b-med-consent"
                style="font-size:12px;font-weight:300;color:var(--color-ink-soft);cursor:pointer"
                >Concordo em compartilhar meus dados conforme a <a
                  href="/politica-de-privacidade"
                  style="color:var(--color-brand-text);text-decoration:underline"
                  target="_blank">política de privacidade</a
                ></label
              >
            </div>
            <button type="submit" class="bd" style="align-self:flex-start">enviar interesse</button>
            <p
              id="form-b2b-med-ok"
              style="display:none;font-size:13px;font-weight:400;color:var(--color-brand-text);margin-top:4px"
            >
              Recebemos seu interesse. Entraremos em contato em breve.
            </p>
          </form>
          <script>
            import { initFormSubmit } from '../scripts/form-submit';
            initFormSubmit();
          </script>
        </div>
        <div class="r d2">
          <div
            style="background:var(--color-cream);padding:40px 34px;border:1px solid var(--color-stone)"
          >
            <div class="lbl u-mb-20">áreas de atuação</div>
            {
              medAreas.map((area) => (
                <div class="lr">
                  <>
                    <span class="u-dot" />
                    <span class="body-md">{area}</span>
                  </>
                </div>
              ))
            }
          </div>
          <p class="body r d3" style="margin-top:20px;font-size:13px">
            É nutricionista? <a
              href="/para-nutricionistas"
              style="color:var(--color-brand-text);text-underline-offset:3px;text-decoration:underline"
              >Conheça a ecooa.working para nutricionistas →</a
            >
          </p>
        </div>
      </div>
    </div>
  </section>

  <CtaSection
    heading="Quer atender<br>na <em>ecooa?</em>"
    subtext="Um ecossistema de saúde premium em Moinhos de Vento. Se você é profissional de saúde e quer um espaço que eleva sua prática, vamos conversar."
    showAgendar={false}
  />
</BaseLayout>

<style>
  /* Bandeiras: grade 3x3 pautada por hairlines sobre ink, texto serif itálico.
     Nove células, manifesto silencioso: nada de cards, só papel e luz. */
  .band-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    border-left: 1px solid rgba(255, 255, 255, 0.12);
  }
  .band-cell {
    border-right: 1px solid rgba(255, 255, 255, 0.12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    padding: 44px 38px;
  }
  .band-num {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-brand-mid);
    margin-bottom: 14px;
  }
  .band-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(19px, 1.8vw, 24px);
    font-weight: 400;
    line-height: 1.45;
    color: var(--color-brand-light);
  }
  @media (max-width: 900px) {
    .band-grid {
      grid-template-columns: 1fr;
    }
    .band-cell {
      padding: 30px 24px;
    }
  }
</style>
