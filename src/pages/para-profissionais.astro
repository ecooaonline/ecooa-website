---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import WavePattern from '../components/WavePattern.astro';
import { WA_BASE, FORM_ACTION, ADDRESS_NEIGHBORHOOD } from '../data/constants';
import { medAreas } from '../data/specialties';

const WA_B2B = `${WA_BASE}?text=${encodeURIComponent('Olá, sou profissional de saúde e gostaria de saber mais sobre atender na ecooa')}`;
---

<BaseLayout
  title="Para Profissionais de Saúde"
  description="Atenda na ecooa: consultórios premium em Moinhos de Vento, Porto Alegre, para médicos, nutricionistas, psicólogos e profissionais da estética. Ecossistema multidisciplinar com recepção dedicada."
  currentPage="para-profissionais"
  ogImage="/clinic/respire.webp"
  breadcrumbs={[{ name: 'Para Profissionais', url: '/para-profissionais' }]}
>
  <!-- Hero -->
  <div class="ph" style="background:var(--color-ink)">
    <svg
      class="wsv u-op-05"
      viewBox="0 0 1440 500"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
      ><g fill="none" stroke="white" stroke-width="1"
        ><WavePattern count={8} x0={-100} y0={80} step={55} width={1600} /></g
      ></svg
    >
    <div class="ph-c">
      <div class="lbl lbl-lt r">para profissionais de saúde</div>
      <h1 class="h1 h1-w r d1 u-mt-18">Atenda na<br /><em>ecooa.</em></h1>
      <p class="body body-lt r d2" style="margin-top:16px;max-width:520px">
        Consultórios premium em {ADDRESS_NEIGHBORHOOD} para médicos, nutricionistas, psicólogos e profissionais
        da estética. Um ecossistema que valoriza sua prática e conecta você a uma rede multidisciplinar.
      </p>
      <a
        href={WA_B2B}
        target="_blank"
        rel="noopener noreferrer"
        class="bw r d3 u-cta"
        data-intent="b2b-hero">falar pelo whatsapp</a
      >
    </div>
  </div>

  <!-- Por que atender aqui -->
  <section class="u-bg-warm" aria-label="Por que atender na ecooa">
    <div class="w">
      <div class="g2 g2c">
        <div>
          <div class="lbl r">por que a ecooa</div>
          <h2 class="h2 r d1 u-mt-15">Um espaço que<br />eleva a sua<br /><em>prática.</em></h2>
          <p class="body r d2 u-mt-18">
            A ecooa nasceu para unir profissionais que acreditam que a saúde deve ser integral,
            humanizada e ética. Aqui, você atende em um ambiente sofisticado, com estrutura completa
            e ao lado de uma equipe que compartilha casos, conhecimento e propósito.
          </p>
        </div>
        <div class="st r d2">
          <div class="sr">
            <span class="sn">01</span><div>
              <div class="st-t">Valor para o profissional</div><div class="st-b">
                O ambiente sofisticado eleva a percepção do seu trabalho, fortalece sua marca
                pessoal e atrai pacientes que valorizam excelência.
              </div>
            </div>
          </div>
          <div class="sr">
            <span class="sn">02</span><div>
              <div class="st-t">Networking multidisciplinar</div><div class="st-b">
                Médicos, nutricionistas, psicólogos e profissionais da estética no mesmo
                ecossistema, com encaminhamentos internos e trabalho em equipe.
              </div>
            </div>
          </div>
          <div class="sr">
            <span class="sn">03</span><div>
              <div class="st-t">Infraestrutura premium</div><div class="st-b">
                9 salas equipadas, recepção dedicada, café e áreas comuns que refletem o padrão
                ecooa em Moinhos de Vento.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Espaço -->
  <section
    style="background:var(--color-warm);padding:0 4px 4px;overflow:hidden"
    aria-label="Nosso espaço"
  >
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px">
      <div class="u-img-43 r">
        <OptimizedImage
          src="/clinic/recepcao.webp"
          alt="Recepção da ecooa"
          width={1000}
          height={1233}
          class="u-cover"
        />
      </div>
      <div class="u-img-43 r d1">
        <OptimizedImage
          src="/clinic/respire.webp"
          alt="Sala Respire da ecooa"
          width={1200}
          height={799}
          class="u-cover"
        />
      </div>
      <div class="u-img-43 r d2">
        <OptimizedImage
          src="/clinic/cafe.webp"
          alt="Café da ecooa"
          width={1200}
          height={799}
          class="u-cover"
        />
      </div>
    </div>
  </section>

  <!-- Áreas -->
  <section class="u-bg-cream" aria-label="Áreas de atuação">
    <div class="w">
      <div class="g2 g2c">
        <div>
          <div class="lbl r">áreas médicas na ecooa.med</div>
          <h2 class="h2 r d1 u-mt-15">
            Uma rede de<br />especialistas que<br /><em>se entendem.</em>
          </h2>
          <p class="body r d2 u-mt-18">
            Liderada pelo Dr. Gustavo Gehrke, a ecooa.med une médicos que atuam nas mais diversas
            áreas. Sem pressa a cada atendimento, com escuta total ao paciente e trabalho
            multiprofissional.
          </p>
          <p class="body r d3 u-mt-13">
            Você é médico e quer atender na ecooa? Preencha o formulário abaixo ou <a
              href={WA_B2B}
              target="_blank"
              rel="noopener noreferrer"
              style="color:var(--color-brand-text);text-underline-offset:3px;text-decoration:underline"
              >fale pelo WhatsApp</a
            >.
          </p>
          <form
            action={FORM_ACTION}
            method="POST"
            class="b2b-form r d4 ecooa-form"
            id="form-b2b-med"
            data-ok-target="#form-b2b-med-ok"
            data-success-text="Recebemos seu interesse. Entraremos em contato em breve."
          >
            <input type="hidden" name="_formType" value="b2b-medicina" />
            <input type="hidden" name="_next" value="" />
            <input
              type="text"
              name="_honeypot"
              style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
            <input type="hidden" name="_loadedAt" value="" />
            <input
              type="text"
              name="nome"
              placeholder="Nome completo"
              required
              minlength="2"
              class="b2b-input b2b-light"
              aria-label="Nome completo"
            />
            <input
              type="tel"
              name="whatsapp"
              placeholder="WhatsApp: (51) 99999-9999"
              required
              pattern="[\s()+\-0-9]{10,20}"
              class="b2b-input b2b-light"
              aria-label="Número de WhatsApp"
            />
            <input
              type="email"
              name="email"
              placeholder="E-mail"
              required
              class="b2b-input b2b-light"
              aria-label="E-mail profissional"
            />
            <div style="display:flex;align-items:flex-start;gap:10px">
              <input
                type="checkbox"
                id="b2b-med-consent"
                name="consent"
                required
                style="margin-top:4px;cursor:pointer;min-width:16px"
              />
              <label
                for="b2b-med-consent"
                style="font-size:12px;font-weight:300;color:var(--color-ink-soft);cursor:pointer"
                >Concordo em compartilhar meus dados conforme a <a
                  href="/politica-de-privacidade"
                  style="color:var(--color-brand-text);text-decoration:underline"
                  target="_blank">política de privacidade</a
                ></label
              >
            </div>
            <button type="submit" class="bd" style="align-self:flex-start">enviar interesse</button>
            <p
              id="form-b2b-med-ok"
              style="display:none;font-size:13px;font-weight:400;color:var(--color-brand-text);margin-top:4px"
            >
              Recebemos seu interesse. Entraremos em contato em breve.
            </p>
          </form>
          <script>
            import { initFormSubmit } from '../scripts/form-submit';
            initFormSubmit();
          </script>
        </div>
        <div class="r d2">
          <div
            style="background:var(--color-warm);padding:40px 34px;border:1px solid var(--color-stone)"
          >
            <div class="lbl u-mb-20">áreas de atuação</div>
            {
              medAreas.map((area) => (
                <div class="lr">
                  <>
                    <span class="u-dot" />
                    <span class="body-md">{area}</span>
                  </>
                </div>
              ))
            }
          </div>
          <p class="body r d3" style="margin-top:20px;font-size:13px">
            É nutricionista? <a
              href="/para-nutricionistas"
              style="color:var(--color-brand-text);text-underline-offset:3px;text-decoration:underline"
              >Conheça a ecooa.working para nutricionistas →</a
            >
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bandeiras -->
  <section class="u-bg-warm" aria-label="Nossas bandeiras">
    <div class="w">
      <div class="lbl r u-mb-16">o que nos move</div>
      <h2 class="h2 r d1 u-mb-48">Nossas <em>bandeiras.</em></h2>
      <div
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));border-top:1px solid var(--color-stone);border-left:1px solid var(--color-stone)"
      >
        <div class="r gc-md">
          <p class="gc-tag">01</p><p class="body-lg">É possível ter o seu próprio negócio</p>
        </div>
        <div class="r gc-md">
          <p class="gc-tag">02</p><p class="body-lg">Acredite e viva o processo</p>
        </div>
        <div class="r gc-md">
          <p class="gc-tag">03</p><p class="body-lg">Trabalho em equipe nos leva mais longe</p>
        </div>
        <div class="r gc-md">
          <p class="gc-tag">04</p><p class="body-lg">Acreditamos em inovação em saúde</p>
        </div>
        <div class="r gc-md">
          <p class="gc-tag">05</p><p class="body-lg">Priorizamos e cultivamos a excelência</p>
        </div>
        <div class="r gc-md">
          <p class="gc-tag">06</p><p class="body-lg">Acreditamos em uma gestão humanizada</p>
        </div>
        <div class="r gc-md">
          <p class="gc-tag">07</p><p class="body-lg">Não aceitamos exploração</p>
        </div>
        <div class="r gc-md">
          <p class="gc-tag">08</p><p class="body-lg">Acreditamos no multidisciplinar</p>
        </div>
        <div class="r gc-md">
          <p class="gc-tag">09</p><p class="body-lg">Competição não define meu lugar</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Processo -->
  <section class="u-bg-cream" aria-label="Como funciona">
    <div class="w">
      <div class="lbl r u-mb-16">como funciona</div>
      <h2 class="h2 r d1 u-mb-44">do primeiro contato<br />à <em>parceria.</em></h2>
      <div
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:32px;max-width:800px;margin:0 auto"
      >
        <div class="r u-tac">
          <span class="step-num">1</span>
          <h3 class="it-t">Contato inicial</h3>
          <p class="it-d">Nos fale sobre você e sua prática pelo WhatsApp ou pelo formulário.</p>
        </div>
        <div class="r d1 u-tac">
          <span class="step-num">2</span>
          <h3 class="it-t">Visita ao espaço</h3>
          <p class="it-d">Conheça pessoalmente a estrutura, a equipe e a cultura ecooa.</p>
        </div>
        <div class="r d2 u-tac">
          <span class="step-num">3</span>
          <h3 class="it-t">Alinhamento e contrato</h3>
          <p class="it-d">Definimos juntos o melhor modelo de uso e formalizamos a parceria.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section
    style="background:var(--color-ink);padding:86px 60px;position:relative;overflow:hidden"
    aria-label="Convite para profissionais"
  >
    <svg
      class="wsv u-op-05"
      viewBox="0 0 1440 400"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
    >
      <g fill="none" stroke="white" stroke-width="1"><WavePattern count={7} y0={80} step={55} /></g>
    </svg>
    <div style="position:relative;z-index:2;max-width:700px;margin:0 auto;text-align:center">
      <div class="lbl lbl-br r" style="justify-content:center;margin-bottom:22px">
        vamos conversar
      </div>
      <h2
        style="font-size:clamp(30px,3.8vw,54px);font-weight:200;color:white;line-height:1.08;letter-spacing:-.025em;margin-bottom:20px"
        class="r d1"
      >
        Quer atender<br />na <em
          style="font-family:var(--font-serif);font-style:italic;color:var(--color-brand-light)"
          >ecooa?</em
        >
      </h2>
      <p
        style="font-size:15px;font-weight:300;line-height:1.9;color:rgba(255,255,255,.6);max-width:500px;margin:0 auto 36px"
        class="r d2"
      >
        Somos um ecossistema de saúde premium em {ADDRESS_NEIGHBORHOOD}. Se você é profissional de
        saúde e quer um espaço que eleva sua prática, vamos conversar.
      </p>
      <a
        href={WA_B2B}
        target="_blank"
        rel="noopener noreferrer"
        class="bw r d3"
        style="display:inline-block"
        data-intent="b2b-cta-final">falar pelo whatsapp</a
      >
    </div>
  </section>
</BaseLayout>
