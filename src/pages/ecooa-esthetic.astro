---
const categoryLabels: { [key: string]: string } = {
  medicina: 'Medicina',
  estetica: 'Estética',
  nutricao: 'Nutrição',
  'saude-mental': 'Saúde Mental',
  longevidade: 'Longevidade',
  ecooa: 'ecooa',
};
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import HeroEditorial from '../components/HeroEditorial.astro';
import MaskedWordBand from '../components/MaskedWordBand.astro';
import FaqVisivel from '../components/FaqVisivel.astro';
import EspelhoSection from '../components/EspelhoSection.astro';
import TranslateNote from '../components/TranslateNote.astro';
import RiskReversalBadge from '../components/RiskReversalBadge.astro';
import GuiaSection from '../components/GuiaSection.astro';
import DisclaimerMedico from '../components/DisclaimerMedico.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_BASE, WA_DEFAULT } from '../data/constants';
import { getCollection } from 'astro:content';

const WA = WA_DEFAULT;

const allEstheticPosts = await getCollection(
  'blog',
  ({ data }) => !data.draft && data.category === 'estetica'
);
const estheticPosts = allEstheticPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const estheticFaqs = [
  {
    q: 'Vou ficar com cara de feito?',
    a: 'Não é o nosso estilo. Nosso critério é você se reconhecer no espelho. Cada procedimento é indicado com base na sua anatomia e na sua expectativa. E se algo não for seguro ou não for para você, a gente diz não.',
  },
  {
    q: 'O transplante capilar dói?',
    a: 'O procedimento é realizado com anestesia local e sedação leve. O desconforto é mínimo durante e após o procedimento.',
  },
  {
    q: 'Quando o resultado do transplante capilar aparece?',
    a: 'O resultado é progressivo. Nos primeiros meses os fios transplantados passam por uma fase de adaptação, e o crescimento visível costuma aparecer a partir do sexto mês. Cada organismo responde no seu tempo, e o acompanhamento continua durante toda a evolução.',
  },
  {
    q: 'Quanto tempo dura o resultado do botox?',
    a: 'Em média, de 4 a 6 meses. A duração varia conforme o metabolismo de cada pessoa e a área tratada.',
  },
  {
    q: 'Posso fazer vários procedimentos estéticos ao mesmo tempo?',
    a: 'Sim, quando indicado clinicamente. Nossa equipe avalia o melhor plano de tratamento combinado para o seu caso.',
  },
  {
    q: 'Qual a diferença entre bioestimulador e preenchimento?',
    a: 'O preenchimento repõe volume imediato. O bioestimulador estimula a produção natural de colágeno, com resultado progressivo e mais duradouro. Em bom português: colágeno estimulado aos poucos, para você parecer você, com a aparência mais descansada.',
  },
];

const WA_TRANSPLANTE = `${WA_BASE}?text=${encodeURIComponent('Olá, gostaria de avaliar um transplante capilar na ecooa')}`;

const procedimentos = [
  {
    title: 'tricologia clínica',
    desc: 'Diagnóstico completo da saúde dos fios e do couro cabeludo, com tratamentos específicos por causa: hormonal, nutricional, inflamatória ou genética. Avaliamos, prescrevemos e acompanhamos.',
  },
  {
    title: 'rejuvenescimento facial',
    desc: 'Toxina botulínica, preenchimento com ácido hialurônico, bioremodeladores e bioestimuladores de colágeno. Sempre com resultado harmonioso, natural e com muito bom gosto.',
  },
  {
    title: 'prp e soroterapia',
    desc: 'Plasma rico em plaquetas e ativos específicos via microinjeção ou soroterapia para cabelos, pele e imunidade. Renovação celular com base em evidências clínicas sólidas.',
  },
  {
    title: 'peeling e renovação da pele',
    desc: 'Peeling químico, enzimático e físico para renovação celular, manchas, textura e luminosidade. Com indicação personalizada e abordagem clínica.',
  },
  {
    title: 'mesoterapia e injetáveis corporais',
    desc: 'Coquetéis de ativos e bioestimuladores para hidratação profunda, gordura localizada, celulite, firmeza e modelagem corporal, com estímulo à produção natural de colágeno e elastina.',
  },
  {
    title: 'osteopatia',
    desc: 'Avaliação e tratamento osteopático para adultos, crianças e bebês. Abordagem manual para dores crônicas, restrições posturais e equilíbrio do sistema nervoso, postural e visceral.',
  },
];
---

<BaseLayout
  title="Estética Avançada e Transplante Capilar | ecooa · Porto Alegre"
  description="Estética avançada e transplante capilar FUE Safira em Moinhos de Vento, Porto Alegre. Cabelo, rosto, pele e corpo com resultado natural e avaliação sincera."
  currentPage="ecooa-esthetic"
  ogImage="/clinic/esthetic.webp"
  breadcrumbs={[{ name: 'ecooa.esthetic', url: '/ecooa-esthetic' }]}
>
  <HeroEditorial
    label="ecooa.esthetic · estética"
    title="Voltar a se reconhecer<br />no espelho.<br />Sem virar <em>outra pessoa.</em>"
    support="Ninguém vai perceber o que você fez. Todos vão notar como você está."
    sub="Cabelo, rosto, pele e corpo com tricologia clínica e referência em transplante capilar FUE Safira em Porto Alegre. Resultado natural, decidido junto com você."
    ctaHref={WA}
    ctaLabel="contar o que me incomoda"
    ctaIntent="esthetic-hero"
    secondaryHref="#transplante-capilar"
    secondaryLabel="transplante capilar FUE Safira"
    badges={['respondemos em minutos', 'retorno incluído em todos os procedimentos']}
    image="/clinic/esthetic.webp"
    imageAlt="Sala de procedimentos estéticos da ecooa.esthetic"
    imageCaption="sala esthetic · moinhos de vento"
    vertical="pele · rosto · cabelo · corpo"
  />

  <MaskedWordBand word="pele" image="/clinic/esthetic.webp" label="estética que ecooa" />

  <EspelhoSection
    label="o que te incomoda quando você se olha?"
    items={[
      {
        text: 'meu cabelo está caindo e já tentei de tudo',
        waText: 'Olá, meu cabelo está caindo e gostaria de uma avaliação tricológica',
        intent: 'esthetic-espelho-cabelo',
      },
      {
        text: 'quero avaliar um transplante capilar',
        waText: 'Olá, gostaria de avaliar um transplante capilar na ecooa',
        intent: 'esthetic-espelho-transplante',
      },
      {
        text: 'as linhas chegaram antes do que eu esperava',
        waText: 'Olá, gostaria de avaliação para rejuvenescimento facial com resultado natural',
        intent: 'esthetic-espelho-rosto',
      },
      {
        text: 'manchas e acne que nenhum creme resolve',
        waText:
          'Olá, tenho manchas e acne que nenhum creme resolve e gostaria de uma avaliação de pele',
        intent: 'esthetic-espelho-pele',
      },
      {
        text: 'gordura localizada e flacidez que treino não muda',
        waText: 'Olá, gostaria de avaliação para gordura localizada e flacidez',
        intent: 'esthetic-espelho-corpo',
      },
      {
        text: 'não sei o que preciso, só quero uma avaliação sincera',
        waText:
          'Olá, gostaria de uma avaliação estética sincera para entender o que faz sentido para mim',
        intent: 'esthetic-espelho-neutra',
      },
    ]}
    closing="Cada uma dessas frases tem um caminho. A avaliação diz qual é o seu."
  />

  <!-- Transplante capilar: pontuação escura -->
  <section
    style="background:var(--color-ink);padding:104px var(--section-px)"
    aria-label="Transplante capilar"
    id="transplante-capilar"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="g2 g2c">
        <div>
          <div class="lbl lbl-lt r">referência em porto alegre</div>
          <h2 class="h2 h2-w r d1" style="margin-top:15px">
            Transplante capilar<br />fio a fio, com<br /><em>resultado natural.</em>
          </h2>
          <p class="body body-lt r d2" style="max-width:480px;margin-top:18px">
            Técnica FUE e FUE Safira para restauração capilar, reconstrução de barba e definição de
            sobrancelhas, para homens e mulheres. Cada caso começa com uma avaliação tricológica
            completa: quando o tratamento clínico resolve, a gente diz. Quando o transplante é o
            caminho, você sabe exatamente o que esperar.
          </p>
          <div class="r d3" style="margin-top:16px;max-width:480px">
            <TranslateNote
              light={true}
              text="FUE Safira é a extração fio a fio com lâminas de safira: incisões menores, mais precisão e cicatrização mais rápida."
            />
          </div>
          <div class="r d3" style="margin-top:32px">
            <a
              href={WA_TRANSPLANTE}
              target="_blank"
              rel="noopener noreferrer"
              class="bw"
              data-intent="esthetic-transplante-destaque"
              style="display:inline-block">avaliar meu caso de transplante</a
            >
            <RiskReversalBadge
              items={[
                'avaliação sincera: se não for para você, a gente diz',
                'acompanhamento incluído em toda a evolução',
              ]}
              light={true}
              align="left"
            />
          </div>
        </div>
        <div class="st st-dk r d2">
          <div class="sr">
            <span class="sn">01</span><div>
              <div class="st-t">Avaliação tricológica</div><div class="st-b">
                Diagnóstico completo dos fios e do couro cabeludo para entender a causa da queda:
                hormonal, nutricional, inflamatória ou genética.
              </div>
            </div>
          </div>
          <div class="sr">
            <span class="sn">02</span><div>
              <div class="st-t">Tratamento da causa</div><div class="st-b">
                Quando indicado, tratamento clínico antes de qualquer cirurgia: protocolo
                tricometabólico, PRP e soroterapia capilar, integrados à medicina da casa.
              </div>
            </div>
          </div>
          <div class="sr">
            <span class="sn">03</span><div>
              <div class="st-t">Transplante FUE Safira</div><div class="st-b">
                Procedimento fio a fio com anestesia local, desenho natural da linha capilar e
                planejamento feito junto com você.
              </div>
            </div>
          </div>
          <div class="sr">
            <span class="sn">04</span><div>
              <div class="st-t">Acompanhamento da evolução</div><div class="st-b">
                Retornos ao longo dos meses. O crescimento visível costuma aparecer a partir do
                sexto mês, e cada organismo responde no seu tempo.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Procedimentos: lista editorial -->
  <section
    style="background:var(--color-warm);padding:96px var(--section-px)"
    aria-label="Procedimentos"
    id="procedimentos"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl r" style="margin-bottom:14px">o que oferecemos</div>
      <h2 class="h2 r d1" style="margin-bottom:56px">
        Procedimentos que<br />cuidam e <em>revelam.</em>
      </h2>
      <div
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:44px 40px;max-width:1180px"
      >
        {
          procedimentos.map((p, i) => (
            <div
              class={`r d${Math.min(i, 3)}`}
              style="border-top:1px solid var(--color-brand-mid);padding-top:20px"
            >
              <p style="font-size:10px;font-weight:500;letter-spacing:.18em;color:var(--color-brand-text);margin-bottom:10px">
                {String(i + 1).padStart(2, '0')}
              </p>
              <h3 style="font-family:var(--font-serif);font-style:italic;font-size:23px;font-weight:400;color:var(--color-ink);margin-bottom:10px">
                {p.title}
              </h3>
              <p class="it-d-lg">{p.desc}</p>
            </div>
          ))
        }
      </div>
      <p class="body r d3" style="margin-top:52px;color:var(--color-ink-soft);max-width:520px">
        Avaliação sincera e retorno incluído em todos os procedimentos. Se algo não for para você, a
        gente diz.
      </p>
    </div>
  </section>

  <GuiaSection
    unit="esthetic"
    heading="Quem cuida<br>de <em>você.</em>"
    subtext="Tricologistas, especialistas em transplante capilar e profissionais de estética avançada, com história e técnica para mostrar."
  />

  <!-- Filosofia -->
  <section
    style="background:var(--color-cream);padding:104px var(--section-px)"
    aria-label="Nossa filosofia"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="g2 g2c" style="align-items:center;gap:clamp(40px,6vw,96px)">
        <div>
          <div class="lbl r" style="margin-bottom:18px">nossa filosofia</div>
          <h2 class="h2 r d1" style="margin-bottom:20px">
            "Estética com ciência.<br />Resultados que <em>respeitam quem você é.</em>"
          </h2>
          <p class="body r d2" style="max-width:480px">
            Nossos procedimentos são indicados com base na sua anatomia, na sua expectativa e na sua
            saúde. Nunca pelo modismo, sempre pelo que valoriza quem você realmente é.
          </p>
        </div>
        <figure class="lux-frame r d2" style="margin:0;max-width:440px;justify-self:end">
          <OptimizedImage
            src="/clinic/detalhes.webp"
            alt="Detalhes do espaço ecooa"
            width={945}
            height={792}
            class="lux-frame-img"
          />
        </figure>
      </div>
    </div>
  </section>

  <!-- Depoimentos -->
  <section
    style="background:var(--color-warm);padding:88px var(--section-px)"
    aria-label="Depoimentos de pacientes"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl r" style="margin-bottom:36px">depoimentos</div>
      <div class="gr-grid r d1">
        <div class="gr-card">
          <p class="gr-quote">
            "Fiz o transplante e o resultado ficou tão natural que meus amigos acharam que eu só
            tinha mudado o corte de cabelo. Exatamente o que eu queria."
          </p>
          <p class="gr-author">E. C.</p>
        </div>
        <div class="gr-card">
          <p class="gr-quote">
            "Tinha medo de ficar com aparência artificial. O resultado foi sutil e bonito. Me senti
            eu mesma, só que mais descansada e confiante."
          </p>
          <p class="gr-author">J. R.</p>
        </div>
        <div class="gr-card">
          <p class="gr-quote">
            "Desde a recepção até o procedimento, tudo impecável. O espaço é lindo e a equipe
            transmite segurança. Voltei para fazer bioestimulador e amei."
          </p>
          <p class="gr-author">T. F.</p>
        </div>
      </div>
      <p
        class="r d2"
        style="margin-top:24px;font-size:11px;font-weight:300;color:var(--color-ink-soft);letter-spacing:.02em"
      >
        Depoimentos reais publicados com autorização dos pacientes.
      </p>
    </div>
  </section>

  <!-- Artigos relacionados -->
  {
    estheticPosts.length > 0 && (
      <section
        style="background:var(--color-warm);padding:24px var(--section-px) 88px"
        aria-label="Artigos relacionados"
      >
        <div style="max-width:1280px;margin:0 auto">
          <div class="lbl r" style="margin-bottom:36px">
            do nosso blog
          </div>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2px">
            {estheticPosts.map((post, i) => (
              <a
                href={`/blog/${post.id}`}
                class={`r d${Math.min(i, 3)}`}
                style="display:flex;flex-direction:column;text-decoration:none;color:inherit;padding:30px 28px;background:var(--color-cream);border:1px solid var(--color-stone)"
              >
                <span style="font-size:9px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:12px">
                  {categoryLabels[post.data.category] || post.data.category}
                </span>
                <span style="font-family:var(--font-serif);font-size:18px;font-weight:400;color:var(--color-ink);line-height:1.4;margin-bottom:12px">
                  {post.data.title}
                </span>
                <span
                  class="ghost"
                  style="margin-top:auto;font-size:11px;color:var(--color-brand-text)"
                >
                  ler artigo <span aria-hidden="true">→</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <FaqVisivel faqs={estheticFaqs} heading="Dúvidas sobre a<br><em>ecooa.esthetic.</em>" />

  <section class="u-bg-warm" aria-label="Aviso médico" style="padding:32px var(--section-px) 8px">
    <DisclaimerMedico />
  </section>

  <CtaSection
    heading="Seu espelho pode voltar<br>a ser <em>um lugar bom.</em>"
    subtext="Conte o que te incomoda. A avaliação é sincera: se um procedimento não for para você, a gente diz. Estamos em Moinhos de Vento."
  />
</BaseLayout>
