---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import WavePattern from '../components/WavePattern.astro';
import Marquee from '../components/Marquee.astro';
import QuizSection from '../components/QuizSection.astro';
import B2BBanner from '../components/B2BBanner.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_DEFAULT } from '../data/constants';
import { getCollection } from 'astro:content';

const WA = WA_DEFAULT;

const allEstheticPosts = await getCollection('blog', ({data}) => !data.draft && data.category === 'estetica');
const estheticPosts = allEstheticPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);

const estheticFaqs = [
  { q: "O transplante capilar dói?", a: "O procedimento é realizado com anestesia local e sedação leve. O desconforto é mínimo durante e após o procedimento." },
  { q: "Quanto tempo dura o resultado do botox?", a: "Em média, de 4 a 6 meses. A duração varia conforme o metabolismo de cada pessoa e a área tratada." },
  { q: "Posso fazer vários procedimentos estéticos ao mesmo tempo?", a: "Sim, quando indicado clinicamente. Nossa equipe avalia o melhor plano de tratamento combinado para o seu caso." },
  { q: "Qual a diferença entre bioestimulador e preenchimento?", a: "O preenchimento repõe volume imediato. O bioestimulador estimula a produção natural de colágeno, com resultado progressivo e mais duradouro." },
];

const estheticFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": estheticFaqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};
---

<BaseLayout
  title="Estética Avançada e Transplante Capilar | ecooa · Porto Alegre"
  description="Estética avançada em Moinhos de Vento, Porto Alegre. Procedimentos que respeitam a beleza natural, com técnica refinada e muito bom gosto."
  currentPage="ecooa-esthetic"
  ogImage="/clinic/esthetic.webp"
  breadcrumbs={[{ name: "ecooa.esthetic", url: "/ecooa-esthetic" }]}
>

<!-- Hero -->
<div class="ph" style="background:var(--color-brand)">
  <svg class="wsv" style="opacity:.15" viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true"><g fill="none" stroke="white" stroke-width="1"><WavePattern count={9} x0={-100} y0={80} step={55} width={1600} /></g></svg>
  <div class="ph-c">
    <div class="lbl lbl-br r">ecooa.esthetic</div>
    <h1 style="font-size:clamp(38px,4.4vw,68px);font-weight:200;color:white;line-height:1.06;letter-spacing:-.025em;margin-top:18px;margin-bottom:16px" class="r d1">Estética avançada.<br>Sem exageros,<br><em style="font-family:var(--font-serif);font-style:italic;color:rgba(255,255,255,.82)">com muito bom gosto.</em></h1>
    <p style="font-size:14px;font-weight:300;line-height:1.9;color:rgba(255,255,255,.82);max-width:500px" class="r d2">Procedimentos de última geração que respeitam e revelam a sua beleza natural. Com olhar clínico apurado, técnica refinada e a estética como extensão da saúde.</p>
    <a href={WA} target="_blank" rel="noopener noreferrer" class="bw r d3 u-cta">falar pelo whatsapp</a>
    <p class="r d3" style="font-size:10px;font-weight:400;color:rgba(255,255,255,.65);margin-top:8px;letter-spacing:.04em">respondemos em minutos</p>
    <p class="r d3" style="font-size:11px;font-weight:300;color:rgba(255,255,255,.55);margin-top:14px;letter-spacing:.02em;text-align:center;max-width:400px">Avaliação personalizada. Vagas limitadas para garantir resultado natural e seguro.</p>
  </div>
</div>

<Marquee />

<script type="application/ld+json" set:html={JSON.stringify(estheticFaqSchema)} />

<QuizSection options={[
  { title: "meu cabelo", subtitle: "está caindo", waText: "Olá, gostaria de avaliação para queda de cabelo" },
  { title: "rejuvenescer", subtitle: "com naturalidade", waText: "Olá, gostaria de avaliação para rejuvenescimento facial" },
  { title: "transplante", subtitle: "capilar", waText: "Olá, gostaria de avaliação para transplante capilar" },
  { title: "quero uma", subtitle: "avaliação", waText: "Olá, gostaria de uma avaliação estética personalizada" },
]} />

<!-- Empatia -->
<section style="background:var(--color-cream);padding:64px var(--section-px)" aria-label="Entendemos você">
  <div class="u-narrow">
    <p class="body r" style="color:var(--color-ink-soft);line-height:1.9;font-size:14px">Você olha no espelho e algo incomoda. Pode ser a queda de cabelo que ninguém leva a sério, as linhas que apareceram cedo demais, ou a insegurança que nenhum produto cosmético resolve. Você quer cuidar de si, mas com segurança e sem exageros.</p>
    <p class="body r d1" style="color:var(--color-ink);line-height:1.9;font-size:14px;margin-top:14px;font-weight:400">Na ecooa.esthetic, cada procedimento é indicado com base na sua anatomia, na sua expectativa e no que valoriza quem você realmente é.</p>
  </div>
</section>

<!-- Foto do espaço -->
<section style="background:var(--color-cream);padding:0;overflow:hidden" aria-label="Nosso espaço">
  <div style="position:relative;width:100%;aspect-ratio:16/6;overflow:hidden">
    <OptimizedImage src="/clinic/esthetic.webp" alt="Sala de procedimentos estéticos da ecooa.esthetic" width={1200} height={799} class="u-cover" />
  </div>
</section>

<!-- Procedimentos -->
<section class="u-bg-warm" aria-label="Procedimentos">
  <div class="w">
    <div class="lbl r u-mb-16">o que oferecemos</div>
    <h2 class="h2 r d1 u-mb-44">Procedimentos que<br>cuidam e <em>revelam.</em></h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));border-top:1px solid var(--color-stone);border-left:1px solid var(--color-stone)">
      <div class="gc"><p class="gc-tag">01</p><h3 class="it-t">Rejuvenescimento Facial</h3><p class="it-d-lg">Toxina botulínica, preenchimento com ácido hialurônico, bioremodeladores e bioestimuladores de colágeno. O objetivo é sempre um resultado harmonioso, natural e com muito bom gosto.</p></div>
      <div class="gc"><p class="gc-tag">02</p><h3 class="it-t">Transplante Capilar, de Barba e Sobrancelha</h3><p class="it-d-lg">Referência em Porto Alegre. Técnica FUE e FUE Safira para restauração capilar, reconstrução de barba e definição de sobrancelhas. Resultado natural e permanente para homens e mulheres.</p></div>
      <div class="gc"><p class="gc-tag">03</p><h3 class="it-t">Tricologia Clínica</h3><p class="it-d-lg">Diagnóstico completo da saúde dos fios e do couro cabeludo, com tratamentos específicos por causa: hormonal, nutricional, inflamatória ou genética. Avaliamos, prescrevemos e acompanhamos.</p></div>
      <div class="gc"><p class="gc-tag">04</p><h3 class="it-t">PRP Capilar e Facial</h3><p class="it-d-lg">Plasma rico em plaquetas para estimular renovação celular, crescimento capilar e rejuvenescimento facial com base em evidências clínicas sólidas.</p></div>
      <div class="gc"><p class="gc-tag">05</p><h3 class="it-t">Soroterapia Capilar e Vitamínica</h3><p class="it-d-lg">Ativos específicos via microinjeção ou soroterapia para cabelos, pele e imunidade. Rápidos, eficazes e com alta tolerabilidade.</p></div>
      <div class="gc"><p class="gc-tag">06</p><h3 class="it-t">Mesoterapia Facial e Corporal</h3><p class="it-d-lg">Aplicação de coquetéis de ativos para hidratação profunda, gordura localizada, celulite e firmeza. Mínima invasão, excelente resultado.</p></div>
      <div class="gc"><p class="gc-tag">07</p><h3 class="it-t">Peeling e Renovação da Pele</h3><p class="it-d-lg">Peeling químico, enzimático e físico para renovação celular, manchas, textura e luminosidade. Com indicação personalizada e abordagem clínica.</p></div>
      <div class="gc"><p class="gc-tag">08</p><h3 class="it-t">Injetáveis Corporais e Bioestimuladores</h3><p class="it-d-lg">Firmeza, modelagem e rejuvenescimento corporal com estímulo à produção natural de colágeno e elastina.</p></div>
      <div class="gc"><p class="gc-tag">09</p><h3 class="it-t">Osteopatia</h3><p class="it-d-lg">Avaliação e tratamento osteopático para adultos, crianças e bebês. Abordagem manual que identifica e corrige restrições musculoesqueléticas, favorecendo o equilíbrio do sistema nervoso, postural e visceral. Indicada para dores crônicas, cólicas, problemas posturais e muito mais.</p></div>
      <div class="gc"><p class="gc-tag">10</p><h3 class="it-t">Fisioterapia Estética</h3><p class="it-d-lg">Drenagem linfática, modelagem corporal, radiofrequência e eletroestimulação com profissional especializado em estética clínica.</p></div>
    </div>
  </div>
</section>

<!-- Filosofia -->
<section style="background:var(--color-brand);padding:86px 60px;position:relative;overflow:hidden" aria-label="Nossa filosofia">
  <svg class="wsv" style="opacity:.13" viewBox="0 0 1440 400" preserveAspectRatio="xMidYMid slice" aria-hidden="true"><g fill="none" stroke="white" stroke-width="1"><WavePattern count={7} x0={-100} y0={80} step={55} width={1600} /></g></svg>
  <div style="position:relative;z-index:2;max-width:580px">
    <div class="lbl lbl-br r u-mb-18">nossa filosofia</div>
    <h2 style="font-size:clamp(28px,3.6vw,52px);font-weight:200;color:white;line-height:1.08;letter-spacing:-.025em;margin-bottom:20px" class="r d1">"Estética com ciência.<br>Resultados que <em style="font-family:var(--font-serif);font-style:italic;color:rgba(255,255,255,.55)">respeitam quem você é.</em>"</h2>
    <p style="font-size:14px;font-weight:300;line-height:1.9;color:rgba(255,255,255,.54)" class="r d2">Nossos procedimentos são indicados com base na sua anatomia, expectativa e saúde. Nunca pelo modismo, sempre pelo que valoriza você de verdade.</p>
  </div>
</section>

<!-- Nosso Espaço -->
<section style="background:var(--color-warm);padding:0;overflow:hidden" aria-label="Espaço ecooa.esthetic">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;padding:4px">
    <div class="u-img-169 r"><OptimizedImage src="/clinic/recepcao.webp" alt="Recepção da ecooa" width={1000} height={1233} class="u-cover" /></div>
    <div class="u-img-169 r d1"><OptimizedImage src="/clinic/detalhes.webp" alt="Detalhes do espaço ecooa" width={945} height={792} class="u-cover" /></div>
  </div>
</section>

<B2BBanner />

<!-- Perguntas frequentes -->
<section class="u-bg-warm" aria-label="Perguntas frequentes">
  <div class="w">
    <div class="lbl r u-mb-16">perguntas frequentes</div>
    <h2 class="h2 r d1 u-mb-40">Dúvidas sobre a<br><em>ecooa.esthetic.</em></h2>
    <div class="faq-section">
      {estheticFaqs.map((faq) => (
        <details class="faq-item">
          <summary class="faq-q">{faq.q}</summary>
          <p class="faq-a">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- Como funciona -->
<section class="u-bg-cream" aria-label="Como funciona">
  <div class="w">
    <div class="lbl r u-mb-16">sua jornada</div>
    <h2 class="h2 r d1 u-mb-44">como <em>funciona</em></h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:32px;max-width:960px;margin:0 auto">
      <div class="r u-tac">
        <span class="step-num">1</span>
        <h3 class="it-t">Agendamento</h3>
        <p class="it-d">Fale com a gente pelo WhatsApp. Respondemos rápido e marcamos no melhor horário para você.</p>
      </div>
      <div class="r d1 u-tac">
        <span class="step-num">2</span>
        <h3 class="it-t">Avaliação personalizada</h3>
        <p class="it-d">Análise da sua anatomia, expectativas e indicação dos procedimentos mais adequados.</p>
      </div>
      <div class="r d2 u-tac">
        <span class="step-num">3</span>
        <h3 class="it-t">Procedimento</h3>
        <p class="it-d">Realizado com técnica refinada, segurança e foco em resultado natural.</p>
      </div>
      <div class="r d3 u-tac">
        <span class="step-num">4</span>
        <h3 class="it-t">Acompanhamento</h3>
        <p class="it-d">Retorno incluído para avaliar o resultado e garantir sua satisfação.</p>
      </div>
    </div>
    <p class="r d3" style="text-align:center;margin-top:36px;font-size:13px;font-weight:400;color:var(--color-brand-text);letter-spacing:.02em">Satisfação garantida. Cada procedimento é planejado para o resultado que você espera.</p>
  </div>
</section>

<!-- Depoimentos -->
<section class="u-bg-cream" aria-label="Depoimentos de pacientes">
  <div class="w">
    <div class="lbl r u-mb-16">depoimentos</div>
    <h2 class="h2 r d1 u-mb-44">o que nossos pacientes <em>dizem</em></h2>
    <div class="grid-auto-260">
      <div class="r card-w">
        <p class="q-serif">"Fiz o transplante e o resultado ficou tão natural que meus amigos acharam que eu só tinha mudado o corte de cabelo. Exatamente o que eu queria."</p>
        <p class="sm-soft">E. C.</p>
      </div>
      <div class="r d1 card-w">
        <p class="q-serif">"Tinha medo de ficar com aparência artificial. O resultado foi sutil e bonito. Me senti eu mesma, só que mais descansada e confiante."</p>
        <p class="sm-soft">J. R.</p>
      </div>
      <div class="r d2 card-w">
        <p class="q-serif">"Desde a recepção até o procedimento, tudo impecável. O espaço é lindo e a equipe transmite segurança. Voltei para fazer bioestimulador e amei."</p>
        <p class="sm-soft">T. F.</p>
      </div>
    </div>
    <p class="r d3" style="text-align:center;margin-top:24px;font-size:11px;font-weight:300;color:var(--color-ink-soft);letter-spacing:.02em">Depoimentos reais publicados com autorização dos pacientes.</p>
  </div>
</section>

<!-- Artigos relacionados -->
{estheticPosts.length > 0 && (
<section class="u-bg-warm" aria-label="Artigos relacionados">
  <div class="w">
    <div class="lbl r u-mb-16">do nosso blog</div>
    <h2 class="h2 r d1 u-mb-44">artigos <em>relacionados</em></h2>
    <div class="grid-auto-260">
      {estheticPosts.map((post, i) => (
        <a href={`/blog/${post.id}`} class={`r d${i}`} style="display:block;background:var(--color-cream);border:1px solid var(--color-stone);padding:28px 24px;text-decoration:none;transition:border-color .2s ease">
          <p style="font-size:11px;font-weight:400;color:var(--color-brand-text);letter-spacing:.04em;text-transform:lowercase;margin-bottom:10px">{post.data.category}</p>
          <h3 style="font-size:15px;font-weight:400;color:var(--color-ink);line-height:1.5;margin-bottom:8px">{post.data.title}</h3>
          <p style="font-size:12px;font-weight:300;line-height:1.7;color:var(--color-ink-soft)">{post.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>
)}

<CtaSection heading='Agende sua<br><em>avaliação estética.</em>' subtext="Nossa equipe analisa suas queixas e indica os procedimentos mais adequados para o seu caso." />

</BaseLayout>
