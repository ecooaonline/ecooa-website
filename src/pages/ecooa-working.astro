---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import WavePattern from '../components/WavePattern.astro';
import Marquee from '../components/Marquee.astro';
import MaskedWordBand from '../components/MaskedWordBand.astro';
import FaqVisivel from '../components/FaqVisivel.astro';
import EspelhoSection from '../components/EspelhoSection.astro';
import ProtocoloCard from '../components/ProtocoloCard.astro';
import CtaBand from '../components/CtaBand.astro';
import RiskReversalBadge from '../components/RiskReversalBadge.astro';
import PrimeiroPassoCTA from '../components/PrimeiroPassoCTA.astro';
import ProvaViva from '../components/ProvaViva.astro';
import GuiaSection from '../components/GuiaSection.astro';
import { WA_BASE } from '../data/constants';
import { getCollection } from 'astro:content';

const WA_NUTRI = `${WA_BASE}?text=${encodeURIComponent('Olá, gostaria de agendar uma avaliação com a equipe de nutrição da ecooa')}`;

const allNutriPosts = await getCollection(
  'blog',
  ({ data }) => !data.draft && data.category === 'nutricao'
);
const nutriPosts = allNutriPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const workingFaqs = [
  {
    q: 'Preciso de pedido médico para consultar com nutricionista?',
    a: 'Não. Você pode agendar diretamente. Em casos que envolvam aspectos médicos, nossa equipe faz o encaminhamento interno.',
  },
  {
    q: 'Quantas consultas preciso para ter resultado?',
    a: 'Depende do objetivo. Em geral, o acompanhamento inicial envolve retornos mensais. Resultados começam a aparecer nas primeiras semanas.',
  },
  {
    q: 'A nutricionista da ecooa atende veganos?',
    a: 'Sim. Temos nutricionistas especializadas em nutrição vegana e vegetariana, com foco em segurança nutricional.',
  },
  {
    q: 'O que é bioimpedância?',
    a: 'É um exame que analisa a composição corporal: percentual de gordura, massa muscular, hidratação e metabolismo basal. Rápido e indolor.',
  },
];
---

<BaseLayout
  title="Nutricionista em Porto Alegre | ecooa · Moinhos de Vento"
  description="Nutricionista em Moinhos de Vento, Porto Alegre: emagrecimento, nutrição esportiva, comportamental e vegana, integrada ao seu médico. Primeira consulta sem compromisso."
  currentPage="ecooa-working"
  ogImage="/clinic/working.webp"
  breadcrumbs={[{ name: 'ecooa.working', url: '/ecooa-working' }]}
>
  <!-- Hero -->
  <div class="ph" style="background:var(--color-brand-mid)">
    <svg
      class="wsv"
      style="opacity:.14"
      viewBox="0 0 1440 500"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
      ><g fill="none" stroke="white" stroke-width="1"
        ><WavePattern count={9} x0={-100} y0={80} step={55} width={1600} /></g
      ></svg
    >
    <div class="ph-c">
      <div class="lbl lbl-br r">ecooa.working · nutrição</div>
      <h1
        style="font-size:clamp(38px,4.4vw,68px);font-weight:200;color:white;line-height:1.06;letter-spacing:-.025em;margin-top:18px;margin-bottom:16px"
        class="r d1"
      >
        Fazer as pazes<br />com a comida.<br /><em
          style="font-family:var(--font-serif);font-style:italic;color:rgba(255,255,255,.58)"
          >E com o espelho.</em
        >
      </h1>
      <p
        style="font-size:14px;font-weight:300;line-height:1.9;color:rgba(255,255,255,.58);max-width:500px"
        class="r d2"
      >
        Nutrição clínica, esportiva e comportamental com 12 nutricionistas que dividem o seu caso
        com o seu médico, dentro da mesma clínica. Sem dieta da moda, sem julgamento, sem fórmula
        mágica.
      </p>
      <a
        href={WA_NUTRI}
        target="_blank"
        rel="noopener noreferrer"
        class="bw r d3 u-cta"
        data-intent="working-hero">agendar minha avaliação</a
      >
      <RiskReversalBadge
        items={['primeira consulta sem compromisso', 'respondemos em minutos']}
        light={true}
      />
    </div>
  </div>

  <Marquee />

  <ProvaViva
    items={[
      '12 nutricionistas, um só prontuário',
      'primeira consulta sem compromisso',
      'desde 2021',
    ]}
  />

  <MaskedWordBand word="corpo" image="/clinic/working.webp" label="nutrição que ecooa" />

  <EspelhoSection
    label="qual dessas frases podia ser sua?"
    items={[
      {
        text: 'cansada de dietas que não funcionam',
        waText:
          'Olá, estou cansada de dietas que não funcionam e gostaria de agendar consulta de nutrição para emagrecimento',
        intent: 'working-espelho-dietas',
      },
      {
        text: 'sinto culpa quando como fora do plano',
        waText:
          'Olá, gostaria de consulta de nutrição comportamental para melhorar minha relação com a comida',
        intent: 'working-espelho-culpa',
      },
      {
        text: 'uso caneta emagrecedora e quero fazer isso direito',
        waText:
          'Olá, uso caneta emagrecedora (tipo Ozempic ou Mounjaro) e gostaria de suporte nutricional para proteger o resultado',
        intent: 'working-espelho-canetas',
      },
      {
        text: 'treino, me dedico e não vejo resultado',
        waText: 'Olá, gostaria de avaliação de nutrição esportiva',
        intent: 'working-espelho-esportiva',
      },
      {
        text: 'sou vegana e quero segurança de verdade',
        waText:
          'Olá, sigo alimentação vegana e gostaria de acompanhamento nutricional especializado',
        intent: 'working-espelho-vegana',
      },
      {
        text: 'quero energia, pele e cabelo saudáveis de dentro pra fora',
        waText: 'Olá, gostaria de avaliação de nutrição estética',
        intent: 'working-espelho-estetica',
      },
    ]}
    closing="Cada uma dessas frases tem um plano por trás. Feito para a sua vida real."
  />

  <!-- Empatia -->
  <section
    style="background:var(--color-cream);padding:64px var(--section-px)"
    aria-label="Entendemos você"
  >
    <div class="u-narrow">
      <p class="body r" style="color:var(--color-ink-soft);line-height:1.9;font-size:14px">
        Você já tentou dieta da moda, cortou grupos alimentares inteiros, fez jejuns sem orientação.
        Perdeu peso, voltou a ganhar. Sente culpa quando come algo fora do plano. Sabe que precisa
        de ajuda profissional, mas não sabe por onde começar.
      </p>
      <p
        class="body r d1"
        style="color:var(--color-ink);line-height:1.9;font-size:14px;margin-top:14px;font-weight:400"
      >
        Na ecooa, nutrição é ciência e escuta. Em bom português: a gente mede antes de mudar, e
        escuta antes de medir. Sem julgamento, sem fórmula mágica.
      </p>
      <CtaBand
        label="quero começar diferente"
        waText="Olá, quero começar um acompanhamento nutricional diferente do que já tentei"
        intent="working-empatia"
        badges={['primeira consulta sem compromisso']}
      />
    </div>
  </section>

  <!-- Foto do espaço -->
  <section
    style="background:var(--color-cream);padding:0;overflow:hidden"
    aria-label="Nosso espaço"
  >
    <div style="position:relative;width:100%;aspect-ratio:16/6;overflow:hidden">
      <OptimizedImage
        src="/clinic/working.webp"
        alt="Espaço de coworking premium da ecooa.working"
        width={1200}
        height={799}
        class="u-cover"
      />
    </div>
  </section>

  <!-- Nutrição para pacientes -->
  <section class="u-bg-cream" aria-label="Nutrição para pacientes">
    <div class="w">
      <div class="lbl r" style="margin-bottom:15px">programas de nutrição</div>
      <h2 class="h2 r d1 u-mb-14">Um programa com nome<br />para cada <em>objetivo.</em></h2>
      <p class="body r d2" style="margin-bottom:44px;max-width:640px">
        12 nutricionistas especializadas em diferentes áreas, integradas ao ecossistema ecooa. Você
        é atendida por quem melhor responde ao seu caso, com toda a estrutura de uma clínica
        premium.
      </p>
      <div class="g3">
        <ProtocoloCard
          numero="01"
          nome="Paz com a Comida"
          paraQuem="Para quem come por ansiedade, sente culpa fora do plano e quer mudar a relação com a comida antes de mudar o prato."
          inclui="Nutrição comportamental, com trabalho sobre gatilhos e hábitos e, quando faz sentido, integração com a psicologia da casa."
          waText="Olá, gostaria de saber mais sobre o programa Paz com a Comida"
          intent="working-programa-paz"
        />
        <ProtocoloCard
          numero="02"
          nome="Emagrecimento 360"
          delay="d1"
          paraQuem="Para quem já tentou de tudo e quer emagrecer com método, dados e acompanhamento."
          inclui="Nutricionista e médico dividindo o mesmo caso, bioimpedância periódica e plano que cabe na sua rotina, ancorado no Método Gehrke 360°."
          traducao="bioimpedância é uma balança inteligente que separa músculo, gordura e água, para o plano partir de dados e não de achismo."
          waText="Olá, gostaria de saber mais sobre o programa Emagrecimento 360"
          intent="working-programa-emagrecimento"
        />
        <ProtocoloCard
          numero="03"
          nome="Suporte às Canetas Emagrecedoras"
          delay="d2"
          paraQuem="Para quem usa ou vai usar canetas como Ozempic, Mounjaro, semaglutida ou tirzepatida e quer fazer isso direito."
          inclui="Nutrição para proteger massa magra e sustentar o resultado, em parceria com o acompanhamento médico, quando há indicação."
          waText="Olá, uso caneta emagrecedora (tipo Ozempic ou Mounjaro) e gostaria de suporte nutricional para proteger o resultado"
          intent="working-programa-canetas"
        />
        <ProtocoloCard
          numero="04"
          nome="Performance"
          paraQuem="Para quem treina de verdade e quer composição corporal, energia e recuperação."
          inclui="Nutrição esportiva com avaliação de composição corporal, periodização alimentar e suplementação baseada em exames."
          waText="Olá, gostaria de avaliação de nutrição esportiva"
          intent="working-programa-performance"
        />
        <ProtocoloCard
          numero="05"
          nome="Nutrição Vegana Segura"
          delay="d1"
          paraQuem="Para veganos e vegetarianos que querem segurança nutricional de verdade, sem julgamento."
          inclui="Planejamento plant-based com análise bioquímica e ciência aplicada, com nutricionistas referência na área."
          waText="Olá, sigo alimentação vegana e gostaria de acompanhamento nutricional especializado"
          intent="working-programa-vegana"
        />
        <ProtocoloCard
          numero="06"
          nome="Beleza de Dentro pra Fora"
          delay="d2"
          paraQuem="Para quem quer pele, cabelo e unhas saudáveis a partir do prato."
          inclui="Nutrição estética integrada aos tratamentos da casa, com avaliação de exames e plano individualizado."
          waText="Olá, gostaria de avaliação de nutrição estética"
          intent="working-programa-beleza"
        />
      </div>
      <p
        class="body r d2"
        style="margin-top:28px;font-size:13px;color:var(--color-ink-soft);max-width:640px"
      >
        Também por aqui: análise de exames e testes genéticos, prescrição de suplementos,
        bioimpedância e soroterapia nutricional sob supervisão médica.
      </p>
    </div>
  </section>

  <!-- Bioimpedância: oferta de entrada -->
  <section class="u-bg-warm" aria-label="Bioimpedância">
    <div class="w" style="max-width:760px">
      <div
        class="r"
        style="background:var(--color-white);border:1px solid var(--color-stone);border-left:3px solid var(--color-brand);padding:36px 32px"
      >
        <p
          style="font-size:10px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:10px"
        >
          comece por aqui
        </p>
        <h2
          style="font-family:var(--font-serif);font-size:clamp(20px,2.4vw,28px);font-weight:300;color:var(--color-ink);line-height:1.3;margin-bottom:12px"
        >
          Avaliação de composição corporal<br /><em style="font-style:italic">por bioimpedância.</em
          >
        </h2>
        <p class="body" style="margin-bottom:6px">
          Em bom português: uma balança inteligente que separa músculo, gordura e água, para o seu
          plano partir de dados, não de achismo.
        </p>
        <p style="font-size:12px;font-weight:300;color:var(--color-ink-soft);margin-bottom:20px">
          Rápida, indolor e com devolutiva explicada. O ponto de partida ideal para qualquer
          programa.
        </p>
        <a
          href={`${WA_BASE}?text=${encodeURIComponent('Olá, gostaria de agendar uma avaliação de bioimpedância na ecooa')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="bd"
          data-intent="working-bioimpedancia"
          style="display:inline-block">agendar minha bioimpedância</a
        >
      </div>
    </div>
  </section>

  <!-- Integração -->
  <section class="u-bg-warm" aria-label="Integração com a medicina">
    <div class="w">
      <div class="g2 g2c">
        <div>
          <div class="lbl r">o diferencial da casa</div>
          <h2 class="h2 r d1 u-mt-15">Sua nutri e seu médico<br />conversam <em>entre si.</em></h2>
          <p class="body r d2 u-mt-18">
            Aqui a nutricionista e o médico dividem exames, protocolo e evolução do mesmo caso. Você
            não carrega exames de um lado para o outro: sua história anda junta.
          </p>
        </div>
        <div class="r d2">
          <div class="card-w">
            <p class="q-serif">
              "A nutricionista e o endocrinologista trabalham juntos aqui dentro. Isso mudou tudo no
              meu processo de emagrecimento."
            </p>
            <p class="sm-soft">L.D. · depoimento publicado com autorização</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FaqVisivel faqs={workingFaqs} heading="Dúvidas sobre<br><em>nutrição.</em>" />

  <!-- Como funciona -->
  <section class="u-bg-cream" aria-label="Como funciona">
    <div class="w">
      <div class="lbl r u-mb-16">sua jornada</div>
      <h2 class="h2 r d1 u-mb-44">como <em>funciona</em></h2>
      <div
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:32px;max-width:960px;margin:0 auto"
      >
        <div class="r u-tac">
          <span class="step-num">1</span>
          <h3 class="it-t">Agendamento</h3>
          <p class="it-d">
            Entre em contato pelo WhatsApp e marque sua consulta de nutrição no melhor horário.
          </p>
        </div>
        <div class="r d1 u-tac">
          <span class="step-num">2</span>
          <h3 class="it-t">Avaliação nutricional</h3>
          <p class="it-d">
            Anamnese completa, bioimpedância e análise da sua rotina alimentar e objetivos.
          </p>
        </div>
        <div class="r d2 u-tac">
          <span class="step-num">3</span>
          <h3 class="it-t">Plano alimentar</h3>
          <p class="it-d">
            Planejamento individualizado, adaptado à sua vida real, sem fórmulas genéricas.
          </p>
        </div>
        <div class="r d3 u-tac">
          <span class="step-num">4</span>
          <h3 class="it-t">Acompanhamento</h3>
          <p class="it-d">
            Retornos regulares para ajustar o plano e acompanhar sua evolução de perto.
          </p>
        </div>
      </div>
      <p
        class="r d3"
        style="text-align:center;margin-top:36px;font-size:13px;font-weight:400;color:var(--color-brand-text);letter-spacing:.02em"
      >
        Primeira consulta sem compromisso. Você decide se quer continuar.
      </p>
    </div>
  </section>

  <GuiaSection
    unit="working"
    heading="Quem caminha<br>com <em>você.</em>"
    subtext="Nutricionistas especializadas em diferentes áreas, atendendo com a estrutura de uma clínica premium e dividindo o seu caso com o seu médico."
  />

  <!-- Depoimentos -->
  <section class="u-bg-cream" aria-label="Depoimentos de pacientes">
    <div class="w">
      <div class="lbl r u-mb-16">depoimentos</div>
      <h2 class="h2 r d1 u-mb-44">o que nossos pacientes <em>dizem</em></h2>
      <div class="grid-auto-260">
        <div class="r card-w">
          <p class="q-serif">
            "Achava que nutrição era só dieta restritiva. O plano que recebi respeita minha rotina e
            os resultados vieram de forma natural."
          </p>
          <p class="sm-soft">G.V.</p>
        </div>
        <div class="r d1 card-w">
          <p class="q-serif">
            "A nutricionista e o endocrinologista trabalham juntos aqui dentro. Isso mudou tudo no
            meu processo de emagrecimento."
          </p>
          <p class="sm-soft">L.D.</p>
        </div>
        <div class="r d2 card-w">
          <p class="q-serif">
            "Sou vegana e sempre foi difícil achar profissional que levasse minha escolha a sério.
            Aqui encontrei nutrição com ciência e sem julgamento."
          </p>
          <p class="sm-soft">I.C.</p>
        </div>
      </div>
      <p
        class="r d3"
        style="text-align:center;margin-top:24px;font-size:11px;font-weight:300;color:var(--color-ink-soft);letter-spacing:.02em"
      >
        Depoimentos reais publicados com autorização dos pacientes.
      </p>
    </div>
  </section>

  <!-- Artigos relacionados -->
  {
    nutriPosts.length > 0 && (
      <section class="u-bg-warm" aria-label="Artigos relacionados">
        <div class="w">
          <div class="lbl r u-mb-16">do nosso blog</div>
          <h2 class="h2 r d1 u-mb-44">
            artigos <em>relacionados</em>
          </h2>
          <div class="grid-auto-260">
            {nutriPosts.map((post, i) => (
              <a
                href={`/blog/${post.id}`}
                class={`r d${i}`}
                style="display:block;background:var(--color-cream);border:1px solid var(--color-stone);padding:28px 24px;text-decoration:none;transition:border-color .2s ease"
              >
                <p style="font-size:11px;font-weight:400;color:var(--color-brand-text);letter-spacing:.04em;text-transform:lowercase;margin-bottom:10px">
                  {post.data.category}
                </p>
                <h3 style="font-size:15px;font-weight:400;color:var(--color-ink);line-height:1.5;margin-bottom:8px">
                  {post.data.title}
                </h3>
                <p style="font-size:12px;font-weight:300;line-height:1.7;color:var(--color-ink-soft)">
                  {post.data.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Link discreto B2B -->
  <section
    class="u-bg-warm"
    aria-label="Para nutricionistas"
    style="padding:24px var(--section-px)"
  >
    <p
      class="r"
      style="text-align:center;font-size:12px;font-weight:300;color:var(--color-ink-soft)"
    >
      É nutricionista? <a
        href="/para-nutricionistas"
        style="color:var(--color-brand-text);text-underline-offset:3px;text-decoration:underline"
        >Conheça a ecooa.working para nutricionistas →</a
      >
    </p>
  </section>

  <PrimeiroPassoCTA
    heading="A sua próxima relação com a comida<br>começa <em>numa conversa.</em>"
    subtext="Agende sua avaliação e descubra como um plano feito para a sua vida real muda a sua relação com a saúde."
    waText="Olá, gostaria de agendar uma avaliação com a equipe de nutrição da ecooa"
    label="agendar minha avaliação"
    intent="working-primeiro-passo"
    badges={['primeira consulta sem compromisso', 'respondemos em minutos']}
  />
</BaseLayout>
