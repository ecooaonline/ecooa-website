---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import WavePattern from '../components/WavePattern.astro';
import Marquee from '../components/Marquee.astro';
import QuizSection from '../components/QuizSection.astro';
import CtaSection from '../components/CtaSection.astro';
import FaqVisivel from '../components/FaqVisivel.astro';
import RiskReversalBadge from '../components/RiskReversalBadge.astro';
import { WA_BASE, WA_DEFAULT } from '../data/constants';
import { getCollection } from 'astro:content';

const WA = WA_DEFAULT;
const WA_NUTRI = `${WA_BASE}?text=${encodeURIComponent('Olá, gostaria de agendar uma avaliação com a equipe de nutrição da ecooa')}`;

const allNutriPosts = await getCollection('blog', ({data}) => !data.draft && data.category === 'nutricao');
const nutriPosts = allNutriPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);

const workingFaqs = [
  { q: "Preciso de pedido médico para consultar com nutricionista?", a: "Não. Você pode agendar diretamente. Em casos que envolvam aspectos médicos, nossa equipe faz o encaminhamento interno." },
  { q: "Quantas consultas preciso para ter resultado?", a: "Depende do objetivo. Em geral, o acompanhamento inicial envolve retornos mensais. Resultados começam a aparecer nas primeiras semanas." },
  { q: "A nutricionista da ecooa atende veganos?", a: "Sim. Temos nutricionistas especializadas em nutrição vegana e vegetariana, com foco em segurança nutricional." },
  { q: "O que é bioimpedância?", a: "É um exame que analisa a composição corporal: percentual de gordura, massa muscular, hidratação e metabolismo basal. Rápido e indolor." },
];

---

<BaseLayout
  title="Nutricionista em Porto Alegre | ecooa · Moinhos de Vento"
  description="Nutricionista em Moinhos de Vento, Porto Alegre: emagrecimento, nutrição esportiva, comportamental e vegana, integrada ao seu médico. Primeira consulta sem compromisso."
  currentPage="ecooa-working"
  ogImage="/clinic/working.webp"
  breadcrumbs={[{ name: "ecooa.working", url: "/ecooa-working" }]}
>

<!-- Hero -->
<div class="ph" style="background:var(--color-brand-mid)">
  <svg class="wsv" style="opacity:.14" viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true"><g fill="none" stroke="white" stroke-width="1"><WavePattern count={9} x0={-100} y0={80} step={55} width={1600} /></g></svg>
  <div class="ph-c">
    <div class="lbl lbl-br r">ecooa.working · nutrição</div>
    <h1 style="font-size:clamp(38px,4.4vw,68px);font-weight:200;color:white;line-height:1.06;letter-spacing:-.025em;margin-top:18px;margin-bottom:16px" class="r d1">Fazer as pazes<br>com a comida.<br><em style="font-family:var(--font-serif);font-style:italic;color:rgba(255,255,255,.58)">E com o espelho.</em></h1>
    <p style="font-size:14px;font-weight:300;line-height:1.9;color:rgba(255,255,255,.58);max-width:500px" class="r d2">Nutrição clínica, esportiva e comportamental com 12 nutricionistas que dividem o seu caso com o seu médico, dentro da mesma clínica. Sem dieta da moda, sem julgamento, sem fórmula mágica.</p>
    <a href={WA_NUTRI} target="_blank" rel="noopener noreferrer" class="bw r d3 u-cta" data-intent="working-hero">agendar minha avaliação</a>
    <RiskReversalBadge items={['primeira consulta sem compromisso', 'respondemos em minutos']} light={true} />
  </div>
</div>

<Marquee />

<QuizSection options={[
  { title: "emagrecer", subtitle: "saudável", waText: "Olá, gostaria de agendar consulta de nutrição para emagrecimento" },
  { title: "nutrição", subtitle: "esportiva", waText: "Olá, gostaria de avaliação de nutrição esportiva" },
  { title: "relação com", subtitle: "a comida", waText: "Olá, gostaria de consulta de nutrição comportamental" },
  { title: "orientação", subtitle: "nutricional", waText: "Olá, gostaria de uma orientação nutricional para entender o melhor caminho" },
]} />

<!-- Empatia -->
<section style="background:var(--color-cream);padding:64px var(--section-px)" aria-label="Entendemos você">
  <div class="u-narrow">
    <p class="body r" style="color:var(--color-ink-soft);line-height:1.9;font-size:14px">Você já tentou dieta da moda, cortou grupos alimentares inteiros, fez jejuns sem orientação. Perdeu peso, voltou a ganhar. Sente culpa quando come algo fora do plano. Sabe que precisa de ajuda profissional, mas não sabe por onde começar.</p>
    <p class="body r d1" style="color:var(--color-ink);line-height:1.9;font-size:14px;margin-top:14px;font-weight:400">Na ecooa, nutrição é ciência e escuta. Sem julgamento, sem fórmula mágica. Um plano que funciona porque foi feito para a sua vida.</p>
  </div>
</section>

<!-- Foto do espaço -->
<section style="background:var(--color-cream);padding:0;overflow:hidden" aria-label="Nosso espaço">
  <div style="position:relative;width:100%;aspect-ratio:16/6;overflow:hidden">
    <OptimizedImage src="/clinic/working.webp" alt="Espaço de coworking premium da ecooa.working" width={1200} height={799} class="u-cover" />
  </div>
</section>

<!-- Nutrição para pacientes -->
<section class="u-bg-cream" aria-label="Nutrição para pacientes">
  <div class="w">
    <div class="lbl r" style="margin-bottom:15px">nutrição para você</div>
    <h2 class="h2 r d1 u-mb-14">Nossa equipe de<br>nutrição está<br><em>aqui por você.</em></h2>
    <p class="body r d2" style="margin-bottom:44px;max-width:640px">A ecooa.working abriga nutricionistas especializados em diferentes áreas, integrados ao ecossistema ecooa. Você é atendido por quem melhor responde ao seu caso, com toda a estrutura de uma clínica premium.</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));border-top:1px solid var(--color-stone);border-left:1px solid var(--color-stone)">
      <div class="gc-sm"><h3 class="it-t-sm">Nutrição Vegana e Vegetariana</h3><p class="it-d">Planejamento alimentar plant-based com segurança nutricional e ciência aplicada.</p></div>
      <div class="gc-sm"><h3 class="it-t-sm">Nutrição Clínica</h3><p class="it-d">Saúde metabólica, doenças crônicas e bem-estar geral.</p></div>
      <div class="gc-sm"><h3 class="it-t-sm">Nutrição Esportiva</h3><p class="it-d">Performance, composição corporal e recuperação.</p></div>
      <div class="gc-sm"><h3 class="it-t-sm">Emagrecimento</h3><p class="it-d">Estratégias integradas à medicina para resultados reais. Para quem busca suporte nutricional no uso de medicamentos como tirzepatida e similares, nossa equipe atua em parceria com o acompanhamento médico para potencializar e sustentar os resultados.</p></div>
      <div class="gc-sm"><h3 class="it-t-sm">Nutrição Estética</h3><p class="it-d">Pele, cabelo, unhas e composição corporal.</p></div>
      <div class="gc-sm"><h3 class="it-t-sm">Análise de Exames e Testes Genéticos</h3><p class="it-d">Interpretação de exames bioquímicos e mapeamento genético aplicado à nutrição individualizada.</p></div>
      <div class="gc-sm"><h3 class="it-t-sm">Nutrição Comportamental</h3><p class="it-d">Comportamento alimentar e relação saudável com a comida.</p></div>
      <div class="gc-sm"><h3 class="it-t-sm">Prescrição de Suplementos</h3><p class="it-d">Indicação baseada em exames e objetivos individuais.</p></div>
      <div class="gc-sm"><h3 class="it-t-sm">Bioimpedância e Avaliação</h3><p class="it-d">Análise detalhada da composição corporal.</p></div>
      <div class="gc-sm"><h3 class="it-t-sm">Soroterapia Nutricional</h3><p class="it-d">Reposição de micronutrientes via soroterapia, sob supervisão médica. Indicada para deficiências identificadas em exames, fadiga, queda de imunidade e otimização metabólica.</p></div>
    </div>
    <div style="margin-top:32px;text-align:center" class="r"><a href={WA} target="_blank" rel="noopener noreferrer" class="bd">agendar consulta de nutrição</a></div>
  </div>
</section>

<FaqVisivel faqs={workingFaqs} heading='Dúvidas sobre<br><em>nutrição.</em>' />

<!-- Como funciona -->
<section class="u-bg-cream" aria-label="Como funciona">
  <div class="w">
    <div class="lbl r u-mb-16">sua jornada</div>
    <h2 class="h2 r d1 u-mb-44">como <em>funciona</em></h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:32px;max-width:960px;margin:0 auto">
      <div class="r u-tac">
        <span class="step-num">1</span>
        <h3 class="it-t">Agendamento</h3>
        <p class="it-d">Entre em contato pelo WhatsApp e marque sua consulta de nutrição no melhor horário.</p>
      </div>
      <div class="r d1 u-tac">
        <span class="step-num">2</span>
        <h3 class="it-t">Avaliação nutricional</h3>
        <p class="it-d">Anamnese completa, bioimpedância e análise da sua rotina alimentar e objetivos.</p>
      </div>
      <div class="r d2 u-tac">
        <span class="step-num">3</span>
        <h3 class="it-t">Plano alimentar</h3>
        <p class="it-d">Planejamento individualizado, adaptado à sua vida real, sem fórmulas genéricas.</p>
      </div>
      <div class="r d3 u-tac">
        <span class="step-num">4</span>
        <h3 class="it-t">Acompanhamento</h3>
        <p class="it-d">Retornos regulares para ajustar o plano e acompanhar sua evolução de perto.</p>
      </div>
    </div>
    <p class="r d3" style="text-align:center;margin-top:36px;font-size:13px;font-weight:400;color:var(--color-brand-text);letter-spacing:.02em">Primeira consulta sem compromisso. Você decide se quer continuar.</p>
  </div>
</section>

<!-- Depoimentos -->
<section class="u-bg-cream" aria-label="Depoimentos de pacientes">
  <div class="w">
    <div class="lbl r u-mb-16">depoimentos</div>
    <h2 class="h2 r d1 u-mb-44">o que nossos pacientes <em>dizem</em></h2>
    <div class="grid-auto-260">
      <div class="r card-w">
        <p class="q-serif">"Achava que nutrição era só dieta restritiva. O plano que recebi respeita minha rotina e os resultados vieram de forma natural."</p>
        <p class="sm-soft">G.V.</p>
      </div>
      <div class="r d1 card-w">
        <p class="q-serif">"A nutricionista e o endocrinologista trabalham juntos aqui dentro. Isso mudou tudo no meu processo de emagrecimento."</p>
        <p class="sm-soft">L.D.</p>
      </div>
      <div class="r d2 card-w">
        <p class="q-serif">"Sou vegana e sempre foi difícil achar profissional que levasse minha escolha a sério. Aqui encontrei nutrição com ciência e sem julgamento."</p>
        <p class="sm-soft">I.C.</p>
      </div>
    </div>
    <p class="r d3" style="text-align:center;margin-top:24px;font-size:11px;font-weight:300;color:var(--color-ink-soft);letter-spacing:.02em">Depoimentos reais publicados com autorização dos pacientes.</p>
  </div>
</section>

<!-- Artigos relacionados -->
{nutriPosts.length > 0 && (
<section class="u-bg-warm" aria-label="Artigos relacionados">
  <div class="w">
    <div class="lbl r u-mb-16">do nosso blog</div>
    <h2 class="h2 r d1 u-mb-44">artigos <em>relacionados</em></h2>
    <div class="grid-auto-260">
      {nutriPosts.map((post, i) => (
        <a href={`/blog/${post.id}`} class={`r d${i}`} style="display:block;background:var(--color-cream);border:1px solid var(--color-stone);padding:28px 24px;text-decoration:none;transition:border-color .2s ease">
          <p style="font-size:11px;font-weight:400;color:var(--color-brand-text);letter-spacing:.04em;text-transform:lowercase;margin-bottom:10px">{post.data.category}</p>
          <h3 style="font-size:15px;font-weight:400;color:var(--color-ink);line-height:1.5;margin-bottom:8px">{post.data.title}</h3>
          <p style="font-size:12px;font-weight:300;line-height:1.7;color:var(--color-ink-soft)">{post.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>
)}

<!-- Link discreto B2B -->
<section class="u-bg-warm" aria-label="Para nutricionistas" style="padding:24px var(--section-px)">
  <p class="r" style="text-align:center;font-size:12px;font-weight:300;color:var(--color-ink-soft)">É nutricionista? <a href="/para-nutricionistas" style="color:var(--color-brand-text);text-underline-offset:3px;text-decoration:underline">Conheça a ecooa.working para nutricionistas →</a></p>
</section>

<CtaSection heading='Comece sua transformação<br>pela <em>nutrição.</em>' subtext="Agende sua consulta e descubra como um plano alimentar personalizado pode mudar a sua relação com a saúde." />

</BaseLayout>
