---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroEditorial from '../components/HeroEditorial.astro';
import MaskedWordBand from '../components/MaskedWordBand.astro';
import EspelhoSection from '../components/EspelhoSection.astro';
import GuiaSection from '../components/GuiaSection.astro';
import FaqVisivel from '../components/FaqVisivel.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_BASE } from '../data/constants';
import { getCollection } from 'astro:content';

const categoryLabels: { [key: string]: string } = {
  medicina: 'Medicina',
  estetica: 'Estética',
  nutricao: 'Nutrição',
  'saude-mental': 'Saúde Mental',
  longevidade: 'Longevidade',
  ecooa: 'ecooa',
};

const wa = (text: string) => `${WA_BASE}?text=${encodeURIComponent(text)}`;

const WA_NUTRI = wa('Olá, gostaria de agendar uma avaliação com a equipe de nutrição da ecooa');

const allNutriPosts = await getCollection(
  'blog',
  ({ data }) => !data.draft && data.category === 'nutricao'
);
const nutriPosts = allNutriPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const programas = [
  {
    numero: '01',
    nome: 'Paz com a Comida',
    desc: 'Para quem come por ansiedade e sente culpa fora do plano. Nutrição comportamental, com trabalho sobre gatilhos e hábitos e, quando faz sentido, integração com a psicologia da casa.',
    waText: 'Olá, gostaria de saber mais sobre o programa Paz com a Comida',
    intent: 'working-programa-paz',
  },
  {
    numero: '02',
    nome: 'Emagrecimento 360',
    desc: 'Para quem já tentou de tudo e quer emagrecer com método, dados e acompanhamento. Nutricionista e médico dividindo o mesmo caso, bioimpedância periódica e plano ancorado no Método Gehrke 360°.',
    waText: 'Olá, gostaria de saber mais sobre o programa Emagrecimento 360',
    intent: 'working-programa-emagrecimento',
  },
  {
    numero: '03',
    nome: 'Suporte às Canetas Emagrecedoras',
    desc: 'Para quem usa ou vai usar canetas emagrecedoras (análogos de GLP-1) e quer fazer isso direito. Nutrição para proteger massa magra e sustentar o resultado, em parceria com o acompanhamento médico, quando há indicação.',
    waText:
      'Olá, uso caneta emagrecedora e gostaria de suporte nutricional para proteger o resultado',
    intent: 'working-programa-canetas',
  },
  {
    numero: '04',
    nome: 'Performance',
    desc: 'Para quem treina de verdade e quer composição corporal, energia e recuperação. Nutrição esportiva com periodização alimentar e suplementação baseada em exames.',
    waText: 'Olá, gostaria de avaliação de nutrição esportiva',
    intent: 'working-programa-performance',
  },
  {
    numero: '05',
    nome: 'Nutrição Vegana Segura',
    desc: 'Para veganos e vegetarianos que querem segurança nutricional de verdade, sem julgamento. Planejamento plant-based com análise bioquímica e nutricionistas referência na área.',
    waText: 'Olá, sigo alimentação vegana e gostaria de acompanhamento nutricional especializado',
    intent: 'working-programa-vegana',
  },
  {
    numero: '06',
    nome: 'Beleza de Dentro pra Fora',
    desc: 'Para quem quer pele, cabelo e unhas saudáveis a partir do prato. Nutrição estética integrada aos tratamentos da casa, com avaliação de exames e plano individualizado.',
    waText: 'Olá, gostaria de avaliação de nutrição estética',
    intent: 'working-programa-beleza',
  },
];

const workingFaqs = [
  {
    q: 'Preciso de pedido médico para consultar com nutricionista?',
    a: 'Não. Você pode agendar diretamente. Em casos que envolvam aspectos médicos, nossa equipe faz o encaminhamento interno.',
  },
  {
    q: 'Quantas consultas preciso para ter resultado?',
    a: 'Depende do objetivo. Em geral, o acompanhamento inicial envolve retornos mensais. Resultados começam a aparecer nas primeiras semanas.',
  },
  {
    q: 'A nutricionista da ecooa atende veganos?',
    a: 'Sim. Temos nutricionistas especializadas em nutrição vegana e vegetariana, com foco em segurança nutricional.',
  },
  {
    q: 'O que é bioimpedância?',
    a: 'É um exame que analisa a composição corporal: percentual de gordura, massa muscular, hidratação e metabolismo basal. Rápido e indolor.',
  },
];
---

<BaseLayout
  title="Nutricionista em Porto Alegre | ecooa · Moinhos de Vento"
  description="Nutricionista em Moinhos de Vento, Porto Alegre: emagrecimento, nutrição esportiva, comportamental e vegana, integrada ao seu médico. Primeira consulta sem compromisso."
  currentPage="ecooa-working"
  ogImage="/clinic/working.webp"
  breadcrumbs={[{ name: 'ecooa.working', url: '/ecooa-working' }]}
>
  <HeroEditorial
    label="ecooa.working · nutrição"
    title="Fazer as pazes<br />com a comida.<br /><em>E com o espelho.</em>"
    sub="Nutrição clínica, esportiva e comportamental com 12 nutricionistas que dividem o seu caso com o seu médico, dentro da mesma clínica. Sem dieta da moda, sem julgamento, sem fórmula mágica."
    ctaHref={WA_NUTRI}
    ctaLabel="agendar minha avaliação"
    ctaIntent="working-hero"
    secondaryHref="#programas"
    secondaryLabel="conhecer os programas"
    badges={['primeira consulta sem compromisso', 'respondemos em minutos']}
    image="/clinic/working.webp"
    imageAlt="Espaço da ecooa.working em Moinhos de Vento"
    imageCaption="ecooa.working · moinhos de vento"
    vertical="corpo · energia · equilíbrio"
  />

  <MaskedWordBand word="corpo" image="/clinic/working.webp" label="nutrição que ecooa" />

  <EspelhoSection
    label="qual dessas frases podia ser sua?"
    items={[
      {
        text: 'cansada de dietas que não funcionam',
        waText:
          'Olá, estou cansada de dietas que não funcionam e gostaria de agendar consulta de nutrição para emagrecimento',
        intent: 'working-espelho-dietas',
      },
      {
        text: 'sinto culpa quando como fora do plano',
        waText:
          'Olá, gostaria de consulta de nutrição comportamental para melhorar minha relação com a comida',
        intent: 'working-espelho-culpa',
      },
      {
        text: 'uso caneta emagrecedora e quero fazer isso direito',
        waText:
          'Olá, uso caneta emagrecedora e gostaria de suporte nutricional para proteger o resultado',
        intent: 'working-espelho-canetas',
      },
      {
        text: 'treino, me dedico e não vejo resultado',
        waText: 'Olá, gostaria de avaliação de nutrição esportiva',
        intent: 'working-espelho-esportiva',
      },
      {
        text: 'sou vegana e quero segurança de verdade',
        waText:
          'Olá, sigo alimentação vegana e gostaria de acompanhamento nutricional especializado',
        intent: 'working-espelho-vegana',
      },
      {
        text: 'quero energia, pele e cabelo saudáveis de dentro pra fora',
        waText: 'Olá, gostaria de avaliação de nutrição estética',
        intent: 'working-espelho-estetica',
      },
    ]}
    closing="Cada uma dessas frases tem um plano por trás. Feito para a sua vida real."
  />

  <!-- Programas de nutrição -->
  <section
    style="background:var(--color-warm);padding:96px var(--section-px)"
    aria-label="Programas de nutrição"
    id="programas"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl r" style="margin-bottom:14px">programas de nutrição</div>
      <h2 class="h2 r d1" style="margin-bottom:18px">
        Um programa com nome<br />para cada <em>objetivo.</em>
      </h2>
      <p class="body r d2" style="max-width:560px;margin-bottom:56px">
        12 nutricionistas especializadas, um só prontuário. Você é atendida por quem melhor responde
        ao seu caso, e o plano é dividido com o seu médico dentro da mesma clínica.
      </p>
      <div style="max-width:1100px">
        {
          programas.map((p, i) => (
            <article class={`prog-row r d${Math.min(i % 3, 2)}`}>
              <div>
                <p class="prog-num">{p.numero}</p>
                <h3 class="prog-nome">{p.nome}</h3>
              </div>
              <div>
                <p class="body" style="max-width:640px;margin-bottom:14px">
                  {p.desc}
                </p>
                <a
                  href={wa(p.waText)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="ghost"
                  data-intent={p.intent}
                >
                  conversar sobre este programa <span aria-hidden="true">→</span>
                </a>
              </div>
            </article>
          ))
        }
      </div>
      <p
        class="r d2"
        style="margin-top:32px;font-size:13px;font-weight:300;color:var(--color-ink-soft);max-width:640px"
      >
        Também por aqui: análise de exames e testes genéticos, prescrição de suplementos,
        bioimpedância e soroterapia nutricional sob supervisão médica.
      </p>
    </div>
  </section>

  <!-- Bioimpedância: porta de entrada (pontuação escura) -->
  <section
    style="background:var(--color-ink);padding:96px var(--section-px)"
    aria-label="Bioimpedância"
    id="bioimpedancia"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl lbl-lt r" style="margin-bottom:14px">comece por aqui</div>
      <h2 class="h2 h2-w r d1" style="margin-bottom:18px">
        A gente mede antes de mudar.<br /><em>E escuta antes de medir.</em>
      </h2>
      <p class="body body-lt r d2" style="max-width:540px;margin-bottom:14px">
        Avaliação de composição corporal por bioimpedância. Em bom português: uma balança
        inteligente que separa músculo, gordura e água, para o seu plano partir de dados, não de
        achismo.
      </p>
      <p class="body body-lt r d2" style="max-width:540px;margin-bottom:36px">
        Rápida, indolor e com devolutiva explicada. O ponto de partida ideal para qualquer programa.
      </p>
      <div class="r d3">
        <a
          href={wa('Olá, gostaria de agendar uma avaliação de bioimpedância na ecooa')}
          target="_blank"
          rel="noopener noreferrer"
          class="bw"
          data-intent="working-bioimpedancia">agendar minha bioimpedância</a
        >
      </div>
      <p
        class="r d3"
        style="margin-top:16px;font-size:11px;font-weight:300;color:rgba(255,255,255,.55);letter-spacing:.03em"
      >
        Primeira consulta sem compromisso. Você decide se quer continuar.
      </p>
    </div>
  </section>

  <!-- Integração nutri + médico, com prova social discreta -->
  <section
    style="background:var(--color-cream);padding:96px var(--section-px)"
    aria-label="Integração com a medicina"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl r" style="margin-bottom:14px">o diferencial da casa</div>
      <h2 class="h2 r d1" style="margin-bottom:18px">
        Sua nutri e seu médico<br />conversam <em>entre si.</em>
      </h2>
      <p class="body r d2" style="max-width:520px;margin-bottom:48px">
        Aqui a nutricionista e o médico dividem exames, protocolo e evolução do mesmo caso. Você não
        carrega exames de um lado para o outro: sua história anda junta.
      </p>
      <div class="gr-grid r d2">
        <div class="gr-card">
          <p class="gr-quote">
            "Achava que nutrição era só dieta restritiva. O plano que recebi respeita minha rotina e
            os resultados vieram de forma natural."
          </p>
          <p class="gr-author">G. V.</p>
        </div>
        <div class="gr-card">
          <p class="gr-quote">
            "A nutricionista e o endocrinologista trabalham juntos aqui dentro. Isso mudou tudo no
            meu processo de emagrecimento."
          </p>
          <p class="gr-author">L. D.</p>
        </div>
        <div class="gr-card">
          <p class="gr-quote">
            "Sou vegana e sempre foi difícil achar profissional que levasse minha escolha a sério.
            Aqui encontrei nutrição com ciência e sem julgamento."
          </p>
          <p class="gr-author">I. C.</p>
        </div>
      </div>
      <p
        class="r d3"
        style="margin-top:24px;font-size:11px;font-weight:300;color:var(--color-ink-soft);letter-spacing:.02em"
      >
        Depoimentos reais publicados com autorização dos pacientes.
      </p>
    </div>
  </section>

  <GuiaSection
    unit="working"
    heading="Quem caminha<br>com <em>você.</em>"
    subtext="Nutricionistas especializadas em diferentes áreas, atendendo com a estrutura de uma clínica premium e dividindo o seu caso com o seu médico."
  />

  <!-- Artigos relacionados -->
  {
    nutriPosts.length > 0 && (
      <section
        style="background:var(--color-cream);padding:88px var(--section-px)"
        aria-label="Artigos relacionados"
      >
        <div style="max-width:1280px;margin:0 auto">
          <div class="lbl r" style="margin-bottom:36px">
            do nosso blog
          </div>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2px">
            {nutriPosts.map((post, i) => (
              <a
                href={`/blog/${post.id}`}
                class={`r d${Math.min(i, 3)}`}
                style="display:flex;flex-direction:column;text-decoration:none;color:inherit;padding:30px 28px;background:var(--color-white);border:1px solid var(--color-stone)"
              >
                <span style="font-size:9px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:12px">
                  {categoryLabels[post.data.category] || post.data.category}
                </span>
                <span style="font-family:var(--font-serif);font-size:18px;font-weight:400;color:var(--color-ink);line-height:1.4;margin-bottom:12px">
                  {post.data.title}
                </span>
                <span
                  class="ghost"
                  style="margin-top:auto;font-size:11px;color:var(--color-brand-text)"
                >
                  ler artigo <span aria-hidden="true">→</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <FaqVisivel faqs={workingFaqs} heading="Dúvidas sobre<br><em>nutrição.</em>" />

  <!-- Link discreto B2B -->
  <section
    style="background:var(--color-warm);padding:0 var(--section-px) 48px"
    aria-label="Para nutricionistas"
  >
    <p
      class="r"
      style="text-align:center;font-size:12px;font-weight:300;color:var(--color-ink-soft)"
    >
      É nutricionista? <a
        href="/para-nutricionistas"
        style="color:var(--color-brand-text);text-underline-offset:3px;text-decoration:underline"
        >Conheça a ecooa.working para nutricionistas →</a
      >
    </p>
  </section>

  <CtaSection
    heading="A sua próxima relação com a comida<br>começa <em>numa conversa.</em>"
    subtext="Agende sua avaliação e descubra como um plano feito para a sua vida real muda a sua relação com a saúde."
  />
</BaseLayout>

<style>
  .prog-row {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 16px 56px;
    border-top: 1px solid var(--color-stone);
    padding: 32px 0;
  }
  .prog-num {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-brand-text);
    margin-bottom: 10px;
  }
  .prog-nome {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 23px;
    font-weight: 400;
    color: var(--color-ink);
    line-height: 1.3;
  }
  @media (max-width: 720px) {
    .prog-row {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  }
</style>
