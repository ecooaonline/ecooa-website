---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import WavePattern from '../components/WavePattern.astro';
import Marquee from '../components/Marquee.astro';
import FaqVisivel from '../components/FaqVisivel.astro';
import EspelhoSection from '../components/EspelhoSection.astro';
import RiskReversalBadge from '../components/RiskReversalBadge.astro';
import PrimeiroPassoCTA from '../components/PrimeiroPassoCTA.astro';
import ProvaViva from '../components/ProvaViva.astro';
import GuiaSection from '../components/GuiaSection.astro';
import { WA_BASE } from '../data/constants';
import { getCollection } from 'astro:content';

const allMindPosts = await getCollection(
  'blog',
  ({ data }) => !data.draft && data.category === 'saude-mental'
);
const mindPosts = allMindPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const mindFaqs = [
  {
    q: 'Como funciona a sessão de acolhimento?',
    a: 'A primeira sessão é um espaço de acolhimento e escuta. Você conta o que está sentindo, no seu ritmo, e juntos definimos os próximos passos. Você decide se quer continuar.',
  },
  {
    q: 'Qual a diferença entre psicólogo e psiquiatra?',
    a: 'O psicólogo trabalha com psicoterapia (conversa estruturada). O psiquiatra é médico e pode prescrever medicamentos. Na ecooa, quando há indicação de avaliação médica, o encaminhamento acontece de forma integrada, com o seu histórico junto.',
  },
  {
    q: 'Preciso de medicação para começar terapia?',
    a: 'Não necessariamente. A necessidade de medicação é avaliada individualmente. Muitos pacientes se beneficiam apenas da psicoterapia.',
  },
  {
    q: 'Vocês atendem online?',
    a: 'Sim. Oferecemos atendimento presencial em Moinhos de Vento e online, conforme a preferência e indicação clínica.',
  },
  {
    q: 'O que eu falo fica em sigilo?',
    a: 'Sim, sigilo absoluto. O que você compartilha em sessão é protegido pelo código de ética profissional. Informações só circulam entre profissionais da equipe com o seu consentimento, quando isso ajuda o seu cuidado.',
  },
  {
    q: 'Posso trocar de profissional?',
    a: 'Pode, sem constrangimento. O vínculo com o terapeuta é parte do tratamento, e encontrar a pessoa certa faz diferença. É só avisar a recepção.',
  },
];

const WA_ACOLHIMENTO = `${WA_BASE}?text=${encodeURIComponent('Olá, gostaria de agendar uma sessão de acolhimento na ecooa.mind')}`;
---

<BaseLayout
  title="Psicologia em Porto Alegre | ecooa.mind · Moinhos de Vento"
  description="Psicologia presencial em Moinhos de Vento, Porto Alegre, ou online. Sessão de acolhimento com agendamento ágil, sem lista de espera e sem julgamento."
  currentPage="ecooa-mind"
  ogImage="/clinic/mind.webp"
  breadcrumbs={[{ name: 'ecooa.mind', url: '/ecooa-mind' }]}
>
  <!-- Hero -->
  <div class="ph" style="background:var(--color-ink)">
    <svg
      class="wsv u-op-05"
      viewBox="0 0 1440 500"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
      ><g fill="none" stroke="white" stroke-width="1"
        ><WavePattern count={8} x0={-100} y0={80} step={55} width={1600} /></g
      ></svg
    >
    <div class="ph-c">
      <div class="lbl lbl-lt r">ecooa.mind · saúde mental</div>
      <h1 class="h1 h1-w r d1 u-mt-18">
        Você não precisa<br />dar conta de tudo<br /><em>sozinho.</em>
      </h1>
      <p
        style="font-family:var(--font-serif);font-style:italic;font-size:15px;font-weight:300;color:rgba(255,255,255,.55);margin-top:14px"
        class="r d2"
      >
        Pedir ajuda não é fraqueza. É o primeiro capítulo.
      </p>
      <p class="body body-lt r d2" style="margin-top:10px;max-width:500px">
        Psicologia presencial em Moinhos de Vento ou online, com agendamento ágil da sua sessão de
        acolhimento. Sem lista de espera, sem julgamento.
      </p>
      <a
        href={WA_ACOLHIMENTO}
        target="_blank"
        rel="noopener noreferrer"
        class="bw r d3 u-cta"
        data-intent="mind-hero">agendar sessão de acolhimento</a
      >
      <RiskReversalBadge
        items={['sigilo absoluto', 'primeira sessão sem compromisso', 'respondemos em minutos']}
        light={true}
      />
    </div>
  </div>

  <Marquee />

  <ProvaViva
    items={['acolhimento sem lista de espera', 'presencial ou online', 'sigilo absoluto']}
  />

  <EspelhoSection
    label="você se reconhece?"
    items={[
      {
        text: 'acordo cansada mesmo tendo dormido',
        waText:
          'Olá, ando acordando cansada mesmo dormindo e gostaria de agendar uma sessão de acolhimento',
        intent: 'mind-espelho-cansaco',
      },
      {
        text: 'a ansiedade chega sem avisar',
        waText: 'Olá, gostaria de agendar uma sessão de acolhimento para ansiedade',
        intent: 'mind-espelho-ansiedade',
      },
      {
        text: 'estou no automático faz tempo',
        waText:
          'Olá, sinto que estou no automático faz tempo e gostaria de conversar com a equipe ecooa.mind',
        intent: 'mind-espelho-automatico',
      },
      {
        text: 'trabalho, entrego, sorrio, e por dentro estou no limite',
        waText:
          'Olá, estou com sinais de esgotamento e gostaria de agendar uma sessão de acolhimento',
        intent: 'mind-espelho-esgotamento',
      },
      {
        text: 'como por ansiedade e depois me culpo',
        waText:
          'Olá, como por ansiedade e depois me sinto culpada. Gostaria de conversar com a equipe ecooa.mind',
        intent: 'mind-espelho-compulsao',
      },
      {
        text: 'não sei nomear o que sinto, só sei que preciso conversar',
        waText: 'Olá, sinto que preciso de ajuda e gostaria de conversar com a equipe ecooa.mind',
        intent: 'mind-espelho-neutra',
      },
    ]}
    closing="Pedir ajuda não é fraqueza. É o primeiro capítulo."
  />

  <!-- Empatia -->
  <section
    style="background:var(--color-cream);padding:64px var(--section-px)"
    aria-label="Entendemos você"
  >
    <div class="u-narrow">
      <p class="body r" style="color:var(--color-ink-soft);line-height:1.9;font-size:14px">
        Acordar sem energia mesmo tendo dormido. A ansiedade que aparece sem motivo aparente. A
        sensação de viver no automático, sem espaço para o que importa. Você já tentou resolver por
        conta própria, mas o esgotamento persiste.
      </p>
      <p
        class="body r d1"
        style="color:var(--color-ink);line-height:1.9;font-size:14px;margin-top:14px;font-weight:400"
      >
        Pedir ajuda não é fraqueza. Na ecooa.mind, o primeiro passo é ser ouvido sem julgamento, no
        seu ritmo.
      </p>
    </div>
  </section>

  <!-- Foto do espaço -->
  <section
    style="background:var(--color-cream);padding:0;overflow:hidden"
    aria-label="Nosso espaço"
  >
    <div style="position:relative;width:100%;aspect-ratio:16/6;overflow:hidden">
      <OptimizedImage
        src="/clinic/mind.webp"
        alt="Sala de terapia da ecooa.mind, ambiente acolhedor e seguro"
        width={1200}
        height={798}
        class="u-cover"
      />
    </div>
  </section>

  <!-- Abordagem -->
  <section class="u-bg-warm" aria-label="Nossa abordagem">
    <div class="w">
      <div class="g2 g2c">
        <div>
          <div class="lbl r">nossa abordagem</div>
          <h2 class="h2 r d1 u-mt-15">Mente e corpo<br />não se <em>separam.</em></h2>
          <p class="body r d2 u-mt-18">
            A ecooa.mind nasceu da compreensão de que saúde plena é impossível sem saúde mental.
            Nossa equipe trabalha integrada ao restante do ecossistema ecooa: quando seu médico
            percebe que o componente emocional influencia seus resultados, a conexão com a
            ecooa.mind acontece de forma natural.
          </p>
          <p class="body r d3 u-mt-13">
            Sem burocracia, sem recomeçar do zero. A equipe já se conhece e você é o centro de tudo.
          </p>
        </div>
        <div class="r d2">
          <div
            style="background:var(--color-cream);padding:40px 34px;border:1px solid var(--color-stone)"
          >
            <div class="lbl u-mb-20">áreas de atuação</div>
            <div class="lr">
              <span class="u-dot"></span><span class="body-md">Psicoterapia individual</span>
            </div>
            <div class="lr">
              <span class="u-dot"></span><span class="body-md"
                >Encaminhamento médico integrado, quando indicado</span
              >
            </div>
            <div class="lr">
              <span class="u-dot"></span><span class="body-md"
                >Ansiedade e Transtornos de Humor</span
              >
            </div>
            <div class="lr">
              <span class="u-dot"></span><span class="body-md">Burnout e Estresse Crônico</span>
            </div>
            <div class="lr">
              <span class="u-dot"></span><span class="body-md"
                >Saúde Mental Feminina e Hormonal</span
              >
            </div>
            <div class="lr">
              <span class="u-dot"></span><span class="body-md">Transtornos Alimentares</span>
            </div>
            <div class="lr">
              <span class="u-dot"></span><span class="body-md"
                >Suporte Psicológico em Doenças Crônicas</span
              >
            </div>
            <div class="lr">
              <span class="u-dot"></span><span class="body-md">Psicologia Esportiva</span>
            </div>
            <div class="lr">
              <span class="u-dot"></span><span class="body-md"
                >Protocolo Oxford de Emagrecimento</span
              >
            </div>
            <div class="lr">
              <span class="u-dot"></span><span class="body-md">TDAH em adultos</span>
            </div>
            <div class="lr">
              <span class="u-dot"></span><span class="body-md">Terapia de casal</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <GuiaSection
    unit="mind"
    heading="Quem caminha<br>com <em>você.</em>"
    subtext="Psicólogas e psicólogos que criam um espaço seguro para você ser quem é, integrados ao restante do seu cuidado."
    max={3}
  />

  <!-- Diferenciais -->
  <section class="u-bg-cream" aria-label="Diferenciais ecooa.mind">
    <div class="w">
      <div class="lbl r u-mb-16">um ambiente seguro</div>
      <h2 class="h2 r d1 u-mb-40">Por que a <em>ecooa.mind</em><br />é diferente.</h2>
      <div class="g3">
        <div class="card-w">
          <h3 style="font-size:16px;font-weight:400;color:var(--color-ink);margin-bottom:8px">
            Integrado ao ecossistema
          </h3><p class="it-d-lg">
            Seu psicólogo já tem contexto sobre o seu cuidado clínico geral, sem que você precise
            repetir sua história a cada profissional.
          </p>
        </div>
        <div class="card-w">
          <h3 style="font-size:16px;font-weight:400;color:var(--color-ink);margin-bottom:8px">
            Ambiente pensado para você
          </h3><p class="it-d-lg">
            Nossa sala foi projetada para transmitir acolhimento, privacidade e calma. O ambiente
            faz parte do tratamento e precisa ecooar segurança.
          </p>
        </div>
        <div class="card-w">
          <h3 style="font-size:16px;font-weight:400;color:var(--color-ink);margin-bottom:8px">
            Sem lista de espera
          </h3><p class="it-d-lg">
            Agendamento ágil da sua sessão de acolhimento. Sabemos que quem busca ajuda não pode
            esperar.
          </p>
        </div>
      </div>
    </div>
  </section>

  <FaqVisivel faqs={mindFaqs} heading="Dúvidas sobre a<br><em>ecooa.mind.</em>" />

  <!-- Como funciona -->
  <section class="u-bg-cream" aria-label="Como funciona">
    <div class="w">
      <div class="lbl r u-mb-16">sua jornada</div>
      <h2 class="h2 r d1 u-mb-44">como <em>funciona</em></h2>
      <div
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:32px;max-width:800px;margin:0 auto"
      >
        <div class="r u-tac">
          <span class="step-num">1</span>
          <h3 class="it-t">Primeira conversa</h3>
          <p class="it-d">
            Pelo WhatsApp, no seu ritmo. Pode ser por texto ou por áudio. Nossa equipe acolhe e
            agenda.
          </p>
        </div>
        <div class="r d1 u-tac">
          <span class="step-num">2</span>
          <h3 class="it-t">Sessão de acolhimento</h3>
          <p class="it-d">
            Agendada sem demora, um espaço seguro para a sua história ser ouvida. Você decide se
            quer continuar.
          </p>
        </div>
        <div class="r d2 u-tac">
          <span class="step-num">3</span>
          <h3 class="it-t">Acompanhamento contínuo</h3>
          <p class="it-d">
            Sessões regulares, presenciais ou online, com objetivos combinados entre vocês. Terapia
            não é mágica, é caminho.
          </p>
        </div>
      </div>
      <p
        class="r d3"
        style="text-align:center;margin-top:36px;font-size:13px;font-weight:400;color:var(--color-brand-text);letter-spacing:.02em"
      >
        Primeira sessão sem compromisso. Você decide se quer continuar.
      </p>
    </div>
  </section>

  <!-- Depoimentos -->
  <section class="u-bg-cream" aria-label="Depoimentos de pacientes">
    <div class="w">
      <div class="lbl r u-mb-16">depoimentos</div>
      <h2 class="h2 r d1 u-mb-44">o que nossos pacientes <em>dizem</em></h2>
      <div class="grid-auto-260">
        <div class="r card-w">
          <p class="q-serif">
            "Adiei muito tempo procurar ajuda. Na primeira sessão já senti acolhimento de verdade. O
            ambiente é calmo e a escuta é genuína."
          </p>
          <p class="sm-soft">C.T.</p>
        </div>
        <div class="r d1 card-w">
          <p class="q-serif">
            "Minha psicóloga e meu médico conversam entre si sobre o meu caso. Isso fez o tratamento
            render muito mais. Me senti cuidada de forma completa."
          </p>
          <p class="sm-soft">A.P.</p>
        </div>
        <div class="r d2 card-w">
          <p class="q-serif">
            "Cheguei esgotada, quase em burnout. O acompanhamento integrado de psicologia e medicina
            me devolveu equilíbrio e qualidade de vida."
          </p>
          <p class="sm-soft">B.N.</p>
        </div>
      </div>
      <p
        class="r d3"
        style="text-align:center;margin-top:24px;font-size:11px;font-weight:300;color:var(--color-ink-soft);letter-spacing:.02em"
      >
        Depoimentos reais publicados com autorização dos pacientes.
      </p>
    </div>
  </section>

  <!-- Artigos relacionados -->
  {
    mindPosts.length > 0 && (
      <section class="u-bg-warm" aria-label="Artigos relacionados">
        <div class="w">
          <div class="lbl r u-mb-16">do nosso blog</div>
          <h2 class="h2 r d1 u-mb-44">
            artigos <em>relacionados</em>
          </h2>
          <div class="grid-auto-260">
            {mindPosts.map((post, i) => (
              <a
                href={`/blog/${post.id}`}
                class={`r d${i}`}
                style="display:block;background:var(--color-cream);border:1px solid var(--color-stone);padding:28px 24px;text-decoration:none;transition:border-color .2s ease"
              >
                <p style="font-size:11px;font-weight:400;color:var(--color-brand-text);letter-spacing:.04em;text-transform:lowercase;margin-bottom:10px">
                  {post.data.category}
                </p>
                <h3 style="font-size:15px;font-weight:400;color:var(--color-ink);line-height:1.5;margin-bottom:8px">
                  {post.data.title}
                </h3>
                <p style="font-size:12px;font-weight:300;line-height:1.7;color:var(--color-ink-soft)">
                  {post.data.description}
                </p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <PrimeiroPassoCTA
    heading="O primeiro passo pode ser<br>uma mensagem de <em>uma linha.</em>"
    subtext="A gente cuida do resto. Um ambiente seguro, acolhedor e sem julgamento."
    waText="Olá, gostaria de agendar uma sessão de acolhimento na ecooa.mind"
    label="agendar sessão de acolhimento"
    intent="mind-primeiro-passo"
    badges={['sem lista de espera', 'sigilo absoluto', 'você decide se continua']}
  />
</BaseLayout>
