---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import HeroEditorial from '../components/HeroEditorial.astro';
import MaskedWordBand from '../components/MaskedWordBand.astro';
import EspelhoSection from '../components/EspelhoSection.astro';
import FaqVisivel from '../components/FaqVisivel.astro';
import GuiaSection from '../components/GuiaSection.astro';
import PrimeiroPassoCTA from '../components/PrimeiroPassoCTA.astro';
import { WA_BASE } from '../data/constants';
import { getCollection } from 'astro:content';

const categoryLabels: { [key: string]: string } = {
  medicina: 'Medicina',
  estetica: 'Estética',
  nutricao: 'Nutrição',
  'saude-mental': 'Saúde Mental',
  longevidade: 'Longevidade',
  ecooa: 'ecooa',
};

const allMindPosts = await getCollection(
  'blog',
  ({ data }) => !data.draft && data.category === 'saude-mental'
);
const mindPosts = allMindPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const mindFaqs = [
  {
    q: 'Como funciona a sessão de acolhimento?',
    a: 'A primeira sessão é um espaço de acolhimento e escuta. Você conta o que está sentindo, no seu ritmo, e juntos definimos os próximos passos. Você decide se quer continuar.',
  },
  {
    q: 'Qual a diferença entre psicólogo e psiquiatra?',
    a: 'O psicólogo trabalha com psicoterapia (conversa estruturada). O psiquiatra é médico e pode prescrever medicamentos. Na ecooa, quando há indicação de avaliação médica, o encaminhamento acontece de forma integrada, com o seu histórico junto.',
  },
  {
    q: 'Preciso de medicação para começar terapia?',
    a: 'Não necessariamente. A necessidade de medicação é avaliada individualmente. Muitos pacientes se beneficiam apenas da psicoterapia.',
  },
  {
    q: 'Vocês atendem online?',
    a: 'Sim. Oferecemos atendimento presencial em Moinhos de Vento e online, conforme a preferência e indicação clínica.',
  },
  {
    q: 'O que eu falo fica em sigilo?',
    a: 'Sim, sigilo absoluto. O que você compartilha em sessão é protegido pelo código de ética profissional. Informações só circulam entre profissionais da equipe com o seu consentimento, quando isso ajuda o seu cuidado.',
  },
  {
    q: 'Posso trocar de profissional?',
    a: 'Pode, sem constrangimento. O vínculo com o terapeuta é parte do tratamento, e encontrar a pessoa certa faz diferença. É só avisar a recepção.',
  },
];

// Áreas de acolhimento consolidadas em lista editorial fina.
const mindAreas = [
  'Psicoterapia individual',
  'Ansiedade e transtornos de humor',
  'Burnout e estresse crônico',
  'Saúde mental feminina e hormonal',
  'Transtornos alimentares',
  'Suporte psicológico em doenças crônicas',
  'Psicologia esportiva',
  'Protocolo Oxford de Emagrecimento',
  'TDAH em adultos',
  'Terapia de casal',
  'Encaminhamento médico integrado, quando indicado',
];

const WA_ACOLHIMENTO = `${WA_BASE}?text=${encodeURIComponent('Olá, gostaria de agendar uma sessão de acolhimento na ecooa.mind')}`;
---

<BaseLayout
  title="Psicologia em Porto Alegre | ecooa.mind · Moinhos de Vento"
  description="Psicologia presencial em Moinhos de Vento, Porto Alegre, ou online. Sessão de acolhimento com agendamento ágil, sem lista de espera e sem julgamento."
  currentPage="ecooa-mind"
  ogImage="/clinic/mind.webp"
  breadcrumbs={[{ name: 'ecooa.mind', url: '/ecooa-mind' }]}
>
  <HeroEditorial
    label="ecooa.mind · saúde mental"
    title="Você não precisa<br />dar conta de tudo<br /><em>sozinho.</em>"
    sub="Psicologia presencial em Moinhos de Vento ou online, com agendamento ágil da sua sessão de acolhimento. Sem lista de espera, sem julgamento."
    ctaHref={WA_ACOLHIMENTO}
    ctaLabel="agendar sessão de acolhimento"
    ctaIntent="mind-hero"
    secondaryHref="#como-funciona"
    secondaryLabel="como funciona"
    badges={['sigilo absoluto', 'primeira sessão sem compromisso']}
    image="/clinic/mind.webp"
    imageAlt="Sala de terapia da ecooa.mind, ambiente acolhedor e seguro"
    imageCaption="sala ecooa.mind · moinhos de vento"
    vertical="cuidado que ecooa"
  />

  <MaskedWordBand word="mente" image="/clinic/mind.webp" />

  <!-- Entrada por dor -->
  <EspelhoSection
    label="você se reconhece?"
    items={[
      {
        text: 'acordo cansada mesmo tendo dormido',
        waText:
          'Olá, ando acordando cansada mesmo dormindo e gostaria de agendar uma sessão de acolhimento',
        intent: 'mind-espelho-cansaco',
      },
      {
        text: 'a ansiedade chega sem avisar',
        waText: 'Olá, gostaria de agendar uma sessão de acolhimento para ansiedade',
        intent: 'mind-espelho-ansiedade',
      },
      {
        text: 'estou no automático faz tempo',
        waText:
          'Olá, sinto que estou no automático faz tempo e gostaria de conversar com a equipe ecooa.mind',
        intent: 'mind-espelho-automatico',
      },
      {
        text: 'trabalho, entrego, sorrio, e por dentro estou no limite',
        waText:
          'Olá, estou com sinais de esgotamento e gostaria de agendar uma sessão de acolhimento',
        intent: 'mind-espelho-esgotamento',
      },
      {
        text: 'como por ansiedade e depois me culpo',
        waText:
          'Olá, como por ansiedade e depois me sinto culpada. Gostaria de conversar com a equipe ecooa.mind',
        intent: 'mind-espelho-compulsao',
      },
      {
        text: 'não sei nomear o que sinto, só sei que preciso conversar',
        waText: 'Olá, sinto que preciso de ajuda e gostaria de conversar com a equipe ecooa.mind',
        intent: 'mind-espelho-neutra',
      },
    ]}
    closing="Pedir ajuda não é fraqueza. É o primeiro capítulo."
  />

  <!-- Abordagem: corpo e mente integrados -->
  <section
    style="background:var(--color-warm);padding:104px var(--section-px)"
    aria-label="Nossa abordagem"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="g2 g2c">
        <div>
          <div class="lbl r">nossa abordagem</div>
          <h2 class="h2 r d1" style="margin-top:15px">
            Mente e corpo<br />não se <em>separam.</em>
          </h2>
          <p class="body r d2" style="margin-top:18px">
            A ecooa.mind nasceu da compreensão de que saúde plena é impossível sem saúde mental.
            Nossa equipe trabalha integrada ao restante do ecossistema ecooa: quando seu médico
            percebe que o componente emocional influencia seus resultados, a conexão com a
            ecooa.mind acontece de forma natural. Sem burocracia, sem recomeçar do zero. A equipe já
            se conhece e você é o centro de tudo.
          </p>
          <p class="body r d3" style="margin-top:13px">
            Do outro lado da porta, uma sala projetada para transmitir acolhimento, privacidade e
            calma. O ambiente também faz parte do tratamento e precisa ecooar segurança.
          </p>
        </div>
        <figure class="lux-frame r d2" style="margin:0">
          <OptimizedImage
            src="/clinic/respire.webp"
            alt="Sala Respire da ecooa, com jardim vertical e luz natural"
            width={900}
            height={1200}
            class="lux-frame-img"
          />
        </figure>
      </div>
      <div class="lbl r d3" style="margin-top:56px;margin-bottom:4px">áreas de acolhimento</div>
      <div
        class="r d3"
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));column-gap:40px;max-width:900px"
      >
        {
          mindAreas.map((area) => (
            <p style="font-size:12px;font-weight:300;color:var(--color-ink-soft);border-top:1px solid var(--color-stone);padding:11px 0;line-height:1.5">
              {area}
            </p>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Como funciona: pontuação escura -->
  <section
    style="background:var(--color-ink);padding:104px var(--section-px)"
    aria-label="Como funciona"
    id="como-funciona"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl lbl-lt r" style="margin-bottom:16px">sua jornada</div>
      <h2 class="h2 h2-w r d1" style="margin-bottom:20px">Como <em>funciona.</em></h2>
      <p class="body body-lt r d2" style="max-width:560px;margin-bottom:48px">
        Três passos, no seu ritmo. Terapia não é mágica, é caminho, e ele começa com uma mensagem.
      </p>
      <div class="gehrke-tiers">
        <div class="gehrke-tier r d1">
          <div class="gehrke-tier-num">01</div>
          <h3 class="gehrke-tier-name">Primeira conversa</h3>
          <p class="gehrke-tier-desc">
            Pelo WhatsApp, no seu ritmo. Pode ser por texto ou por áudio. Nossa equipe acolhe e
            agenda, sem lista de espera.
          </p>
        </div>
        <div class="gehrke-tier r d2">
          <div class="gehrke-tier-num">02</div>
          <h3 class="gehrke-tier-name">Sessão de acolhimento</h3>
          <p class="gehrke-tier-desc">
            Agendada sem demora, um espaço seguro para a sua história ser ouvida. Você decide se
            quer continuar.
          </p>
        </div>
        <div class="gehrke-tier r d3">
          <div class="gehrke-tier-num">03</div>
          <h3 class="gehrke-tier-name">Acompanhamento contínuo</h3>
          <p class="gehrke-tier-desc">
            Sessões regulares, presenciais ou online, com objetivos combinados entre vocês.
          </p>
        </div>
      </div>
      <p
        class="r d3"
        style="margin-top:40px;font-size:13px;font-weight:300;color:rgba(255,255,255,.55);letter-spacing:.02em"
      >
        Primeira sessão sem compromisso. Você decide se quer continuar.
      </p>
    </div>
  </section>

  <GuiaSection
    unit="mind"
    heading="Quem caminha<br>com <em>você.</em>"
    subtext="Psicólogas e psicólogos que criam um espaço seguro para você ser quem é, integrados ao restante do seu cuidado."
    max={3}
  />

  <!-- Depoimentos -->
  <section class="u-bg-cream" aria-label="Depoimentos de pacientes">
    <div class="w">
      <div class="lbl r" style="margin-bottom:16px">depoimentos</div>
      <h2 class="h2 r d1" style="margin-bottom:44px">
        O que nossos pacientes<br /><em>dizem.</em>
      </h2>
      <div class="gr-grid r d2">
        <div class="gr-card">
          <p class="gr-quote">
            "Adiei muito tempo procurar ajuda. Na primeira sessão já senti acolhimento de verdade. O
            ambiente é calmo e a escuta é genuína."
          </p>
          <p class="gr-author">C. T.</p>
        </div>
        <div class="gr-card">
          <p class="gr-quote">
            "Minha psicóloga e meu médico conversam entre si sobre o meu caso. Isso fez o tratamento
            render muito mais. Me senti cuidada de forma completa."
          </p>
          <p class="gr-author">A. P.</p>
        </div>
        <div class="gr-card">
          <p class="gr-quote">
            "Cheguei esgotada, quase em burnout. O acompanhamento integrado de psicologia e medicina
            me devolveu equilíbrio e qualidade de vida."
          </p>
          <p class="gr-author">B. N.</p>
        </div>
      </div>
      <p
        class="r d3"
        style="margin-top:24px;font-size:11px;font-weight:300;color:var(--color-ink-soft);letter-spacing:.02em"
      >
        Depoimentos reais publicados com autorização dos pacientes.
      </p>
    </div>
  </section>

  <!-- Artigos relacionados -->
  {
    mindPosts.length > 0 && (
      <section
        style="background:var(--color-warm);padding:88px var(--section-px)"
        aria-label="Artigos relacionados"
      >
        <div style="max-width:1280px;margin:0 auto">
          <div class="lbl r" style="margin-bottom:36px">
            do nosso blog
          </div>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2px">
            {mindPosts.map((post, i) => (
              <a
                href={`/blog/${post.id}`}
                class={`r d${Math.min(i, 3)}`}
                style="display:flex;flex-direction:column;text-decoration:none;color:inherit;padding:30px 28px;background:var(--color-cream);border:1px solid var(--color-stone)"
              >
                <span style="font-size:9px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:12px">
                  {categoryLabels[post.data.category] || post.data.category}
                </span>
                <span style="font-family:var(--font-serif);font-size:18px;font-weight:400;color:var(--color-ink);line-height:1.4;margin-bottom:12px">
                  {post.data.title}
                </span>
                <span
                  class="ghost"
                  style="margin-top:auto;font-size:11px;color:var(--color-brand-text)"
                >
                  ler artigo <span aria-hidden="true">→</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <FaqVisivel faqs={mindFaqs} heading="Dúvidas sobre a<br><em>ecooa.mind.</em>" />

  <PrimeiroPassoCTA
    heading="O primeiro passo pode ser<br>uma mensagem de <em>uma linha.</em>"
    subtext="A gente cuida do resto. Um ambiente seguro, acolhedor e sem julgamento."
    waText="Olá, gostaria de agendar uma sessão de acolhimento na ecooa.mind"
    label="agendar sessão de acolhimento"
    intent="mind-primeiro-passo"
    badges={['sem lista de espera', 'sigilo absoluto', 'você decide se continua']}
  />
</BaseLayout>
