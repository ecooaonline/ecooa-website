---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WavePattern from '../../components/WavePattern.astro';
import Marquee from '../../components/Marquee.astro';
import CtaSection from '../../components/CtaSection.astro';
import ProfessionalCard from '../../components/ProfessionalCard.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';
import { professionals } from '../../data/professionals';
import { curatedIntents } from '../../data/match-intents';
import { WA_BASE } from '../../data/constants';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return professionals.map(p => ({
    params: { slug: p.slug },
    props: { professional: p },
  }));
}

const { professional } = Astro.props;
const p = professional;

const unitLabels: Record<string, string> = {
  med: 'ecooa.med',
  esthetic: 'ecooa.esthetic',
  working: 'ecooa.working',
  mind: 'ecooa.mind',
};
const unitNames: Record<string, string> = {
  med: 'Medicina',
  esthetic: 'Estética',
  working: 'Nutrição',
  mind: 'Saúde Mental',
};
const unitPages: Record<string, string> = {
  med: '/ecooa-med',
  esthetic: '/ecooa-esthetic',
  working: '/ecooa-working',
  mind: '/ecooa-mind',
};

const waText = encodeURIComponent(`Olá, gostaria de agendar uma avaliação com ${p.name}`);
const WA = `${WA_BASE}?text=${waText}`;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const authorVariants = [p.name, `Dr. ${p.name}`, `Dra. ${p.name}`];
const articles = allPosts
  .filter(post => authorVariants.some(v => post.data.author.includes(v) || post.data.author.includes(p.name.split(' ')[0])))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);

const firstName = p.name.split(' ')[0];

function isPhysician(role: string) {
  return /\bMédic[oa]\b/i.test(role);
}

function credentialCategory(role: string): string {
  const lower = role.toLowerCase();
  if (/\bmedic[oa]?\b|\bmédic[oa]\b/.test(lower)) return 'CRM';
  if (lower.includes('nutricion')) return 'CRN';
  if (lower.includes('psicólog') || lower.includes('psicolog')) return 'CRP';
  if (lower.includes('bioméd') || lower.includes('biomed')) return 'CRBM';
  if (lower.includes('fisioterapeut') || lower.includes('osteop')) return 'CREFITO';
  if (lower.includes('enfermei')) return 'COREN';
  if (lower.includes('odontólog') || lower.includes('odontolog')) return 'CRO';
  return '';
}

function medicalSpecialty(role: string): string {
  const lower = role.toLowerCase();
  if (lower.includes('dermato') || lower.includes('capilar') || lower.includes('tricolog')) return 'Dermatology';
  if (lower.includes('psiquiatr')) return 'Psychiatric';
  if (lower.includes('endocrin')) return 'Endocrine';
  return 'PrimaryCare';
}

const schemaType = isPhysician(p.role) ? 'Physician' : 'Person';
const credential = credentialCategory(p.role);

const relatedIntents = curatedIntents.filter(
  (intent) => intent.topSlugs.includes(p.slug) || intent.unit === p.unit
).slice(0, 5);

const relatedProfessionals = professionals
  .filter((pp) => pp.unit === p.unit && pp.slug !== p.slug)
  .slice(0, 3);

const roleKeywords = p.role.split(' · ').filter(Boolean);
const seoTitle = `${p.name} - ${roleKeywords[0]} em Porto Alegre | ecooa`;
const seoDescription = `${p.description} Especialidades: ${p.tags.join(', ')}. Agende sua consulta na ecooa, Moinhos de Vento, Porto Alegre.`;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  currentPage="profissionais"
  ogImage={p.photo}
  breadcrumbs={[{ name: "Profissionais", url: "/profissionais" }, { name: p.name, url: `/profissionais/${p.slug}` }]}
>

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": schemaType,
  "@id": `https://www.somosecooa.com.br/profissionais/${p.slug}`,
  "name": p.name,
  "givenName": firstName,
  "jobTitle": roleKeywords[0],
  "description": p.description,
  "image": `https://www.somosecooa.com.br${p.photo}`,
  "url": `https://www.somosecooa.com.br/profissionais/${p.slug}`,
  ...(schemaType === 'Physician' ? { "medicalSpecialty": medicalSpecialty(p.role) } : {}),
  "knowsAbout": p.tags,
  ...(credential ? {
    "hasCredential": {
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": credential,
    }
  } : {}),
  "hasOccupation": {
    "@type": "Occupation",
    "name": roleKeywords[0],
    "occupationalCategory": unitNames[p.unit],
  },
  "memberOf": {
    "@type": "MedicalBusiness",
    "@id": "https://www.somosecooa.com.br/#organization",
    "name": "ecooa",
  },
  "worksFor": {
    "@type": "MedicalBusiness",
    "@id": "https://www.somosecooa.com.br/#organization",
    "name": "ecooa",
    "url": "https://www.somosecooa.com.br"
  },
  "workLocation": {
    "@type": "Place",
    "name": "ecooa - Moinhos de Vento",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Rua Mariante, 180, 9º andar",
      "addressLocality": "Porto Alegre",
      "addressRegion": "RS",
      "postalCode": "90430-180",
      "addressCountry": "BR"
    }
  },
  ...(p.ig ? { "sameAs": [`https://instagram.com/${p.ig.replace('@', '')}`] } : {}),
})} />

<!-- Match handoff banner (reads ?from=match&r=reason via client) -->
<div id="match-handoff" class="match-handoff" hidden aria-live="polite">
  <div class="match-handoff-inner">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg>
    <p>encontrado via <strong>ecooa.match</strong> <span id="match-handoff-reason"></span></p>
  </div>
</div>

<!-- Hero -->
<div class="ph" style="background:var(--color-ink)">
  <svg class="wsv u-op-05" viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true"><g fill="none" stroke="white" stroke-width="1"><WavePattern count={8} x0={-100} y0={80} step={55} width={1600} /></g></svg>
  <div class="ph-c">
    <a href="/profissionais" style="font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.4);text-decoration:none;margin-bottom:20px;display:inline-block" class="r">← profissionais</a>
    <div class="lbl lbl-lt r u-mb-12">{unitLabels[p.unit]}</div>
    <h1 class="h1 h1-w r d1 u-mt-10">{p.name}</h1>
    {p.isFounder && (
      <span style="display:inline-block;font-size:9px;font-weight:500;letter-spacing:.15em;text-transform:uppercase;color:var(--color-brand-deep);border:1px solid var(--color-brand-deep);padding:4px 12px;margin-top:12px" class="r d1">fundador(a)</span>
    )}
    <p class="body body-lt r d2" style="margin-top:16px;max-width:480px">{p.role}</p>
    {p.personalTouch && (
      <p class="body body-lt r d2" style="margin-top:14px;max-width:480px;font-style:italic;font-family:var(--font-serif);font-size:clamp(15px,1.6vw,18px);color:rgba(255,255,255,.65);line-height:1.5">"{p.personalTouch}"</p>
    )}
  </div>
</div>

<Marquee />

<!-- Sobre -->
<section class="u-bg-warm" aria-label={`Sobre ${p.name}`}>
  <div class="w">
    <div class="g2 g2c">
      <div>
        <div class="lbl r u-mb-16">sobre</div>
        <h2 class="h2 r d1 u-mb-18">Conheça<br><em>{firstName}.</em></h2>
        <p class="body r d2 u-mb-24">{p.description}</p>
        {credential && (
          <p class="r d2" style="font-size:11px;font-weight:400;color:var(--color-ink-ghost);letter-spacing:.04em;margin-bottom:20px">Registro profissional: {credential}</p>
        )}
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:32px" class="r d3">
          <a href={WA} target="_blank" rel="noopener noreferrer" class="bd" data-intent={`profissional-${p.slug}`}>agendar pelo whatsapp</a>
          <a href={`/agendamento?profissional=${p.slug}`} class="bo" data-intent={`profissional-form-${p.slug}`}>agendar pelo formulário</a>
          {p.ig && (
            <a href={`https://instagram.com/${p.ig.replace('@', '')}`} target="_blank" rel="noopener noreferrer" class="ghost">
              {p.ig}
            </a>
          )}
        </div>
        <a href={unitPages[p.unit]} style="font-size:11px;font-weight:400;color:var(--color-brand-text);letter-spacing:.04em;text-decoration:none" class="r d3">ver todos de {unitLabels[p.unit]} →</a>
      </div>
      <div class="r d2">
        <div style="aspect-ratio:3/4;overflow:hidden">
          <OptimizedImage
            src={p.photo}
            alt={p.name}
            loading="eager"
            decoding="async"
            class="u-cover"
            width={480}
            height={640}
            fetchpriority="high"
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Credenciais & Formação -->
{p.registration || p.education && (
  <section class="u-bg-warm" aria-label="Credenciais e formação">
    <div class="w">
      <div class="lbl r u-mb-16">credenciais</div>
      <h2 class="h2 r d1" style="margin-bottom:28px;font-size:clamp(22px,2.6vw,36px)">Trajetória<br><em>profissional.</em></h2>
      <div class="g2 g2c">
        <div class="r d1">
          {p.registration && (
            <div style="margin-bottom:28px">
              <p style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:var(--color-ink-ghost);margin-bottom:8px">registro profissional</p>
              <p style="font-size:16px;font-weight:400">{p.registration}</p>
            </div>
          )}
          {p.education?.graduation && (
            <div style="margin-bottom:28px">
              <p style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:var(--color-ink-ghost);margin-bottom:8px">graduação</p>
              <p style="font-size:16px;font-weight:400">{p.education.graduation}</p>
            </div>
          )}
        </div>
        <div class="r d1">
          {p.education?.postgrad && p.education.postgrad.length > 0 && (
            <div style="margin-bottom:28px">
              <p style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:var(--color-ink-ghost);margin-bottom:8px">pós-graduação & especialização</p>
              <ul style="margin:0;padding:0;list-style:none">
                {p.education.postgrad.map(pg => (
                  <li style="font-size:14px;font-weight:300;line-height:1.6;margin-bottom:6px">{pg}</li>
                ))}
              </ul>
            </div>
          )}
          {p.education?.residency && (
            <div style="margin-bottom:28px">
              <p style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:var(--color-ink-ghost);margin-bottom:8px">residência</p>
              <p style="font-size:14px;font-weight:300;line-height:1.6">{p.education.residency}</p>
            </div>
          )}
          {p.education?.courses && p.education.courses.length > 0 && (
            <div style="margin-bottom:28px">
              <p style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:var(--color-ink-ghost);margin-bottom:8px">cursos & certificações</p>
              <ul style="margin:0;padding:0;list-style:none">
                {p.education.courses.map(course => (
                  <li style="font-size:14px;font-weight:300;line-height:1.6;margin-bottom:4px">• {course}</li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
)}

<!-- Diferencial Clínico -->
{p.clinicalDifferential && (
  <section class="u-bg-cream" aria-label="Diferencial clínico">
    <div class="w">
      <div class="lbl r u-mb-16">abordagem</div>
      <h2 class="h2 r d1" style="margin-bottom:28px;font-size:clamp(22px,2.6vw,36px)">O que te<br><em>diferencia.</em></h2>
      <p class="body r d2" style="max-width:600px;font-size:clamp(14px,1.2vw,18px);line-height:1.7;color:var(--color-ink)">{p.clinicalDifferential}</p>
      {p.mainComplaints && p.mainComplaints.length > 0 && (
        <div style="margin-top:32px;padding:20px;background:var(--color-warm);border-left:4px solid var(--color-brand-deep)" class="r d3">
          <p style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:var(--color-ink-ghost);margin-bottom:12px">principais dores de seus pacientes</p>
          <ul style="margin:0;padding-left:20px;list-style:disc">
            {p.mainComplaints.map(complaint => (
              <li style="font-size:14px;font-weight:300;line-height:1.6;color:var(--color-ink);margin-bottom:8px">{complaint}</li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>
)}

<!-- Dúvidas Frequentes -->
{p.faqPairs && p.faqPairs.length > 0 && (
  <section class="u-bg-warm" aria-label="Dúvidas frequentes">
    <div class="w">
      <div class="lbl r u-mb-16">perguntas</div>
      <h2 class="h2 r d1" style="margin-bottom:32px;font-size:clamp(22px,2.6vw,36px)">Dúvidas<br><em>frequentes.</em></h2>
      <div style="max-width:700px" class="r d2">
        {p.faqPairs.map((pair, idx) => (
          <details style="margin-bottom:20px;padding:16px;background:var(--color-cream);border:1px solid var(--color-stone);cursor:pointer;border-radius:4px" open={idx === 0}>
            <summary style="font-weight:500;font-size:14px;line-height:1.5;color:var(--color-ink);outline:none">{pair.question}</summary>
            <p style="font-size:14px;font-weight:300;line-height:1.7;color:var(--color-ink);margin-top:12px;padding-top:12px;border-top:1px solid var(--color-stone)">{pair.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Caso Clínico -->
{p.caseStudy && (
  <section class="u-bg-cream" aria-label="Caso clínico representativo">
    <div class="w">
      <div class="lbl r u-mb-16">exemplar</div>
      <h2 class="h2 r d1" style="margin-bottom:28px;font-size:clamp(22px,2.6vw,36px)">Caso que<br><em>representa seu trabalho.</em></h2>
      <div class="r d2" style="max-width:700px;background:var(--color-warm);padding:28px;border-left:4px solid var(--color-brand-deep);border-radius:2px">
        <p style="font-size:14px;font-weight:300;line-height:1.8;color:var(--color-ink);white-space:pre-wrap">{p.caseStudy}</p>
        <p style="font-size:11px;font-weight:300;color:var(--color-ink-ghost);margin-top:16px;font-style:italic">Caso documentado sem identificação do paciente, com autorização de uso educacional.</p>
      </div>
    </div>
  </section>
)}

<!-- Valores & Agendamento -->
{p.pricing && (
  <section class="u-bg-warm" aria-label="Valores e agendamento">
    <div class="w">
      <div class="lbl r u-mb-16">investimento</div>
      <h2 class="h2 r d1" style="margin-bottom:32px;font-size:clamp(22px,2.6vw,36px)">Valores e<br><em>formas de atendimento.</em></h2>
      <div class="g2 g2c">
        <div class="r d1">
          {p.pricing.firstConsultation && (
            <div style="margin-bottom:24px">
              <p style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:var(--color-ink-ghost);margin-bottom:8px">primeira consulta</p>
              <p style="font-size:32px;font-weight:300">R$ {p.pricing.firstConsultation}</p>
            </div>
          )}
          {p.pricing.return && (
            <div style="margin-bottom:24px">
              <p style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:var(--color-ink-ghost);margin-bottom:8px">consulta de retorno</p>
              <p style="font-size:32px;font-weight:300">R$ {p.pricing.return}</p>
            </div>
          )}
        </div>
        <div class="r d1">
          {p.pricing.packages && p.pricing.packages.length > 0 && (
            <div>
              <p style="font-size:11px;font-weight:500;letter-spacing:.04em;text-transform:uppercase;color:var(--color-ink-ghost);margin-bottom:12px">programas & pacotes</p>
              <ul style="margin:0;padding:0;list-style:none">
                {p.pricing.packages.map(pkg => (
                  <li style="font-size:14px;font-weight:300;line-height:1.7;margin-bottom:12px;padding-bottom:12px;border-bottom:1px solid var(--color-stone)">{pkg}</li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
)}

<!-- Especialidades -->
<section class="u-bg-cream" aria-label="Especialidades">
  <div class="w">
    <div class="lbl r u-mb-16">especialidades</div>
    <h2 class="h2 r d1" style="margin-bottom:24px;font-size:clamp(22px,2.6vw,36px)">Áreas de<br><em>atuação.</em></h2>
    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:32px" class="r d1">
      {p.tags.map(tag => (
        <span class="tag-pill">{tag}</span>
      ))}
    </div>
    {relatedIntents.length > 0 && (
      <div class="r d2" style="margin-top:8px">
        <p style="font-size:11px;font-weight:400;color:var(--color-ink-ghost);letter-spacing:.04em;margin-bottom:10px">temas relacionados no ecooa.match:</p>
        <div style="display:flex;flex-wrap:wrap;gap:6px">
          {relatedIntents.map(intent => (
            <a href={`/match?q=${encodeURIComponent(intent.query)}`} class="tag-pill" style="font-size:9px;padding:4px 10px;text-decoration:none;color:var(--color-brand-text);border-color:var(--color-brand-deep);transition:all .15s">
              {intent.label}
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<!-- Artigos -->
{articles.length > 0 && (
  <section class="u-bg-warm" aria-label="Artigos">
    <div class="w">
      <div class="lbl r u-mb-16">artigos por {firstName}</div>
      <h2 class="h2 r d1" style="margin-bottom:32px;font-size:clamp(26px,3vw,42px)">Conteúdo que<br><em>transforma.</em></h2>
      <div style="display:grid;gap:16px">
        {articles.map(article => (
          <a href={`/blog/${article.id}`} style="display:block;padding:24px;background:var(--color-cream);text-decoration:none;color:inherit;border:1px solid var(--color-stone);transition:border-color .2s" class="r">
            <div style="display:flex;gap:8px;margin-bottom:8px">
              <span style="font-size:9px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-text)">{article.data.category}</span>
              <span style="font-size:9px;font-weight:300;color:var(--color-ink-soft)">{new Date(article.data.date).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}</span>
            </div>
            <p style="font-family:var(--font-serif);font-size:18px;font-weight:300;color:var(--color-ink);line-height:1.3;margin-bottom:6px">{article.data.title}</p>
            <p style="font-size:12px;font-weight:300;color:var(--color-ink-soft);line-height:1.7">{article.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- Profissionais relacionados -->
{relatedProfessionals.length > 0 && (
  <section class="u-bg-cream" aria-label="Profissionais relacionados">
    <div class="w">
      <div class="lbl r u-mb-16">na mesma unidade</div>
      <h2 class="h2 r d1" style="margin-bottom:32px;font-size:clamp(22px,2.6vw,36px)">Conheça também<br><em>quem atua junto.</em></h2>
      <div class="grid-auto-260">
        {relatedProfessionals.map((rp, i) => (
          <a href={`/profissionais/${rp.slug}`} class={`r d${i}`} style="text-decoration:none;color:inherit">
            <ProfessionalCard name={rp.name} role={rp.role} bg="var(--color-stone)" photo={rp.photo} slug={rp.slug} />
          </a>
        ))}
      </div>
      <p class="r d3" style="text-align:center;margin-top:20px">
        <a href="/profissionais" style="font-size:11px;font-weight:400;color:var(--color-brand-text);letter-spacing:.04em;text-decoration:none">ver todos os profissionais →</a>
      </p>
    </div>
  </section>
)}

<CtaSection heading={`Agende com<br><em>${firstName}.</em>`} subtext={`Converse diretamente com ${p.name} e receba orientação personalizada para o seu caso.`} />

</BaseLayout>

<script>
  try {
    const params = new URLSearchParams(location.search);
    if (params.get('from') === 'match') {
      const banner = document.getElementById('match-handoff');
      const reasonEl = document.getElementById('match-handoff-reason');
      if (banner && reasonEl) {
        const reason = params.get('r') || '';
        if (reason) reasonEl.textContent = `· ${reason}`;
        banner.hidden = false;
        banner.classList.add('is-visible');
      }
    }
  } catch {}
</script>
