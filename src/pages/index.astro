---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import HeroEditorial from '../components/HeroEditorial.astro';
import PaperCard from '../components/PaperCard.astro';
import EspelhoSection from '../components/EspelhoSection.astro';
import FaqVisivel from '../components/FaqVisivel.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_DEFAULT } from '../data/constants';
import { getCollection } from 'astro:content';

const WA = WA_DEFAULT;

const categoryLabels: { [key: string]: string } = {
  medicina: 'Medicina',
  estetica: 'Estética',
  nutricao: 'Nutrição',
  'saude-mental': 'Saúde Mental',
  longevidade: 'Longevidade',
  ecooa: 'ecooa',
};

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const homeFaqs = [
  {
    q: 'O que é a ecooa?',
    a: 'A ecooa é uma clínica multidisciplinar de saúde, estética e longevidade em Moinhos de Vento, Porto Alegre. Reunimos medicina de alta performance, estética avançada, nutrição, transplante capilar e saúde mental em um ecossistema integrado de cuidado.',
  },
  {
    q: 'Quais especialidades a ecooa oferece?',
    a: 'A ecooa oferece medicina de alta performance (emagrecimento, hormônios, longevidade), estética avançada (procedimentos faciais e corporais), transplante capilar, nutrição personalizada (clínica, esportiva e estética) e saúde mental (psicologia).',
  },
  {
    q: 'Onde fica a ecooa?',
    a: 'A ecooa fica na Rua Mariante, 180, 9º andar, no bairro Moinhos de Vento, em Porto Alegre, RS. O atendimento é de segunda a sexta, das 9h às 20h.',
  },
  {
    q: 'Como agendar uma consulta na ecooa?',
    a: 'Você pode agendar sua avaliação pelo WhatsApp (51) 99146-0909 ou pela página de agendamento do site. Nossa equipe irá orientar você sobre o melhor profissional para suas necessidades.',
  },
  {
    q: 'Quanto custa a primeira consulta?',
    a: 'Os valores variam conforme a especialidade e o profissional. Fale com a gente pelo WhatsApp para receber os valores atualizados e as condições de cada protocolo.',
  },
  {
    q: 'A ecooa atende convênio?',
    a: 'Nosso atendimento é particular, com emissão de recibo para você solicitar reembolso ao seu plano de saúde, conforme as regras do seu contrato.',
  },
  {
    q: 'Qual a nota da ecooa no Google?',
    a: 'A ecooa possui nota 5.0 no Google, a nota máxima possível, com avaliações de pacientes reais que destacam o acolhimento, a qualidade do atendimento e os resultados obtidos.',
  },
];

const areas = [
  {
    href: '/ecooa-med',
    title: 'medicina',
    sub: 'ecooa.med',
    desc: 'longevidade com precisão e medicina de excelência.',
    image: '/clinic/respire.webp',
    imageAlt: 'Consultório médico da ecooa',
  },
  {
    href: '/ecooa-esthetic',
    title: 'estética',
    sub: 'ecooa.esthetic',
    desc: 'beleza que respeita sua essência.',
    image: '/clinic/esthetic.webp',
    imageAlt: 'Sala de estética da ecooa',
  },
  {
    href: '/ecooa-working',
    title: 'nutrição',
    sub: 'ecooa.working',
    desc: 'alimentação que sustenta sua melhor versão.',
    image: '/clinic/working.webp',
    imageAlt: 'Espaço de nutrição da ecooa',
  },
  {
    href: '/ecooa-mind',
    title: 'mente',
    sub: 'ecooa.mind',
    desc: 'clareza mental para uma vida com propósito.',
    image: '/clinic/mind.webp',
    imageAlt: 'Sala de acolhimento da ecooa',
  },
  {
    href: '/mentorias',
    title: 'educação',
    sub: 'ecooa.cademy',
    desc: 'formação e mentorias para quem cuida.',
    image: '/clinic/reuniao.webp',
    imageAlt: 'Auditório da ecooa',
  },
  {
    href: '/match',
    title: 'começo',
    sub: 'ecooa.match',
    desc: 'a porta de entrada para quem não sabe por onde começar.',
    image: '/clinic/recepcao.webp',
    imageAlt: 'Recepção da ecooa',
  },
];
---

<BaseLayout
  title="ecooa | Clínica de Saúde e Estética em Porto Alegre"
  description="Clínica de saúde, estética e longevidade em Moinhos de Vento, Porto Alegre. Medicina humanizada, nutrição, estética avançada e saúde mental."
>
  <HeroEditorial
    title="Chegue com<br />o que dói.<br />Saia com um <em>plano.</em>"
    signature={true}
    stars={true}
    ctaHref={WA}
    ctaLabel="falar pelo whatsapp"
    ctaIntent="homepage-hero"
    secondaryHref="/agendamento"
    secondaryLabel="comece pelo plano"
    image="/clinic/respire.webp"
    imageAlt="Sala Respire da ecooa, consultório premium com jardim vertical"
    imageCaption="sala respire · moinhos de vento"
  />

  <!-- As casas da ecooa -->
  <section
    style="background:var(--color-warm);padding:40px var(--section-px) 96px"
    aria-label="Áreas da clínica"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="areas-grid">
        {
          areas.map((a, i) => (
            <PaperCard
              href={a.href}
              title={a.title}
              sub={a.sub}
              desc={a.desc}
              image={a.image}
              imageAlt={a.imageAlt}
              delay={`d${Math.min(i, 3)}`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Entrada por dor -->
  <EspelhoSection
    label="o que trouxe você até aqui?"
    items={[
      {
        text: 'não consigo emagrecer',
        waText:
          'Olá, não consigo emagrecer e gostaria de um acompanhamento que funcione de verdade',
        intent: 'home-dor-emagrecer',
      },
      {
        text: 'meus exames parecem normais, mas eu não estou bem',
        waText:
          'Olá, meus exames parecem normais mas eu não estou bem. Gostaria de uma avaliação completa',
        intent: 'home-dor-exames',
      },
      {
        text: 'meu cabelo está caindo',
        waText: 'Olá, meu cabelo está caindo e gostaria de uma avaliação séria',
        intent: 'home-dor-cabelo',
      },
      {
        text: 'quero cuidar da pele sem exageros',
        waText: 'Olá, quero cuidar da minha pele com resultado natural, sem exageros',
        intent: 'home-dor-pele',
      },
      {
        text: 'minha energia caiu',
        waText: 'Olá, minha energia caiu e gostaria de investigar o que está acontecendo',
        intent: 'home-dor-energia',
      },
      {
        text: 'minha mente pede cuidado',
        waText: 'Olá, sinto que minha mente pede cuidado e gostaria de conversar',
        intent: 'home-dor-mente',
      },
    ]}
    closing="E se você não sabe por onde começar, o ecooa.match escuta e indica."
  />

  <!-- Metodologia -->
  <section
    style="background:var(--color-cream);padding:96px var(--section-px)"
    aria-label="Como cuidamos"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl r" style="margin-bottom:14px">como cuidamos</div>
      <h2 class="h2 r d1" style="margin-bottom:56px">Um método, quatro<br /><em>gestos.</em></h2>
      <div
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:36px;max-width:1100px"
      >
        <div class="r" style="border-top:1px solid var(--color-brand-mid);padding-top:20px">
          <p
            style="font-size:10px;font-weight:500;letter-spacing:.18em;color:var(--color-brand-text);margin-bottom:10px"
          >
            01
          </p>
          <h3
            style="font-family:var(--font-serif);font-style:italic;font-size:24px;font-weight:400;color:var(--color-ink);margin-bottom:10px"
          >
            escuta
          </h3>
          <p class="it-d-lg">
            Você conta sua história uma vez, com tempo de verdade. Nada de consulta apressada.
          </p>
        </div>
        <div class="r d1" style="border-top:1px solid var(--color-brand-mid);padding-top:20px">
          <p
            style="font-size:10px;font-weight:500;letter-spacing:.18em;color:var(--color-brand-text);margin-bottom:10px"
          >
            02
          </p>
          <h3
            style="font-family:var(--font-serif);font-style:italic;font-size:24px;font-weight:400;color:var(--color-ink);margin-bottom:10px"
          >
            dados
          </h3>
          <p class="it-d-lg">
            Exames, composição corporal e contexto. O seu plano parte de evidência, não de achismo.
          </p>
        </div>
        <div class="r d2" style="border-top:1px solid var(--color-brand-mid);padding-top:20px">
          <p
            style="font-size:10px;font-weight:500;letter-spacing:.18em;color:var(--color-brand-text);margin-bottom:10px"
          >
            03
          </p>
          <h3
            style="font-family:var(--font-serif);font-style:italic;font-size:24px;font-weight:400;color:var(--color-ink);margin-bottom:10px"
          >
            plano
          </h3>
          <p class="it-d-lg">
            Um caminho claro, construído com você e integrado entre as áreas da casa.
          </p>
        </div>
        <div class="r d3" style="border-top:1px solid var(--color-brand-mid);padding-top:20px">
          <p
            style="font-size:10px;font-weight:500;letter-spacing:.18em;color:var(--color-brand-text);margin-bottom:10px"
          >
            04
          </p>
          <h3
            style="font-family:var(--font-serif);font-style:italic;font-size:24px;font-weight:400;color:var(--color-ink);margin-bottom:10px"
          >
            acompanhamento
          </h3>
          <p class="it-d-lg">
            Retornos que ajustam o percurso no seu ritmo. Cuidado é continuidade.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Avaliações -->
  <section
    style="background:var(--color-warm);padding:88px var(--section-px)"
    aria-label="Avaliações no Google"
  >
    <div style="text-align:center;margin-bottom:36px">
      <div class="lbl r" style="justify-content:center">avaliações reais</div>
      <div class="r d1" style="margin-top:14px">
        <a
          href="https://g.page/r/CR6HT7KGWT_3EAI"
          target="_blank"
          rel="noopener noreferrer"
          class="stars-quiet"
        >
          <span class="st-glyphs" aria-hidden="true">★ ★ ★ ★ ★</span> 5.0 no Google
        </a>
      </div>
    </div>
    <div class="gr-grid r d2">
      <div class="gr-card">
        <div class="gr-stars" aria-hidden="true">★★★★★</div>
        <p class="gr-quote">
          "Fui muito bem recebida desde a recepção. O Dr. Gustavo ouviu tudo com calma e explicou
          cada detalhe dos meus exames. Saí sabendo exatamente o que fazer."
        </p>
        <p class="gr-author">C. M.</p>
      </div>
      <div class="gr-card">
        <div class="gr-stars" aria-hidden="true">★★★★★</div>
        <p class="gr-quote">
          "O ambiente é lindo e acolhedor. Fiz acompanhamento nutricional e médico ao mesmo tempo, e
          os profissionais conversaram entre si sobre o meu caso. Nunca tinha vivido isso."
        </p>
        <p class="gr-author">R. S.</p>
      </div>
      <div class="gr-card">
        <div class="gr-stars" aria-hidden="true">★★★★★</div>
        <p class="gr-quote">
          "Depois de passar por vários endocrinologistas sem resultado, encontrei na ecooa o cuidado
          que eu precisava. Em três meses já vi mudanças reais."
        </p>
        <p class="gr-author">F. L.</p>
      </div>
    </div>
  </section>

  <!-- O espaço: pontuação escura -->
  <section
    style="background:var(--color-ink);padding:96px var(--section-px)"
    aria-label="Nosso espaço"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl lbl-lt r" style="margin-bottom:14px">o espaço</div>
      <h2 class="h2 h2-w r d1" style="margin-bottom:18px">
        Salas que valorizam<br />quem <em>cuida</em> e quem é <em>cuidado.</em>
      </h2>
      <p class="body body-lt r d2" style="max-width:520px;margin-bottom:48px">
        Painéis de madeira, jardim vertical, iluminação pensada e uma vista privilegiada de Porto
        Alegre. Cada detalhe do 9º andar foi projetado para acolher.
      </p>
      <div
        class="r d2"
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:26px"
      >
        <figure class="lux-frame" style="margin:0">
          <OptimizedImage
            src="/clinic/recepcao.webp"
            alt="Recepção da ecooa"
            width={1000}
            height={1233}
            class="lux-frame-img"
          />
        </figure>
        <figure class="lux-frame" style="margin:0">
          <OptimizedImage
            src="/clinic/respire.webp"
            alt="Sala Respire da ecooa"
            width={900}
            height={1200}
            class="lux-frame-img"
          />
        </figure>
        <figure class="lux-frame" style="margin:0">
          <OptimizedImage
            src="/clinic/reuniao.webp"
            alt="Sala de reuniões da ecooa"
            width={1000}
            height={666}
            class="lux-frame-img"
          />
        </figure>
      </div>
      <div class="r d3" style="margin-top:40px">
        <a href="/quem-somos" class="bow">conhecer a ecooa</a>
      </div>
    </div>
  </section>

  <!-- Artigos recentes -->
  <section
    style="background:var(--color-warm);padding:88px var(--section-px)"
    aria-label="Artigos recentes"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl r" style="margin-bottom:36px">artigos recentes</div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2px">
        {
          recentPosts.map((post, i) => (
            <a
              href={`/blog/${post.id}`}
              class={`r d${Math.min(i, 3)}`}
              style="display:flex;flex-direction:column;text-decoration:none;color:inherit;padding:30px 28px;background:var(--color-cream);border:1px solid var(--color-stone)"
            >
              <span style="font-size:9px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:12px">
                {categoryLabels[post.data.category] || post.data.category}
              </span>
              <span style="font-family:var(--font-serif);font-size:18px;font-weight:400;color:var(--color-ink);line-height:1.4;margin-bottom:12px">
                {post.data.title}
              </span>
              <span
                class="ghost"
                style="margin-top:auto;font-size:11px;color:var(--color-brand-text)"
              >
                ler artigo <span aria-hidden="true">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <FaqVisivel faqs={homeFaqs} heading="Dúvidas sobre a<br><em>ecooa.</em>" />

  <CtaSection
    heading="Comece pelo<br><em>plano.</em>"
    subtext="A primeira conversa reduz a ansiedade e devolve a clareza. Estamos em Moinhos de Vento."
  />
</BaseLayout>
