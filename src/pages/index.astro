---
import BaseLayout from '../layouts/BaseLayout.astro';
import WavePattern from '../components/WavePattern.astro';
import Marquee from '../components/Marquee.astro';
import PillarCard from '../components/PillarCard.astro';
import ProfessionalCard from '../components/ProfessionalCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_DEFAULT } from '../data/constants';
import { getCollection } from 'astro:content';

const WA = WA_DEFAULT;

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout
  title="ecooa | Clínica de Saúde e Estética em Porto Alegre"
  description="A ecooa é uma clínica multidisciplinar de saúde, estética e longevidade em Moinhos de Vento, Porto Alegre. Medicina humanizada, estética avançada, nutrição e saúde mental."
>

<!-- Hero -->
<section class="hero" aria-label="Apresentação ecooa">
  <div class="hl">
    <div class="hl-lbl lbl">Porto Alegre · Moinhos de Vento</div>
    <h1 class="hh1">Sua saúde merece mais do que<br><em>respostas genéricas.</em></h1>
    <p class="hl-sub body">Medicina, nutrição, psicologia e estética trabalhando juntos. Para que você se sinta, de verdade, cuidado.</p>
    <div class="hl-act">
      <a href="/agendamento" class="bd">agendar avaliação</a>
      <a href={WA} target="_blank" rel="noopener noreferrer" class="ghost" data-intent="homepage-hero">falar pelo whatsapp <span aria-hidden="true">→</span></a>
    </div>
    <p style="font-size:10px;font-weight:400;color:var(--color-ink-soft);letter-spacing:.04em;margin-top:4px">respondemos em minutos</p>
    <div class="hl-ft"><div class="sl"></div><span class="sl-t">scroll</span></div>
  </div>
  <div class="hr">
    <svg class="wsv" viewBox="0 0 700 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <rect width="700" height="900" fill="#C4BBB8"/>
      <g fill="none" stroke="rgba(255,255,255,0.17)" stroke-width="1.3"><WavePattern count={22} x0={-80} y0={80} step={40} width={700} /></g>
      <g transform="translate(170, 380) scale(1.6)" opacity="1">
