---
import BaseLayout from '../layouts/BaseLayout.astro';
import WavePattern from '../components/WavePattern.astro';
import Marquee from '../components/Marquee.astro';
import PillarCard from '../components/PillarCard.astro';
import ProfessionalCard from '../components/ProfessionalCard.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CtaSection from '../components/CtaSection.astro';

const WA = 'https://wa.me/5551991460909';
---

<BaseLayout
  title="ecooa | Saúde, Estética e Longevidade · Moinhos de Vento, Porto Alegre"
  description="A ecooa é uma clínica multidisciplinar de saúde, estética e longevidade em Moinhos de Vento, Porto Alegre. Medicina humanizada, estética avançada, nutrição e saúde mental."
>

<!-- Hero -->
<section class="hero" aria-label="Apresentação ecooa">
  <div class="hl">
    <div class="hl-lbl lbl">Porto Alegre · Moinhos de Vento</div>
    <h1 class="hh1">Um lugar que <em>acolhe</em><br>pessoas que cuidam<br>e são <em>cuidadas.</em></h1>
    <p class="hl-sub body">Medicina humanizada, estética avançada, nutrição, saúde mental e longevidade: um ecossistema onde o seu cuidado pode ecooar.</p>
    <div class="hl-act">
      <a href="/quem-somos" class="bd">conhecer a ecooa</a>
      <a href={WA} target="_blank" rel="noopener noreferrer" class="ghost">falar pelo whatsapp <span aria-hidden="true">→</span></a>
    </div>
    <div class="hl-ft"><div class="sl"></div><span class="sl-t">scroll</span></div>
  </div>
  <div class="hr">
