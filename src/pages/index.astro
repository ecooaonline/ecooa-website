9.0L101.5,40.3L105.2,41.3L109.3,41.5L109.3,0.3Z M66.0,0.3L62.7,1.0L58.3,2.8L55.0,5.2L52.0,8.3L50.0,11.5L48.5,15.3L47.8,19.2L48.0,24.2L49.2,28.5L52.7,34.3L55.8,37.3L62.7,40.8L66.0,41.5L71.0,41.5L74.8,40.7L78.3,39.2L82.2,36.5L84.2,34.3L79.5,29.7L75.7,33.0L70.7,34.8L66.3,34.8L61.3,33.0L57.5,29.7L55.5,26.3L54.5,22.7L54.5,19.2L55.5,15.5L57.5,12.2L59.7,10.0L64.8,7.3L67.8,6.8L72.2,7.3L75.7,8.8L79.5,12.2L84.2,7.3L80.0,3.7L75.3,1.3L71.0,0.3Z M18.5,0.3L15.2,1.0L10.5,3.0L7.8,4.8L4.3,8.5L1.0,15.2L0.3,23.2L1.3,27.7L2.8,31.0L5.0,34.2L8.5,37.5L15.2,40.8L18.5,41.5L23.3,41.5L28.7,40.2L31.7,38.7L36.7,34.3L31.8,29.7L27.8,33.2L24.0,34.7L20.2,35.0L15.8,34.0L13.0,32.5L9.8,29.5L7.8,26.0L7.5,24.2L41.3,24.2L41.5,18.3L40.2,13.2L36.7,7.3L31.3,3.0L26.7,1.0L23.3,0.3Z M7.3,17.3L7.8,15.8L8.8,13.8L9.8,12.3L12.3,9.8L14.3,8.5L15.8,7.8L18.0,7.2L20.2,6.8L23.0,7.0L25.2,7.5L27.8,8.7L29.3,9.7L32.2,12.5L33.8,15.3L34.5,17.3Z"/>
        <text x="214" y="12" font-family="system-ui,sans-serif" font-size="22" font-weight="300" fill="#FFFFFF">®</text>
      </g>
    </svg>
    <div class="hq">
      <div class="hero-google-badge">
        <div class="hgb-stars" aria-label="5 estrelas">★★★★★</div>
        <div class="hgb-score">5.0</div>
        <div class="hgb-label">no Google</div>
      </div>
    </div>
  </div>
</section>

<Marquee />

<!-- Empatia -->
<section class="empathy-section" aria-label="Você se identifica?">
  <div class="empathy-wrap">
    <div class="empathy-questions">
      <p class="empathy-q r">Você já saiu de uma consulta sentindo que não foi ouvido?</p>
      <p class="empathy-q r d1">Já fez exames e ninguém explicou direito o que significam?</p>
      <p class="empathy-q r d2">Já tentou emagrecer sem entender por que não funciona?</p>
    </div>
    <div class="empathy-answer r d3">
      <p class="empathy-lead">Na ecooa, cada paciente é um caso único.</p>
      <p class="empathy-body body">Nosso time de 30 especialistas trabalha junto para encontrar respostas reais. Medicina, nutrição, psicologia e estética conectados por um objetivo: cuidar de você de verdade.</p>
      <a href="/agendamento" class="bd" style="margin-top:24px;display:inline-block">agendar avaliação</a>
    </div>
  </div>
</section>

<!-- Persona -->
<section class="persona-section" aria-label="Como podemos ajudar">
  <div class="w">
    <div class="lbl r" style="margin-bottom:14px;justify-content:center;text-align:center">como podemos ajudar</div>
    <h2 class="h2 r d1" style="text-align:center;margin-bottom:48px">O que você precisa<br><em>neste momento?</em></h2>
    <div class="persona-grid">
      <a href="/ecooa-med" class="persona-card r">
        <span class="persona-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z" stroke="currentColor" stroke-width="1"/></svg></span>
        <span class="persona-label">quero cuidar da minha saúde</span>
        <span class="persona-arrow" aria-hidden="true">→</span>
      </a>
      <a href="/ecooa-esthetic" class="persona-card r d1">
        <span class="persona-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1"/></svg></span>
        <span class="persona-label">quero cuidar da minha estética</span>
        <span class="persona-arrow" aria-hidden="true">→</span>
      </a>
      <a href="/ecooa-mind" class="persona-card r d2">
        <span class="persona-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1"/><path d="M12 8v4l3 3" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg></span>
        <span class="persona-label">quero cuidar da minha mente</span>
        <span class="persona-arrow" aria-hidden="true">→</span>
      </a>
      <a href="/ecooa-working" class="persona-card r d3">
        <span class="persona-icon"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 22C6 22 2 17 2 11c0-2 1-4 2-5 1 4 4 6 8 6s7-2 8-6c1 1 2 3 2 5 0 6-4 11-10 11z" stroke="currentColor" stroke-width="1"/></svg></span>
        <span class="persona-label">quero cuidar da minha nutrição</span>
        <span class="persona-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<!-- Google Reviews -->
<section style="background:var(--color-warm);padding:56px var(--section-px)" aria-label="Avaliações no Google">
  <div style="text-align:center;margin-bottom:32px">
    <div class="lbl r" style="justify-content:center">avaliações reais</div>
    <div class="r d1" style="margin-top:14px;display:flex;align-items:center;justify-content:center;gap:10px">
      <span style="color:#E8B931;font-size:22px;letter-spacing:2px" aria-label="5 estrelas">★★★★★</span>
      <span style="font-size:28px;font-weight:200;color:var(--color-ink);letter-spacing:-.02em">5.0</span>
      <a href="https://www.google.com/maps/place/ecooa" target="_blank" rel="noopener noreferrer" style="font-size:12px;font-weight:300;color:var(--color-ink-soft);text-decoration:none;border-bottom:1px solid var(--color-stone)">no Google</a>
    </div>
  </div>
  <div class="gr-grid r d2">
    <div class="gr-card">
      <div class="gr-stars" aria-hidden="true">★★★★★</div>
      <p class="gr-quote">"Fui muito bem recebida desde a recepção. O Dr. Gustavo ouviu tudo com calma e explicou cada detalhe dos meus exames. Saí sabendo exatamente o que fazer."</p>
      <p class="gr-author">C. M.</p>
    </div>
    <div class="gr-card">
      <div class="gr-stars" aria-hidden="true">★★★★★</div>
      <p class="gr-quote">"O ambiente é lindo e acolhedor. Fiz acompanhamento nutricional e médico ao mesmo tempo, e os profissionais conversaram entre si sobre o meu caso. Nunca tinha vivido isso."</p>
      <p class="gr-author">R. S.</p>
    </div>
    <div class="gr-card">
      <div class="gr-stars" aria-hidden="true">★★★★★</div>
      <p class="gr-quote">"Depois de passar por vários endocrinologistas sem resultado, encontrei na ecooa o cuidado que eu precisava. Em três meses já vi mudanças reais."</p>
      <p class="gr-author">F. L.</p>
    </div>
    <div class="gr-card">
      <div class="gr-stars" aria-hidden="true">★★★★★</div>
      <p class="gr-quote">"A nutricionista e o médico trabalham juntos no meu protocolo. Recomendo para quem quer um atendimento que realmente olha para a pessoa como um todo."</p>
      <p class="gr-author">M. T.</p>
    </div>
    <div class="gr-card">
      <div class="gr-stars" aria-hidden="true">★★★★★</div>
      <p class="gr-quote">"Comecei pela psicóloga e fui encaminhada para a nutrição. Tudo no mesmo lugar, com profissionais que se conhecem. Faz toda a diferença."</p>
      <p class="gr-author">A. P.</p>
    </div>
  </div>
</section>

<!-- Fundadores -->
<section style="background:var(--color-cream);padding:86px 60px" aria-label="Fundadores">
  <div style="max-width:900px;margin:0 auto;text-align:center">
    <div class="lbl r" style="justify-content:center;margin-bottom:16px">quem lidera a ecooa</div>
    <h2 class="h2 r d1" style="margin-bottom:48px">Fundadores que<br><em>vivem o propósito.</em></h2>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;text-align:left">
      <div class="r">
        <div style="aspect-ratio:3/4;overflow:hidden;margin-bottom:20px">
          <img src="/team/gustavo.webp" alt="Dr. Gustavo Gehrke, fundador da ecooa" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;display:block" width="480" height="640" />
        </div>
        <p style="font-size:10px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:6px">fundador</p>
        <p style="font-family:var(--font-serif);font-size:22px;font-weight:300;color:var(--color-ink);margin-bottom:4px">Dr. Gustavo Gehrke</p>
        <p style="font-size:12px;font-weight:300;color:var(--color-ink-soft);line-height:1.7;margin-bottom:12px">Médico Generalista. Fundador e diretor executivo da ecooa. Medicina de alta performance com foco em diagnóstico metabólico, equilíbrio hormonal e emagrecimento.</p>
        <a href="/profissionais/gustavo-gehrke" style="font-size:11px;font-weight:500;color:var(--color-brand-text);letter-spacing:.04em;text-decoration:none">ver perfil completo →</a>
      </div>
      <div class="r d1">
        <div style="aspect-ratio:3/4;overflow:hidden;margin-bottom:20px">
          <img src="/team/jessica.webp" alt="Jessica Stein, fundadora da ecooa" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;display:block" width="480" height="640" />
        </div>
        <p style="font-size:10px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:6px">fundadora</p>
        <p style="font-family:var(--font-serif);font-size:22px;font-weight:300;color:var(--color-ink);margin-bottom:4px">Jessica Stein</p>
        <p style="font-size:12px;font-weight:300;color:var(--color-ink-soft);line-height:1.7;margin-bottom:12px">Nutricionista. Sócia e diretora de ensino da ecooa. Referência em nutrição vegana e vegetariana, com expertise em análise bioquímica.</p>
        <a href="/profissionais/jessica-stein" style="font-size:11px;font-weight:500;color:var(--color-brand-text);letter-spacing:.04em;text-decoration:none">ver perfil completo →</a>
      </div>
    </div>
  </div>
</section>

<!-- Quem somos (intro) -->
<section style="background:var(--color-warm)" aria-label="Quem somos">
  <div class="w">
    <div class="g2 g2c">
      <div>
        <div class="lbl r">quem somos</div>
        <h2 class="h2 r d1" style="margin-top:15px">Somos a ecooa,<br>a clínica que <em>abraça</em><br>pessoas que cuidam<br>e são cuidadas.</h2>
        <p class="body r d2" style="margin-top:18px">Somos um ecossistema de crescimento, inovação, networking, bem-estar e ciência, onde cada detalhe foi pensado para que você se sinta vista, acolhida e cuidada do jeito que merece.</p>
        <a href="/quem-somos" class="bo r d3" style="margin-top:28px">nossa história</a>
        <div class="ia r d4">
          <div><span class="aw">acolhedora</span><span class="ad">um lugar onde você se sente em casa</span></div>
          <div><span class="aw">especialista</span><span class="ad">profissionais de referência em cada área</span></div>
          <div><span class="aw">integradora</span><span class="ad">todas as especialidades conectadas por você</span></div>
          <div><span class="aw">transformadora</span><span class="ad">do cuidado pontual à mudança que ecooa</span></div>
        </div>
      </div>
      <div class="iv r d2">
        <div class="ic ic-m" style="overflow:hidden">
          <img src="/clinic/recepcao.webp" alt="Recepção da ecooa, Moinhos de Vento" fetchpriority="high" loading="eager" decoding="async" width="1000" height="1233" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block" />
        </div>
        <div class="ic ic-f"><p class="if-lbl">cuidando com excelência</p><p class="if-v">desde 2021</p></div>
      </div>
    </div>
  </div>
</section>

<!-- Ecossistema -->
<section style="background:var(--color-cream)" aria-label="Serviços">
  <div class="w">
    <div class="ph2">
      <div>
        <div class="lbl r">o ecossistema ecooa</div>
        <h2 class="h2 r d1" style="margin-top:15px">Diferentes serviços.<br><em>Um propósito.</em></h2>
      </div>
      <p class="body r d2">Um ecossistema de cuidado completo, onde cada área ecooa com as demais para cuidar de você de dentro para fora.</p>
    </div>
    <div class="pg r">
      <PillarCard number="01" name="Medicina de Alta Performance" description="Emagreça, equilibre hormônios e viva mais com acompanhamento médico que escuta você." label="ecooa.med" href="/ecooa-med" />
      <PillarCard number="02" name="Estética Avançada" description="Resultados naturais que realçam sua beleza, com técnica refinada e profissionais de referência." label="ecooa.esthetic" href="/ecooa-esthetic" />
      <PillarCard number="03" name="Nutrição" description="Nutrição personalizada para seus objetivos. Clínica, esportiva ou estética, integrada à sua saúde." label="ecooa.working" href="/ecooa-working" />
      <PillarCard number="04" name="Transplante Capilar" description="Do diagnóstico ao transplante: referência em Porto Alegre para a saúde dos seus cabelos." label="ecooa.esthetic" href="/ecooa-esthetic" />
      <PillarCard number="05" name="Saúde Mental" description="Psicologia e psiquiatria para quem entende que saúde plena começa pela mente." label="ecooa.mind" href="/ecooa-mind" />
    </div>
  </div>
</section>

<!-- Metodologia -->
<section class="ap" aria-label="Metodologia">
  <div class="ap-vis" style="overflow:hidden">
    <img src="/clinic/reuniao-edit.webp" alt="Reunião na ecooa, metodologia de cuidado" loading="lazy" decoding="async" width="800" height="533" style="width:100%;height:100%;object-fit:cover;display:block" />
  </div>
  <div class="ap-cp">
    <div class="lbl lbl-lt r">nossa metodologia</div>
    <h2 class="h2 h2-w r d1" style="margin-top:15px">Cuidado que<br>começa na <em>escuta</em><br>e nunca termina.</h2>
    <p class="body body-lt r d2" style="margin-top:16px">Não trabalhamos com protocolos genéricos. Entendemos sua história, analisamos seus dados e construímos com você um caminho feito para os seus objetivos.</p>
    <div class="st st-dk r d3" style="margin-top:32px">
      <div class="sr"><span class="sn">01</span><div><div class="st-t">Diagnóstico e escuta ativa</div><div class="st-b">Nossa equipe multidisciplinar se conhece e se comunica. Cada especialista sabe o momento certo de envolver os demais, de forma natural e coordenada.</div></div></div>
