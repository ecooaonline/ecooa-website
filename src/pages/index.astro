9.0L101.5,40.3L105.2,41.3L109.3,41.5L109.3,0.3Z M66.0,0.3L62.7,1.0L58.3,2.8L55.0,5.2L52.0,8.3L50.0,11.5L48.5,15.3L47.8,19.2L48.0,24.2L49.2,28.5L52.7,34.3L55.8,37.3L62.7,40.8L66.0,41.5L71.0,41.5L74.8,40.7L78.3,39.2L82.2,36.5L84.2,34.3L79.5,29.7L75.7,33.0L70.7,34.8L66.3,34.8L61.3,33.0L57.5,29.7L55.5,26.3L54.5,22.7L54.5,19.2L55.5,15.5L57.5,12.2L59.7,10.0L64.8,7.3L67.8,6.8L72.2,7.3L75.7,8.8L79.5,12.2L84.2,7.3L80.0,3.7L75.3,1.3L71.0,0.3Z M18.5,0.3L15.2,1.0L10.5,3.0L7.8,4.8L4.3,8.5L1.0,15.2L0.3,23.2L1.3,27.7L2.8,31.0L5.0,34.2L8.5,37.5L15.2,40.8L18.5,41.5L23.3,41.5L28.7,40.2L31.7,38.7L36.7,34.3L31.8,29.7L27.8,33.2L24.0,34.7L20.2,35.0L15.8,34.0L13.0,32.5L9.8,29.5L7.8,26.0L7.5,24.2L41.3,24.2L41.5,18.3L40.2,13.2L36.7,7.3L31.3,3.0L26.7,1.0L23.3,0.3Z M7.3,17.3L7.8,15.8L8.8,13.8L9.8,12.3L12.3,9.8L14.3,8.5L15.8,7.8L18.0,7.2L20.2,6.8L23.0,7.0L25.2,7.5L27.8,8.7L29.3,9.7L32.2,12.5L33.8,15.3L34.5,17.3Z"/>
        <text x="214" y="12" font-family="system-ui,sans-serif" font-size="22" font-weight="300" fill="#FFFFFF">®</text>
      </g>
    </svg>
    <div class="hq">
      <blockquote>"Nossa voz é a de muitos. É a voz de quem acredita na inovação, em relações genuínas e humanas, e num mercado de saúde cujo cuidado pode ecooar longe."</blockquote>
      <cite>ecooa · nosso propósito</cite>
    </div>
  </div>
</section>

<Marquee />

<!-- Quem somos (intro) -->
<section style="background:var(--color-warm)" aria-label="Quem somos">
  <div class="w">
    <div class="g2 g2c">
      <div>
        <div class="lbl r">quem somos</div>
        <h2 class="h2 r d1" style="margin-top:15px">Somos a ecooa,<br>a clínica que <em>abraça</em><br>pessoas que cuidam<br>e são cuidadas.</h2>
        <p class="body r d2" style="margin-top:18px">Somos um ecossistema de crescimento, inovação, networking, bem-estar e ciência, onde cada detalhe foi pensado para que você se sinta vista, acolhida e cuidada do jeito que merece.</p>
        <a href="/quem-somos" class="bo r d3" style="margin-top:28px">nossa história</a>
        <div class="ia r d4">
          <div><span class="aw">acolhedora</span><span class="ad">um lugar onde você se sente em casa</span></div>
          <div><span class="aw">especialista</span><span class="ad">profissionais de referência em cada área</span></div>
          <div><span class="aw">integradora</span><span class="ad">todas as especialidades conectadas por você</span></div>
          <div><span class="aw">transformadora</span><span class="ad">do cuidado pontual à mudança que ecooa</span></div>
        </div>
      </div>
      <div class="iv r d2">
        <div class="ic ic-m" style="overflow:hidden">
          <img src="/clinic/recepcao.webp" alt="Recepção da ecooa — Moinhos de Vento" loading="lazy" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block" />
        </div>
        <div class="ic ic-f"><p class="if-lbl">cuidando com excelência</p><p class="if-v">desde 2021</p></div>
      </div>
    </div>
  </div>
</section>

<!-- Ecossistema -->
<section style="background:var(--color-cream)" aria-label="Serviços">
  <div class="w">
    <div class="ph2">
      <div>
        <div class="lbl r">o ecossistema ecooa</div>
        <h2 class="h2 r d1" style="margin-top:15px">Diferentes serviços.<br><em>Um propósito.</em></h2>
      </div>
      <p class="body r d2">Um ecossistema de cuidado completo, onde cada área ecooa com as demais para cuidar de você de dentro para fora.</p>
    </div>
    <div class="pg r">
      <PillarCard number="01" name="Medicina Humanizada" description="Diagnóstico metabólico, hormônios, emagrecimento e longevidade com cuidado genuíno." label="ecooa.med" href="/ecooa-med" />
      <PillarCard number="02" name="Estética Avançada" description="Procedimentos que respeitam a beleza natural, com técnica refinada e muito bom gosto." label="ecooa.esthetic" href="/ecooa-esthetic" />
      <PillarCard number="03" name="Nutrição" description="Clínica, esportiva, estética e comportamental, integrada a toda a sua jornada de saúde." label="ecooa.working" href="/ecooa-working" />
      <PillarCard number="04" name="Transplante Capilar" description="Referência em Porto Alegre para cabelos e couro cabeludo, do diagnóstico ao procedimento." label="ecooa.esthetic" href="/ecooa-esthetic" />
      <PillarCard number="05" name="Saúde Mental" description="Psicologia e psiquiatria integradas ao cuidado, porque saúde plena começa pela mente." label="ecooa.mind" href="/ecooa-mind" />
    </div>
  </div>
</section>

<!-- Metodologia -->
<section class="ap" aria-label="Metodologia">
  <div class="ap-vis" style="overflow:hidden">
    <img src="/clinic/reuniao-edit.webp" alt="Reunião na ecooa — metodologia de cuidado" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;display:block" />
  </div>
  <div class="ap-cp">
    <div class="lbl lbl-lt r">nossa metodologia</div>
    <h2 class="h2 h2-w r d1" style="margin-top:15px">Cuidado que<br>começa na <em>escuta</em><br>e nunca termina.</h2>
    <p class="body body-lt r d2" style="margin-top:16px">Não trabalhamos com protocolos genéricos. Entendemos sua história, analisamos seus dados e construímos com você um caminho feito para os seus objetivos.</p>
    <div class="st st-dk r d3" style="margin-top:32px">
      <div class="sr"><span class="sn">01</span><div><div class="st-t">Diagnóstico e escuta ativa</div><div class="st-b">Nossa equipe multidisciplinar se conhece e se comunica. Cada especialista sabe o momento certo de envolver os demais, de forma natural e coordenada.</div></div></div>
      <div class="sr"><span class="sn">02</span><div><div class="st-t">Testes genéticos e biomarcadores</div><div class="st-b">Análise aprofundada dos seus dados para um panorama preciso e real da sua saúde.</div></div></div>
      <div class="sr"><span class="sn">03</span><div><div class="st-t">Protocolo baseado nos seus objetivos</div><div class="st-b">Nada genérico, nada imposto. Construído com base nas suas informações e no que você quer alcançar.</div></div></div>
      <div class="sr"><span class="sn">04</span><div><div class="st-t">Acompanhamento humanizado</div><div class="st-b">Contínuo e presente, onde o objetivo principal é sempre você e a sua evolução.</div></div></div>
    </div>
    <a href="/ecooa-med" class="bow r d4" style="margin-top:36px">conhecer a metodologia</a>
  </div>
</section>

<!-- Números -->
<section style="background:var(--color-mist);padding:72px var(--section-px)" aria-label="Números da ecooa">
  <div class="nr">
    <div class="ni r"><p class="nv">9</p><p class="nl">Salas de atendimento</p></div>
    <div class="ni r d1"><p class="nv">30<sup>+</sup></p><p class="nl">Especialistas</p></div>
    <div class="ni r d2"><p class="nv">6</p><p class="nl">Sub-marcas integradas</p></div>
    <div class="ni r d3"><p class="nv">2021</p><p class="nl">Fundação</p></div>
  </div>
</section>

<!-- Cuidado -->
<section style="background:var(--color-warm)" aria-label="Para quem busca cuidado">
  <div class="w">
    <div class="ci-w">
      <div class="ci-sk">
        <div class="lbl r">para quem busca cuidado</div>
        <h2 class="h2 r d1" style="margin-top:15px">Você merece<br>um lugar que<br><em>cuida de verdade.</em></h2>
        <p class="body r d2" style="margin-top:16px">Aqui, você não é um número. Cada consulta é uma conversa. Cada protocolo é construído pensando em quem você é, no que você sente e onde quer chegar.</p>
        <a href={WA} target="_blank" rel="noopener noreferrer" class="bd r d3" style="margin-top:28px;display:inline-block">falar pelo whatsapp</a>
      </div>
      <div class="ci-ls">
        <div class="ci-row r">
          <div class="ci-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402 0-3.791 3.068-5.191 5.281-5.191 1.312 0 4.151.501 5.719 4.457 1.59-3.968 4.464-4.447 5.726-4.447 2.54 0 5.274 1.621 5.274 5.181 0 4.069-5.136 8.625-11 14.402z" stroke="#C4BBB8" stroke-width="1"/></svg></div>
          <div><p class="ci-t">Acolhimento genuíno</p><p class="ci-b">Antes de qualquer protocolo, escutamos você. Com tempo, atenção e sem pressa.</p></div>
        </div>
        <div class="ci-row r d1">
          <div class="ci-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="#C4BBB8" stroke-width="1"/><path d="M9 12l2 2 4-4" stroke="#C4BBB8" stroke-width="1" stroke-linecap="round"/></svg></div>
          <div><p class="ci-t">Medicina humanizada e precisa</p><p class="ci-b">Diagnóstico metabólico, testes genéticos e biomarcadores para um protocolo verdadeiramente seu.</p></div>
        </div>
        <div class="ci-row r d2">
          <div class="ci-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="#C4BBB8" stroke-width="1"/></svg></div>
          <div><p class="ci-t">Estética que respeita você</p><p class="ci-b">Para realçar, não transformar. Para revelar a melhor versão de quem você já é.</p></div>
        </div>
        <div class="ci-row r d3">
          <div class="ci-ic"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 22C6 22 2 17 2 11c0-2 1-4 2-5 1 4 4 6 8 6s7-2 8-6c1 1 2 3 2 5 0 6-4 11-10 11z" stroke="#C4BBB8" stroke-width="1"/></svg></div>
          <div><p class="ci-t">Longevidade como estilo de vida</p><p class="ci-b">Com energia, vitalidade e propósito. Um acompanhamento que transforma hábitos em resultados que ecooam.</p></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Nosso Espaço -->
<section aria-label="Nosso espaço premium" style="background:var(--color-ink);padding:0;overflow:hidden">
  <div style="position:relative;width:100%;aspect-ratio:16/9;overflow:hidden">
    <img src="/clinic/respire.webp" alt="Sala Respire da ecooa — consultório premium com jardim vertical e letreiro neon" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block" />
    <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(28,25,23,.7) 0%,transparent 50%)"></div>
    <div style="position:absolute;bottom:40px;left:60px;right:60px;z-index:2">
      <div class="lbl lbl-lt r" style="margin-bottom:12px">nosso espaço</div>
      <h2 style="font-family:var(--font-serif);font-size:clamp(28px,4vw,48px);font-weight:300;color:white;line-height:1.15;letter-spacing:-.02em" class="r d1">Salas que valorizam quem <em>cuida</em> e quem é <em>cuidado.</em></h2>
    </div>
  </div>
  <div style="padding:64px 60px 72px;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:start">
    <div>
      <p class="body body-lt r" style="max-width:480px">Cada consultório da ecooa foi projetado para elevar a experiência de quem atende e de quem é atendido. Painéis de madeira, jardim vertical, iluminação pensada e uma vista privilegiada de Porto Alegre criam o cenário ideal para consultas que transformam.</p>
      <a href="/quem-somos" class="bow r d1" style="margin-top:32px">conhecer o espaço</a>
    </div>
    <div class="st st-dk r d1">
      <div class="sr"><span class="sn">01</span><div><div class="st-t">Valor para o profissional</div><div class="st-b">O ambiente sofisticado eleva a percepção do seu trabalho, fortalece sua marca pessoal e atrai pacientes que valorizam excelência.</div></div></div>
      <div class="sr"><span class="sn">02</span><div><div class="st-t">Conforto para o paciente</div><div class="st-b">Quando o paciente entra num espaço que acolhe, a confiança no tratamento começa antes da primeira palavra. Cada detalhe comunica cuidado.</div></div></div>
      <div class="sr"><span class="sn">03</span><div><div class="st-t">Infraestrutura premium</div><div class="st-b">9 salas equipadas, recepção dedicada e áreas comuns que refletem o padrão ecooa.</div></div></div>
    </div>
  </div>
</section>

<!-- Liderança -->
<section style="background:var(--color-warm)" aria-label="Equipe de liderança">
  <div class="w" style="padding-top:0">
    <div class="tm-h">
      <div><div class="lbl r">liderança</div><h2 class="h2 r d1" style="margin-top:13px">Quem faz a ecooa<br><em>existir.</em></h2></div>
      <a href="/profissionais" class="ghost r">ver todos os profissionais <span aria-hidden="true">→</span></a>
    </div>
    <div class="g4">
      <ProfessionalCard name="Gustavo Gehrke" role="Sócio · Diretor Executivo · Médico" bg="linear-gradient(145deg,#DDD8D5,#C4BBB8)" photo="/team/gustavo.webp" />
      <ProfessionalCard name="Jessica Stein" role="Sócia · Diretora de Ensino · Nutricionista · Professora de Pós-Graduação" bg="linear-gradient(145deg,#D8D3CF,#BEB5B2)" photo="/team/jessica.webp" />
      <ProfessionalCard name="Maria Luísa Beltran" role="Diretora Administrativa · Nutricionista · Atleta de Crossfit" bg="linear-gradient(145deg,#E2DDD9,#C8C0BC)" photo="/team/maria-luisa.webp" />
      <ProfessionalCard name="Rafaela Teixeira" role="Atendimento e Relacionamento" bg="linear-gradient(145deg,#D5D0CC,#BAB2AE)" photo="/team/rafaela.webp" />
    </div>
  </div>
</section>

<!-- Depoimentos -->
<section style="background:var(--color-brand);padding:86px var(--section-px);overflow:hidden;position:relative" aria-label="Depoimentos de pacientes">
  <svg class="wsv" style="opacity:.1" viewBox="0 0 1440 400" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <g fill="none" stroke="white" stroke-width="1"><WavePattern count={6} y0={80} step={60} /></g>
  </svg>
  <div style="position:relative;z-index:2">
    <div class="lbl lbl-br" style="margin-bottom:36px">
      <span style="width:18px;height:1px;background:rgba(28,25,23,.15);display:inline-block;margin-right:11px"></span>o que dizem sobre nós
    </div>
    <div class="tt" id="tt" role="region" aria-roledescription="carrossel" aria-label="Depoimentos">
      <TestimonialCard quote='"Pela primeira vez me senti realmente escutada. Não é uma clínica, é um lugar onde você importa como pessoa."' author="paciente · longevidade" />
      <TestimonialCard quote='"O ambiente é diferente de tudo que já vi em Porto Alegre. Chega aqui e já sente que está sendo cuidada."' author="paciente · estética avançada" />
      <TestimonialCard quote='"Minha saúde mudou completamente. Mais energia, mais disposição, mais eu. A ecooa ecooou na minha vida."' author="paciente · medicina humanizada" />
      <TestimonialCard quote='"A equipe sabe o que faz e ainda assim sabe como fazer você se sentir importante. Isso é raro."' author="paciente · acompanhamento" />
      <TestimonialCard quote='"Em poucos meses já notei resultados que não consegui em anos de outras clínicas."' author="paciente · nutrição e medicina" />
    </div>
  </div>
