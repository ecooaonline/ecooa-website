---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, WA_DEFAULT } from '../data/site';
---

<BaseLayout
  title="Contato"
  description="TODO_DESCRICAO_CONTATO"
  currentPage="contato"
  breadcrumbs={[{ name: 'Contato', url: '/contato' }]}
>

  <section class="hero" style="min-height:auto;padding-top:140px;padding-bottom:var(--section-py)">
    <div style="max-width:800px;width:100%">
      <p class="lbl r">contato</p>
      <h1 class="r d1" style="font-size:clamp(28px,4vw,36px)">TODO_TITULO_CONTATO</h1>

      <div class="g2" style="margin-top:var(--space-xl);gap:var(--space-xl)">
        <div class="r">
          <h2 style="font-size:14px;font-weight:500;margin-bottom:var(--space-md)">Informacoes</h2>
          <div style="font-size:13px;line-height:2;color:var(--color-ink-soft)">
            <p>{SITE.address.street}, {SITE.address.number}</p>
            <p>{SITE.address.complement}</p>
            <p>{SITE.address.neighborhood}, {SITE.address.city} - {SITE.address.state}</p>
            <p style="margin-top:var(--space-sm)">{SITE.phone}</p>
            <p>{SITE.email}</p>
          </div>
          <div style="margin-top:var(--space-lg);display:flex;gap:12px;flex-wrap:wrap">
            <a href={WA_DEFAULT} target="_blank" rel="noopener noreferrer" class="btn btn-primary">whatsapp</a>
            <a href={SITE.mapsUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline">ver no mapa</a>
          </div>
        </div>
        <div class="r d1" style="aspect-ratio:1;background:var(--color-cream);border-radius:2px;display:flex;align-items:center;justify-content:center;font-size:12px;color:var(--color-ink-soft)">
          <!-- TODO: embed Google Maps ou foto do local -->
          Mapa
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
