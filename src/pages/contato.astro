---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroEditorial from '../components/HeroEditorial.astro';
import LocationCard from '../components/LocationCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_DEFAULT, FORM_ACTION, PHONE, INSTAGRAM } from '../data/constants';

const WA = WA_DEFAULT;
---

<BaseLayout
  title="Contato"
  description="Entre em contato com a ecooa. WhatsApp, e-mail e Instagram. Estamos prontos para te ouvir, orientar e receber. Moinhos de Vento, Porto Alegre."
  currentPage="contato"
  ogImage="/clinic/faxada-predio.webp"
  breadcrumbs={[{ name: 'Contato', url: '/contato' }]}
>
  <HeroEditorial
    label="contato"
    title="Fale com a<br /><em>ecooa.</em>"
    sub="Estamos prontos para te ouvir, orientar e receber. O canal mais ágil é sempre o WhatsApp."
    ctaHref={WA}
    ctaLabel="falar pelo whatsapp"
    ctaIntent="contato-hero"
    secondaryHref="#form-contato"
    secondaryLabel="prefere escrever?"
    image="/clinic/faxada-predio.webp"
    imageAlt="Fachada do edifício da ecooa na Rua Mariante, Moinhos de Vento"
    imageCaption="rua mariante, 180 · moinhos de vento"
  />

  <!-- Canais de contato -->
  <section
    style="background:var(--color-warm);padding:96px var(--section-px)"
    aria-label="Canais de contato"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="g2">
        <div>
          <div class="lbl r" style="margin-bottom:14px">fale conosco</div>
          <h2 class="h2 r d1" style="margin-bottom:40px">
            A conversa<br />começa <em>aqui.</em>
          </h2>
          <div class="r d2">
            <div class="ci-ct" style="border-top:1px solid var(--color-stone)">
              <p class="ci-cl">whatsapp · pacientes e visitantes</p>
              <p class="ci-cv">{PHONE}</p>
              <p class="ci-cs">Canal principal · Segunda a Sexta, 9h às 20h · Sábado a consultar</p>
              <a
                href={WA}
                target="_blank"
                rel="noopener noreferrer"
                class="bd"
                data-intent="contato-canal-whatsapp"
                style="display:inline-block">abrir whatsapp</a
              >
            </div>
            <div class="ci-ct">
              <p class="ci-cl">e-mail · administrativo e parcerias</p>
              <p class="ci-cv"><span class="eml" data-u="ecooa.adm" data-d="gmail.com"></span></p>
              <p class="ci-cs">Para parcerias, fornecedores e assuntos administrativos</p>
              <a
                href="#form-contato"
                class="ghost eml-link"
                data-u="ecooa.adm"
                data-d="gmail.com"
                style="display:inline-flex">enviar e-mail <span aria-hidden="true">→</span></a
              >
            </div>
            <div class="ci-ct">
              <p class="ci-cl">instagram</p>
              <p class="ci-cv">@somos.ecooa</p>
              <p class="ci-cs">Acompanhe nossa comunidade e conteúdos</p>
              <a
                href={INSTAGRAM}
                target="_blank"
                rel="noopener noreferrer"
                class="ghost"
                style="display:inline-flex">ver no instagram <span aria-hidden="true">→</span></a
              >
            </div>
            <div class="ci-ct">
              <p class="ci-cl">para profissionais de saúde</p>
              <p class="ci-cv">Quer atender na ecooa?</p>
              <p class="ci-cs">
                Entre em contato pelo WhatsApp e nos fale sobre você e sua prática
              </p>
              <a
                href={WA}
                target="_blank"
                rel="noopener noreferrer"
                class="ghost"
                style="display:inline-flex">falar pelo whatsapp <span aria-hidden="true">→</span></a
              >
            </div>
          </div>
        </div>
        <div class="r d2"><LocationCard /></div>
      </div>
    </div>
  </section>

  <!-- Formulário de contato -->
  <section
    style="background:var(--color-cream);padding:96px var(--section-px)"
    aria-label="Formulário de contato"
  >
    <div style="max-width:500px;margin:0 auto">
      <div class="lbl r" style="margin-bottom:16px;justify-content:center">formulário</div>
      <h2
        class="h2 r d1"
        style="margin-bottom:12px;text-align:center;font-size:clamp(26px,3vw,38px)"
      >
        Prefere escrever?<br />Deixe sua <em>mensagem.</em>
      </h2>
      <p class="body r d2" style="margin-bottom:36px;text-align:center">
        Responderemos em até 24 horas.
      </p>

      <form
        action={FORM_ACTION}
        method="POST"
        style="display:flex;flex-direction:column;gap:16px"
        class="r d3 ecooa-form"
        id="form-contato"
        data-ok-target="#form-contato-ok"
        data-success-text="Mensagem enviada. Retornaremos em breve."
        data-error-text={`Não foi possível enviar. Fale diretamente pelo WhatsApp: ${PHONE}`}
      >
        <input type="hidden" name="_formType" value="contato" />
        <input type="hidden" name="_source" value="contato" />
        <input
          type="text"
          name="_honeypot"
          style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
        />
        <input type="hidden" name="_loadedAt" value="" />
        <input type="hidden" name="_next" value="" />

        <p
          style="font-size:10px;font-weight:400;color:var(--color-ink-soft);margin:0 0 4px;text-align:right"
        >
          <span aria-hidden="true">* </span>campos obrigatórios
        </p>

        <div>
          <label
            for="contato-name"
            style="font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:lowercase;color:var(--color-ink-soft);margin-bottom:6px;display:block"
            >seu nome<span aria-hidden="true"> *</span></label
          >
          <input
            type="text"
            id="contato-name"
            name="nome"
            required
            minlength="2"
            autocomplete="name"
            style="width:100%;padding:14px 16px;border:1px solid var(--color-stone);background:var(--color-white);color:var(--color-ink);font-family:var(--font-primary);font-size:14px;font-weight:300"
          />
        </div>
        <div>
          <label
            for="contato-email"
            style="font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:lowercase;color:var(--color-ink-soft);margin-bottom:6px;display:block"
            >seu e-mail<span aria-hidden="true"> *</span></label
          >
          <input
            type="email"
            id="contato-email"
            name="email"
            required
            autocomplete="email"
            style="width:100%;padding:14px 16px;border:1px solid var(--color-stone);background:var(--color-white);color:var(--color-ink);font-family:var(--font-primary);font-size:14px;font-weight:300"
          />
        </div>
        <div>
          <label
            for="contato-message"
            style="font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:lowercase;color:var(--color-ink-soft);margin-bottom:6px;display:block"
            >sua mensagem<span aria-hidden="true"> *</span></label
          >
          <textarea
            id="contato-message"
            name="mensagem"
            required
            minlength="10"
            rows="4"
            style="width:100%;padding:14px 16px;border:1px solid var(--color-stone);background:var(--color-white);color:var(--color-ink);font-family:var(--font-primary);font-size:14px;font-weight:300;resize:vertical"
          ></textarea>
        </div>

        <div style="display:flex;align-items:flex-start;gap:10px;margin-top:8px">
          <input
            type="checkbox"
            id="contato-consent"
            name="consent"
            required
            style="margin-top:4px;cursor:pointer;min-width:16px"
          />
          <label
            for="contato-consent"
            style="font-size:12px;font-weight:300;color:var(--color-ink-soft);cursor:pointer"
          >
            Concordo em compartilhar meus dados conforme a <a
              href="/politica-de-privacidade"
              style="color:var(--color-brand-text);text-decoration:underline"
              target="_blank"
              rel="noopener">política de privacidade</a
            >
          </label>
        </div>

        <button
          type="submit"
          class="bd"
          style="width:100%;text-align:center;margin-top:8px;border:none;cursor:pointer"
          >enviar mensagem</button
        >
        <p
          id="form-contato-ok"
          aria-live="polite"
          style="display:none;text-align:center;font-size:14px;font-weight:400;color:var(--color-brand-text);margin-top:8px"
        >
          Mensagem enviada. Retornaremos em breve.
        </p>
        <p
          class="ecooa-form-error"
          role="alert"
          style="display:none;text-align:center;font-size:13px;font-weight:400;color:#c00;margin-top:8px"
        >
        </p>
      </form>
      <script>
        import { initFormSubmit } from '../scripts/form-submit';
        initFormSubmit();
      </script>
    </div>
  </section>

  <CtaSection
    showAgendar={false}
    heading="Pronto para<br><em>começar?</em>"
    subtext="A primeira conversa é o passo mais importante. A ecooa está aqui para te receber."
  />
</BaseLayout>
