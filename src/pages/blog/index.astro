---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WavePattern from '../../components/WavePattern.astro';
import CtaSection from '../../components/CtaSection.astro';
import { getCollection } from 'astro:content';
import { FORM_ACTION } from '../../data/constants';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryLabels: { [key: string]: string } = {
  medicina: 'Medicina',
  estetica: 'Estética',
  nutricao: 'Nutrição',
  'saude-mental': 'Saúde Mental',
  longevidade: 'Longevidade',
  ecooa: 'ecooa',
};

const categories = [
  { slug: 'medicina', label: 'Medicina' },
  { slug: 'estetica', label: 'Estética' },
  { slug: 'nutricao', label: 'Nutrição' },
  { slug: 'saude-mental', label: 'Saúde Mental' },
  { slug: 'longevidade', label: 'Longevidade' },
];
---

<BaseLayout
  title="Blog de Saúde, Estética e Longevidade"
  description="Artigos sobre saúde, estética, nutrição e longevidade. Conteúdo escrito por especialistas da ecooa em Porto Alegre."
  currentPage="blog"
  breadcrumbs={[{ name: 'Blog', url: '/blog' }]}
>
  <!-- Hero editorial -->
  <div class="ph u-bg-cream">
    <svg
      class="wsv u-op-26"
      viewBox="0 0 1440 500"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
      ><g fill="none" stroke="#cac7b8" stroke-width="1"
        ><WavePattern count={8} x0={-100} y0={80} step={55} width={1600} /></g
      ></svg
    >
    <div class="ph-c">
      <div class="lbl r">blog ecooa</div>
      <h1 class="h1 r d1 u-mt-18">Conteúdo que<br /><em>transforma.</em></h1>
      <p class="body r d2" style="margin-top:16px;max-width:480px">
        Artigos escritos por nossos especialistas para ajudar você a cuidar melhor da sua saúde,
        estética e bem-estar.
      </p>
    </div>
  </div>

  <!-- Categorias -->
  <section
    style="background:var(--color-warm);padding:44px var(--section-px) 0"
    aria-label="Categorias do blog"
  >
    <div class="blog-chips r" style="max-width:1240px;margin:0 auto">
      <a href="/blog" class="tag-pill chip-active">todas</a>
      {
        categories.map((cat) => (
          <a href={`/blog/categoria/${cat.slug}`} class="tag-pill">
            {cat.label}
          </a>
        ))
      }
    </div>
  </section>

  <!-- Destaque editorial -->
  {
    posts.length > 0 && (
      <section
        style="background:var(--color-warm);padding:48px var(--section-px) 8px"
        aria-label="Artigo em destaque"
      >
        <div style="max-width:1240px;margin:0 auto">
          <a
            href={`/blog/${posts[0].id}`}
            class="r feat-card"
            style="display:block;text-decoration:none;color:inherit;background:var(--color-mist);border:1px solid var(--color-stone);padding:clamp(36px,6vw,88px)"
          >
            <div style="display:flex;gap:14px;margin-bottom:22px;align-items:center;flex-wrap:wrap">
              <span class="tag-pill">em destaque</span>
              <span style="font-size:9px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text)">
                {categoryLabels[posts[0].data.category] || posts[0].data.category}
              </span>
            </div>
            <h2 style="font-family:var(--font-serif);font-size:clamp(30px,4.2vw,56px);font-weight:500;color:var(--color-ink);line-height:1.08;letter-spacing:-.02em;margin-bottom:18px;max-width:900px">
              {posts[0].data.title}
            </h2>
            <p class="body" style="max-width:620px;margin-bottom:24px">
              {posts[0].data.description}
            </p>
            <span class="ghost" style="font-size:11px">
              ler artigo <span aria-hidden="true">→</span>
            </span>
          </a>
        </div>
      </section>
    )
  }

  <!-- Grade de artigos -->
  <section
    style="background:var(--color-warm);padding:48px var(--section-px) 88px"
    aria-label="Artigos"
  >
    <div
      style="max-width:1240px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1px;background:var(--color-stone);border:1px solid var(--color-stone)"
    >
      {
        posts.slice(1).map((post, i, arr) => (
          <a
            href={`/blog/${post.id}`}
            class="r post-cell"
            style={`display:flex;flex-direction:column;text-decoration:none;color:inherit;padding:34px 30px;background:var(--color-cream)${i === arr.length - 1 ? ';grid-column:1/-1' : ''}`}
          >
            <div style="display:flex;gap:10px;margin-bottom:14px;align-items:baseline;flex-wrap:wrap">
              <span style="font-size:9px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text)">
                {categoryLabels[post.data.category] || post.data.category}
              </span>
              <span style="font-size:9px;font-weight:300;color:var(--color-ink-soft)">
                {new Date(post.data.date).toLocaleDateString('pt-BR', {
                  day: '2-digit',
                  month: 'long',
                  year: 'numeric',
                })}
              </span>
            </div>
            <h2 style="font-family:var(--font-serif);font-size:19px;font-weight:400;color:var(--color-ink);line-height:1.35;letter-spacing:-.01em;margin-bottom:10px">
              {post.data.title}
            </h2>
            <p style="font-size:13px;font-weight:300;color:var(--color-ink-soft);line-height:1.7;margin-bottom:16px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">
              {post.data.description}
            </p>
            <span
              class="ghost"
              style="margin-top:auto;font-size:11px;color:var(--color-brand-text)"
            >
              ler artigo <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Newsletter: pontuação escura -->
  <section style="background:var(--color-warm);padding:0 var(--section-px) 96px">
    <div style="max-width:900px;margin:0 auto">
      <div
        style="padding:clamp(40px,6vw,64px) 36px;background:var(--color-ink);text-align:center"
        class="r"
      >
        <p class="lbl lbl-lt" style="justify-content:center;margin-bottom:16px">semana em saúde</p>
        <p
          style="font-family:var(--font-serif);font-size:clamp(22px,3vw,28px);font-weight:300;color:var(--color-white);line-height:1.3;margin-bottom:10px"
        >
          A ecooa te atualizando<br />sobre o <em>mundo da saúde.</em>
        </p>
        <p
          style="font-size:13px;font-weight:300;color:var(--color-brand-mid);line-height:1.7;margin-bottom:26px"
        >
          Novidades e conteúdo exclusivo em primeira mão. Sem spam, a cada 15 dias.
        </p>
        <form
          action={FORM_ACTION}
          method="POST"
          style="display:flex;gap:8px;max-width:380px;margin:0 auto;flex-wrap:wrap;justify-content:center"
          class="ecooa-form"
          data-success-text="Inscrito com sucesso."
        >
          <input type="hidden" name="_formType" value="newsletter" />
          <input type="hidden" name="_source" value="blog-index" />
          <input
            type="text"
            name="_honeypot"
            style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />
          <input type="hidden" name="_loadedAt" value="" />
          <input
            type="email"
            name="email"
            required
            placeholder="seu melhor e-mail"
            aria-label="Seu melhor e-mail"
            style="flex:1;min-width:200px;padding:12px 16px;border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.06);color:var(--color-white);font-family:var(--font-primary);font-size:13px;font-weight:300"
          />
          <button
            type="submit"
            style="padding:12px 24px;background:var(--color-white);color:var(--color-ink);font-family:var(--font-primary);font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:lowercase;border:none;cursor:pointer"
            >inscrever-se</button
          >
        </form>
        <p
          class="ecooa-form-ok"
          style="display:none;font-size:13px;font-weight:400;color:var(--color-brand-deep);margin-top:10px"
        >
          Inscrito com sucesso.
        </p>
        <script>
          import { initFormSubmit } from '../../scripts/form-submit';
          initFormSubmit();
        </script>
      </div>
    </div>
  </section>

  <CtaSection
    heading="Quer cuidar da sua<br><em>saúde de verdade?</em>"
    subtext="Agende sua avaliação e converse com nossos especialistas."
  />
</BaseLayout>

<style>
  .blog-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .blog-chips .tag-pill {
    text-decoration: none;
    background: transparent;
    transition:
      background 0.25s ease,
      color 0.25s ease,
      border-color 0.25s ease;
  }
  .blog-chips .tag-pill:hover {
    background: var(--color-ink);
    color: var(--color-white);
    border-color: var(--color-ink);
  }
  .blog-chips .chip-active {
    background: var(--color-ink);
    color: var(--color-white);
    border-color: var(--color-ink);
  }
  .feat-card {
    transition: background 0.3s ease;
  }
  .feat-card:hover {
    background: var(--color-cream);
  }
  .post-cell {
    transition: background 0.3s ease;
  }
  .post-cell:hover {
    background: var(--color-mist);
  }
</style>
