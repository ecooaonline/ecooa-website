---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Marquee from '../../components/Marquee.astro';
import WavePattern from '../../components/WavePattern.astro';
import CtaSection from '../../components/CtaSection.astro';
import { getCollection } from 'astro:content';
import { FORM_ACTION } from '../../data/constants';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryLabels: { [key: string]: string } = {
  medicina: 'Medicina',
  estetica: 'Estética',
  nutricao: 'Nutrição',
  'saude-mental': 'Saúde Mental',
  longevidade: 'Longevidade',
  ecooa: 'ecooa',
};

const categories = [
  { slug: 'medicina', label: 'Medicina' },
  { slug: 'estetica', label: 'Estética' },
  { slug: 'nutricao', label: 'Nutrição' },
  { slug: 'saude-mental', label: 'Saúde Mental' },
  { slug: 'longevidade', label: 'Longevidade' },
];
---

<BaseLayout
  title="Blog de Saúde, Estética e Longevidade"
  description="Artigos sobre saúde, estética, nutrição e longevidade. Conteúdo escrito por especialistas da ecooa em Porto Alegre."
  currentPage="blog"
  breadcrumbs={[{ name: 'Blog', url: '/blog' }]}
>
  <!-- Hero -->
  <div class="ph u-bg-cream">
    <svg
      class="wsv u-op-26"
      viewBox="0 0 1440 500"
      preserveAspectRatio="xMidYMid slice"
      aria-hidden="true"
      ><g fill="none" stroke="#C9C5BC" stroke-width="1"
        ><WavePattern count={8} x0={-100} y0={80} step={55} width={1600} /></g
      ></svg
    >
    <div class="ph-c">
      <div class="lbl r">blog ecooa</div>
      <h1 class="h1 r d1 u-mt-18">Conteúdo que<br /><em>transforma.</em></h1>
      <p class="body r d2" style="margin-top:16px;max-width:480px">
        Artigos escritos por nossos especialistas para ajudar você a cuidar melhor da sua saúde,
        estética e bem-estar.
      </p>
    </div>
  </div>

  <Marquee />

  <!-- Categories -->
  <section style="background:var(--color-warm);padding:32px var(--section-px) 0">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center" class="r">
      <a
        href="/blog"
        style="text-decoration:none;display:inline-block;padding:8px 14px;border-radius:20px;background:var(--color-ink);color:white;font-size:11px;font-weight:500"
        >todas</a
      >
      {
        categories.map((cat) => (
          <a
            href={`/blog/categoria/${cat.slug}`}
            class="tag-pill"
            style="text-decoration:none;display:inline-block;padding:8px 14px;border-radius:20px;background:var(--color-stone);color:var(--color-ink-soft);font-size:11px;font-weight:500;transition:all .2s ease;border:none;cursor:pointer"
          >
            {cat.label}
          </a>
        ))
      }
    </div>
  </section>

  <!-- Destaque -->
  {
    posts.length > 0 && (
      <section
        style="background:var(--color-warm);padding:56px var(--section-px) 8px"
        aria-label="Artigo em destaque"
      >
        <div style="max-width:1240px;margin:0 auto">
          <a
            href={`/blog/${posts[0].id}`}
            class="r"
            style="display:block;text-decoration:none;color:inherit;background:var(--color-mist);border:1px solid var(--color-stone);padding:clamp(32px,5vw,72px)"
          >
            <div style="display:flex;gap:14px;margin-bottom:18px;align-items:center;flex-wrap:wrap">
              <span style="font-size:9px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--color-brand-text);border:1px solid var(--color-stone);padding:5px 12px;border-radius:20px">
                em destaque
              </span>
              <span style="font-size:9px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-text)">
                {categoryLabels[posts[0].data.category] || posts[0].data.category}
              </span>
            </div>
            <h2 style="font-family:var(--font-serif);font-size:clamp(28px,3.8vw,52px);font-weight:500;color:var(--color-ink);line-height:1.1;letter-spacing:-.02em;margin-bottom:16px;max-width:900px">
              {posts[0].data.title}
            </h2>
            <p style="font-size:15px;font-weight:300;color:var(--color-ink-soft);line-height:1.8;max-width:640px;margin-bottom:18px">
              {posts[0].data.description}
            </p>
            <span style="font-size:11px;font-weight:500;color:var(--color-ink);letter-spacing:.06em">
              ler artigo →
            </span>
          </a>
        </div>
      </section>
    )
  }

  <!-- Posts -->
  <section
    style="background:var(--color-warm);padding:48px var(--section-px) 72px"
    aria-label="Artigos"
  >
    <div
      style="max-width:1240px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:2px;background:var(--color-stone);border:1px solid var(--color-stone)"
    >
      {
        posts.slice(1).map((post) => (
          <a
            href={`/blog/${post.id}`}
            style="display:flex;flex-direction:column;text-decoration:none;color:inherit;padding:32px 28px;background:var(--color-warm)"
            class="r"
          >
            <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap">
              <span style="font-size:9px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-text)">
                {categoryLabels[post.data.category] || post.data.category}
              </span>
              <span style="font-size:9px;font-weight:300;color:var(--color-ink-soft)">
                {new Date(post.data.date).toLocaleDateString('pt-BR', {
                  day: '2-digit',
                  month: 'long',
                  year: 'numeric',
                })}
              </span>
            </div>
            <h2 style="font-family:var(--font-serif);font-size:19px;font-weight:400;color:var(--color-ink);line-height:1.35;letter-spacing:-.01em;margin-bottom:10px">
              {post.data.title}
            </h2>
            <p style="font-size:13px;font-weight:300;color:var(--color-ink-soft);line-height:1.7;margin-bottom:14px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">
              {post.data.description}
            </p>
            <span style="font-size:11px;font-weight:400;color:var(--color-brand-text);letter-spacing:.04em;margin-top:auto">
              ler artigo →
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Newsletter -->
  <section style="background:var(--color-warm);padding:0 var(--section-px) 48px">
    <div style="max-width:900px;margin:0 auto">
      <div style="padding:36px;background:var(--color-ink);text-align:center" class="r">
        <p
          style="font-size:10px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-light);margin-bottom:12px"
        >
          semana em saúde
        </p>
        <p
          style="font-family:var(--font-serif);font-size:clamp(20px,3vw,24px);font-weight:300;color:var(--color-white);line-height:1.3;margin-bottom:8px"
        >
          A ecooa te atualizando<br />sobre o <em>mundo da saúde.</em>
        </p>
        <p
          style="font-size:13px;font-weight:300;color:var(--color-brand-mid);line-height:1.7;margin-bottom:22px"
        >
          Novidades e conteúdo exclusivo em primeira mão. Sem spam, a cada 15 dias.
        </p>
        <form
          action={FORM_ACTION}
          method="POST"
          style="display:flex;gap:8px;max-width:380px;margin:0 auto;flex-wrap:wrap;justify-content:center"
          class="ecooa-form"
          data-success-text="Inscrito com sucesso."
        >
          <input type="hidden" name="_formType" value="newsletter" />
          <input type="hidden" name="_source" value="blog-index" />
          <input
            type="text"
            name="_honeypot"
            style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;pointer-events:none"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />
          <input type="hidden" name="_loadedAt" value="" />
          <input
            type="email"
            name="email"
            required
            placeholder="seu melhor e-mail"
            aria-label="Seu melhor e-mail"
            style="flex:1;min-width:200px;padding:12px 16px;border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.06);color:var(--color-white);font-family:var(--font-primary);font-size:13px;font-weight:300"
          />
          <button
            type="submit"
            style="padding:12px 24px;background:var(--color-white);color:var(--color-ink);font-family:var(--font-primary);font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:lowercase;border:none;cursor:pointer"
            >inscrever-se</button
          >
        </form>
        <p
          class="ecooa-form-ok"
          style="display:none;font-size:13px;font-weight:400;color:var(--color-brand-deep);margin-top:10px"
        >
          Inscrito com sucesso.
        </p>
        <script>
          import { initFormSubmit } from '../../scripts/form-submit';
          initFormSubmit();
        </script>
      </div>
    </div>
  </section>

  <CtaSection
    heading="Quer cuidar da sua<br><em>saúde de verdade?</em>"
    subtext="Agende sua avaliação e converse com nossos especialistas."
  />
</BaseLayout>
