---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaSection from '../../components/CtaSection.astro';
import DisclaimerMedico from '../../components/DisclaimerMedico.astro';
import { WA_BASE, WA_DEFAULT, FORM_ACTION } from '../../data/constants';
import { getCollection, render } from 'astro:content';
import { professionals } from '../../data/professionals';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Reading time calculation
const wordCount = post.body?.split(/\s+/).length || 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Match author to professional by last name (flexible matching)
const authorName = post.data.author;
const authorClean = authorName.replace(/^(Dra?\.\s*|Dra?\s+)/i, '');
const authorLastName = authorClean.split(/\s+/).pop()?.toLowerCase() || '';
const matchedProfessional = professionals.find(p => {
  const profLastName = p.name.split(/\s+/).pop()?.toLowerCase() || '';
  return profLastName === authorLastName;
}) || professionals.find(p => {
  const profNameLower = p.name.toLowerCase();
  const authorLower = authorClean.toLowerCase();
  return profNameLower.includes(authorLower) || authorLower.includes(profNameLower);
});

// Professional mapping for contextual CTAs (keep legacy map for specialty labels)
const professionalMap: Record<string, { name: string; specialty: string; instagram?: string }> = {
  'Dr. Gustavo Gehrke': { name: 'Dr. Gustavo Gehrke', specialty: 'Medicina de Alta Performance', instagram: 'gustavo.gehrke' },
  'Dra. Larissa Wiebbelling': { name: 'Dra. Larissa Wiebbelling', specialty: 'Tricologia e Transplante Capilar', instagram: 'dra.larissawiebbelling' },
  'Dra. Yale': { name: 'Dra. Yale', specialty: 'Saúde Capilar Feminina' },
  'Manuela Vanti': { name: 'Manuela Vanti', specialty: 'Psicologia Clínica' },
  'Jessica Stein': { name: 'Jessica Stein', specialty: 'Nutrição Clínica' },
  'Maria Luisa Beltran': { name: 'Maria Luisa Beltran', specialty: 'Nutrição Esportiva' },
  'Adriano Lenz': { name: 'Adriano Lenz', specialty: 'Medicina Ortomolecular' },
  'Viviane Fagundes': { name: 'Viviane Fagundes', specialty: 'Teste Genético Capilar' },
  'Giancarla': { name: 'Giancarla', specialty: 'Nutrição e Bioimpedância' },
  'Danusa': { name: 'Danusa', specialty: 'Soroterapia' },
};

const professional = professionalMap[post.data.author];
const waTextProfessional = professional
  ? encodeURIComponent(`Olá, gostaria de agendar uma avaliação com ${professional.name}`)
  : encodeURIComponent('Olá, gostaria de agendar uma avaliação com a equipe ecooa');
const WA_PROFESSIONAL = `${WA_BASE}?text=${waTextProfessional}`;

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const relatedPosts = allPosts.filter(p => p.data.category === post.data.category && p.id !== post.id).slice(0, 3);

const WA = WA_DEFAULT;
const dateFormatted = new Date(post.data.date).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });

// Medical categories use MedicalWebPage schema
const isMedical = ['medicina', 'saude-mental', 'nutricao', 'longevidade'].includes(post.data.category);
const articleType = isMedical ? 'MedicalWebPage' : 'Article';

// Share URLs
const SITE_URL = 'https://www.somosecooa.com.br';
const articleUrl = `${SITE_URL}/blog/${post.id}`;
const shareText = encodeURIComponent(post.data.title);
const shareWhatsApp = `https://wa.me/?text=${shareText}%20${encodeURIComponent(articleUrl)}`;
const shareTwitter = `https://twitter.com/intent/tweet?text=${shareText}&url=${encodeURIComponent(articleUrl)}`;
const shareLinkedIn = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(articleUrl)}`;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  currentPage="blog"
  ogImage={post.data.image || '/favicon/og-image.jpg'}
  breadcrumbs={[{ name: "Blog", url: "/blog" }, { name: post.data.title, url: `/blog/${post.id}` }]}
>

<!-- Article Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": articleType,
  "headline": post.data.title,
  "description": post.data.description,
  "image": `https://www.somosecooa.com.br${post.data.image || '/favicon/og-image.jpg'}`,
  "datePublished": post.data.date,
  "dateModified": post.data.lastModified || post.data.date,
  "author": {
    "@type": "Person",
    "name": post.data.author,
    "worksFor": { "@type": "MedicalBusiness", "name": "ecooa" }
  },
  "publisher": {
    "@type": "Organization",
    "name": "ecooa",
    "url": "https://www.somosecooa.com.br",
    "logo": "https://www.somosecooa.com.br/favicon/favicon.svg"
  },
  "mainEntityOfPage": `https://www.somosecooa.com.br/blog/${post.id}`
})} />

<article style="background:var(--color-warm);padding:48px var(--section-px) 72px">
  <div style="max-width:700px;margin:0 auto">

    <!-- Meta -->
    <div style="margin-bottom:24px" class="r">
      <a href="/blog" style="font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-text);text-decoration:none">← blog</a>
    </div>

    <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;align-items:center" class="r d1">
      <span style="font-size:9px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-text)">{post.data.category}</span>
      <span style="font-size:9px;font-weight:300;color:var(--color-ink-soft)">{dateFormatted}</span>
      <span style="font-size:9px;font-weight:300;color:var(--color-ink-soft)">·</span>
      <span style="font-size:9px;font-weight:300;color:var(--color-ink-soft)">{readingTime} min de leitura</span>
    </div>

    <h1 style="font-family:var(--font-serif);font-size:clamp(28px,4vw,42px);font-weight:300;color:var(--color-ink);line-height:1.2;letter-spacing:-.02em;margin-bottom:16px" class="r d1">{post.data.title}</h1>

    <!-- Author block -->
    {matchedProfessional ? (
      <div style="display:flex;align-items:center;gap:16px;padding:20px;background:var(--color-cream);margin-bottom:32px" class="r d2">
        <img
          src={matchedProfessional.photo}
          alt={matchedProfessional.name}
          width="56"
          height="56"
          style="width:56px;height:56px;border-radius:50%;object-fit:cover;flex-shrink:0"
          loading="lazy"
        />
        <div style="min-width:0">
          <p style="font-size:14px;font-weight:500;color:var(--color-ink);margin-bottom:2px">{post.data.author}</p>
          <p style="font-size:11px;font-weight:300;color:var(--color-ink-soft);margin-bottom:4px;line-height:1.4">{matchedProfessional.role}</p>
          {matchedProfessional.ig && (
            <a
              href={`https://instagram.com/${matchedProfessional.ig.replace('@', '')}`}
              target="_blank"
              rel="noopener noreferrer"
              style="font-size:11px;font-weight:400;color:var(--color-brand-text);text-decoration:none"
            >{matchedProfessional.ig}</a>
          )}
        </div>
      </div>
    ) : (
      <p style="font-size:12px;font-weight:300;color:var(--color-ink-soft);margin-bottom:32px" class="r d2">por <strong style="font-weight:500">{post.data.author}</strong></p>
    )}

    <!-- Tags -->
    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:40px" class="r d2">
      {post.data.tags.map(tag => (
        <span style="font-size:9px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--color-ink-soft);border:1px solid var(--color-stone);padding:4px 10px">{tag}</span>
      ))}
    </div>

    <!-- Highlight -->
    {post.data.highlight && (
      <div style="padding:24px 28px;background:var(--color-brand-light, #f0ebe3);border-left:3px solid var(--color-brand-text);margin-bottom:32px;font-family:var(--font-serif);font-size:clamp(16px,2.5vw,20px);font-weight:300;color:var(--color-ink);line-height:1.5;font-style:italic" class="r d3">
        {post.data.highlight}
      </div>
    )}

    <!-- Content -->
    <div class="blog-content r d3">
      <Content />
    </div>

    <DisclaimerMedico />

    <!-- Share buttons -->
    <div style="margin-top:36px;display:flex;align-items:center;gap:10px;flex-wrap:wrap" class="r">
      <span style="font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-ink-soft)">compartilhar</span>
      <a href={shareWhatsApp} target="_blank" rel="noopener noreferrer" style="font-size:11px;font-weight:400;color:var(--color-ink);text-decoration:none;border:1px solid var(--color-stone);padding:6px 14px;transition:background .2s">WhatsApp</a>
      <a href={shareTwitter} target="_blank" rel="noopener noreferrer" style="font-size:11px;font-weight:400;color:var(--color-ink);text-decoration:none;border:1px solid var(--color-stone);padding:6px 14px;transition:background .2s">X</a>
      <a href={shareLinkedIn} target="_blank" rel="noopener noreferrer" style="font-size:11px;font-weight:400;color:var(--color-ink);text-decoration:none;border:1px solid var(--color-stone);padding:6px 14px;transition:background .2s">LinkedIn</a>
    </div>

    <!-- Professional CTA -->
    <div style="margin-top:48px;padding:36px;background:var(--color-cream);text-align:center" class="r">
      {professional ? (
        <>
          <p style="font-size:10px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:12px">{professional.specialty}</p>
          <p style="font-family:var(--font-serif);font-size:22px;font-weight:300;color:var(--color-ink);margin-bottom:6px">Converse com {professional.name}</p>
          <p style="font-size:13px;font-weight:300;color:var(--color-ink-soft);margin-bottom:22px">Agende sua avaliação e receba orientação personalizada.</p>
          <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
            <a href={WA_PROFESSIONAL} target="_blank" rel="noopener noreferrer" class="bd">agendar com {professional.name.split(' ')[0]}</a>
            {professional.instagram && (
              <a href={`https://instagram.com/${professional.instagram}`} target="_blank" rel="noopener noreferrer" class="ghost">conhecer no instagram</a>
            )}
          </div>
        </>
      ) : (
        <>
          <p style="font-family:var(--font-serif);font-size:22px;font-weight:300;color:var(--color-ink);margin-bottom:8px">Quer saber mais?</p>
          <p style="font-size:13px;font-weight:300;color:var(--color-ink-soft);margin-bottom:20px">Agende sua avaliação com nossos especialistas.</p>
          <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
            <a href={WA_PROFESSIONAL} target="_blank" rel="noopener noreferrer" class="bd">falar pelo whatsapp</a>
            <a href="/agendamento" class="ghost">agendar avaliação com nossa equipe</a>
          </div>
        </>
      )}
    </div>

    <!-- Related articles -->
    {relatedPosts.length > 0 && (
      <div style="margin-top:48px" class="r">
        <p style="font-size:10px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:20px">artigos relacionados</p>
        <div style="display:grid;gap:16px">
          {relatedPosts.map(rp => (
            <a href={`/blog/${rp.id}`} style="display:block;padding:20px;background:var(--color-cream);text-decoration:none;color:inherit;transition:background .2s">
              <p style="font-size:9px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:6px">{rp.data.category}</p>
              <p style="font-family:var(--font-serif);font-size:18px;font-weight:300;color:var(--color-ink);line-height:1.3">{rp.data.title}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Newsletter -->
    <div style="margin-top:48px;padding:36px;background:var(--color-ink);text-align:center" class="r">
      <p style="font-size:10px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-light);margin-bottom:12px">semana em saúde</p>
      <p style="font-family:var(--font-serif);font-size:clamp(20px,3vw,24px);font-weight:300;color:var(--color-white);line-height:1.3;margin-bottom:8px">A ecooa te atualizando<br>sobre o <em>mundo da saúde.</em></p>
      <p style="font-size:13px;font-weight:300;color:var(--color-brand-mid);line-height:1.7;margin-bottom:22px">Novidades, ofertas e conteúdo exclusivo em primeira mão. Sem spam, a cada 15 dias.</p>
      <form action={FORM_ACTION} method="POST" style="display:flex;gap:8px;max-width:380px;margin:0 auto;flex-wrap:wrap;justify-content:center" class="ecooa-newsletter-form">
        <input type="hidden" name="_formType" value="newsletter" />
        <input type="hidden" name="_source" value="blog-post" />
        <input type="email" name="email" required placeholder="seu melhor e-mail" aria-label="Seu melhor e-mail" style="flex:1;min-width:200px;padding:12px 16px;border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.06);color:var(--color-white);font-family:var(--font-primary);font-size:13px;font-weight:300;outline:none" />
        <button type="submit" style="padding:12px 24px;background:var(--color-white);color:var(--color-ink);font-family:var(--font-primary);font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:lowercase;border:none;cursor:pointer">inscrever-se</button>
      </form>
      <p class="ecooa-newsletter-ok" style="display:none;font-size:13px;font-weight:400;color:var(--color-brand-deep);margin-top:10px">Inscrito com sucesso.</p>
      <script>
        document.querySelectorAll('.ecooa-newsletter-form').forEach(form => {
          form.addEventListener('submit', async function(e) {
            e.preventDefault();
            const f = e.target as HTMLFormElement;
            const btn = f.querySelector('button[type="submit"]') as HTMLButtonElement;
            btn.textContent = 'enviando...';
            btn.disabled = true;
            try {
              await fetch(f.action, { method: 'POST', body: new FormData(f) });
              f.style.display = 'none';
              const ok = f.parentElement?.querySelector('.ecooa-newsletter-ok') as HTMLElement;
              if (ok) ok.style.display = 'block';
            } catch {
              btn.textContent = 'erro. tente novamente';
              btn.disabled = false;
            }
          });
        });
      </script>
    </div>

  </div>
</article>

<CtaSection heading='O cuidado começa com<br>uma <em>conversa.</em>' subtext="Estamos prontos para ouvir você." />

</BaseLayout>
