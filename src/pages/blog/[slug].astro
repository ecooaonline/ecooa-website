---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaSection from '../../components/CtaSection.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Professional mapping for contextual CTAs
const professionalMap: Record<string, { name: string; specialty: string; instagram?: string }> = {
  'Dr. Gustavo Gehrke': { name: 'Dr. Gustavo Gehrke', specialty: 'Medicina de Alta Performance', instagram: 'gustavo.gehrke' },
  'Dra. Larissa Wiebbelling': { name: 'Dra. Larissa Wiebbelling', specialty: 'Tricologia e Transplante Capilar', instagram: 'dra.larissawiebbelling' },
  'Dra. Yale': { name: 'Dra. Yale', specialty: 'Saude Capilar Feminina' },
  'Manuela Vanti': { name: 'Manuela Vanti', specialty: 'Psicologia Clinica' },
  'Jessica Stein': { name: 'Jessica Stein', specialty: 'Nutricao Clinica' },
  'Maria Luisa Beltran': { name: 'Maria Luisa Beltran', specialty: 'Nutricao Esportiva' },
  'Adriano Lenz': { name: 'Adriano Lenz', specialty: 'Medicina Ortomolecular' },
  'Viviane Fagundes': { name: 'Viviane Fagundes', specialty: 'Teste Genetico Capilar' },
  'Giancarla': { name: 'Giancarla', specialty: 'Nutricao e Bioimpedancia' },
  'Danusa': { name: 'Danusa', specialty: 'Soroterapia' },
};

const professional = professionalMap[post.data.author];
const waTextProfessional = professional
  ? encodeURIComponent(`Olá, gostaria de agendar uma avaliação com ${professional.name}`)
  : encodeURIComponent('Olá, gostaria de agendar uma avaliação com a equipe ecooa');
const WA_PROFESSIONAL = `https://wa.me/5551991460909?text=${waTextProfessional}`;

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const relatedPosts = allPosts.filter(p => p.data.category === post.data.category && p.id !== post.id).slice(0, 3);

const WA = 'https://wa.me/5551991460909?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20uma%20avalia%C3%A7%C3%A3o%20com%20a%20equipe%20ecooa';
const dateFormatted = new Date(post.data.date).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  currentPage="blog"
  ogImage={post.data.image || '/favicon/og-image.jpg'}
  breadcrumbs={[{ name: "Blog", url: "/blog" }, { name: post.data.title, url: `/blog/${post.id}` }]}
>

<!-- Article Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "image": `https://www.somosecooa.com.br${post.data.image || '/favicon/og-image.jpg'}`,
  "datePublished": post.data.date,
  "author": {
    "@type": "Person",
    "name": post.data.author,
    "worksFor": { "@type": "MedicalBusiness", "name": "ecooa" }
  },
  "publisher": {
    "@type": "Organization",
    "name": "ecooa",
    "url": "https://www.somosecooa.com.br",
    "logo": "https://www.somosecooa.com.br/favicon/favicon.svg"
  },
  "mainEntityOfPage": `https://www.somosecooa.com.br/blog/${post.id}`
})} />

<article style="background:var(--color-warm);padding:48px var(--section-px) 72px">
  <div style="max-width:700px;margin:0 auto">

    <!-- Meta -->
    <div style="margin-bottom:24px" class="r">
      <a href="/blog" style="font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-text);text-decoration:none">← blog</a>
    </div>

    <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap" class="r d1">
      <span style="font-size:9px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-text)">{post.data.category}</span>
      <span style="font-size:9px;font-weight:300;color:var(--color-ink-soft)">{dateFormatted}</span>
    </div>

    <h1 style="font-family:var(--font-serif);font-size:clamp(28px,4vw,42px);font-weight:300;color:var(--color-ink);line-height:1.2;letter-spacing:-.02em;margin-bottom:16px" class="r d1">{post.data.title}</h1>

    <p style="font-size:12px;font-weight:300;color:var(--color-ink-soft);margin-bottom:32px" class="r d2">por <strong style="font-weight:500">{post.data.author}</strong></p>

    <!-- Tags -->
    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:40px" class="r d2">
      {post.data.tags.map(tag => (
        <span style="font-size:9px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--color-ink-soft);border:1px solid var(--color-stone);padding:4px 10px">{tag}</span>
      ))}
    </div>

    <!-- Content -->
    <div class="blog-content r d3">
      <Content />
    </div>

    <!-- Professional CTA -->
    <div style="margin-top:48px;padding:36px;background:var(--color-cream);text-align:center" class="r">
      {professional ? (
        <>
          <p style="font-size:10px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:12px">{professional.specialty}</p>
          <p style="font-family:var(--font-serif);font-size:22px;font-weight:300;color:var(--color-ink);margin-bottom:6px">Converse com {professional.name}</p>
          <p style="font-size:13px;font-weight:300;color:var(--color-ink-soft);margin-bottom:22px">Agende sua avaliacao e receba orientacao personalizada.</p>
          <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
            <a href={WA_PROFESSIONAL} target="_blank" rel="noopener noreferrer" class="bd">agendar com {professional.name.split(' ')[0]}</a>
            {professional.instagram && (
              <a href={`https://instagram.com/${professional.instagram}`} target="_blank" rel="noopener noreferrer" class="ghost">conhecer no instagram</a>
            )}
          </div>
        </>
      ) : (
        <>
          <p style="font-family:var(--font-serif);font-size:22px;font-weight:300;color:var(--color-ink);margin-bottom:8px">Quer saber mais?</p>
          <p style="font-size:13px;font-weight:300;color:var(--color-ink-soft);margin-bottom:20px">Agende sua avaliacao com nossos especialistas.</p>
          <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
            <a href={WA_PROFESSIONAL} target="_blank" rel="noopener noreferrer" class="bd">falar pelo whatsapp</a>
            <a href="/agendamento" class="ghost">agendar avaliacao com nossa equipe</a>
          </div>
        </>
      )}
    </div>

    <!-- Related articles -->
    {relatedPosts.length > 0 && (
      <div style="margin-top:48px" class="r">
        <p style="font-size:10px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:20px">artigos relacionados</p>
        <div style="display:grid;gap:16px">
          {relatedPosts.map(rp => (
            <a href={`/blog/${rp.id}`} style="display:block;padding:20px;background:var(--color-cream);text-decoration:none;color:inherit;transition:background .2s">
              <p style="font-size:9px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:6px">{rp.data.category}</p>
              <p style="font-family:var(--font-serif);font-size:18px;font-weight:300;color:var(--color-ink);line-height:1.3">{rp.data.title}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Newsletter -->
    <div style="margin-top:48px;padding:36px;background:var(--color-ink);text-align:center" class="r">
      <p style="font-size:10px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--color-brand-light);margin-bottom:12px">semana em saude</p>
      <p style="font-family:var(--font-serif);font-size:clamp(20px,3vw,24px);font-weight:300;color:var(--color-white);line-height:1.3;margin-bottom:8px">A ecooa te atualizando<br>sobre o <em>mundo da saude.</em></p>
      <p style="font-size:13px;font-weight:300;color:var(--color-brand-mid);line-height:1.7;margin-bottom:22px">Novidades, ofertas e conteudo exclusivo em primeira mao. Sem spam, a cada 15 dias.</p>
      <form action="https://formspree.io/f/placeholder" method="POST" style="display:flex;gap:8px;max-width:380px;margin:0 auto;flex-wrap:wrap;justify-content:center">
        <input type="email" name="email" required placeholder="seu melhor e-mail" style="flex:1;min-width:200px;padding:12px 16px;border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.06);color:var(--color-white);font-family:var(--font-primary);font-size:13px;font-weight:300;outline:none" />
        <button type="submit" style="padding:12px 24px;background:var(--color-white);color:var(--color-ink);font-family:var(--font-primary);font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:lowercase;border:none;cursor:pointer">aceito</button>
      </form>
    </div>

  </div>
</article>

<CtaSection heading='O cuidado comeca com<br>uma <em>conversa.</em>' subtext="Estamos prontos para ouvir voce." />

</BaseLayout>
