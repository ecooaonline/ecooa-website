---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import WavePattern from '../components/WavePattern.astro';
import HeroEditorial from '../components/HeroEditorial.astro';
import GuiaCard from '../components/GuiaCard.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_BASE, WA_DEFAULT } from '../data/constants';
import { getProfessionalBySlug } from '../data/professionals';

const gustavo = getProfessionalBySlug('gustavo-gehrke');
const jessica = getProfessionalBySlug('jessica-stein');

const WA_CARTA = `${WA_BASE}?text=${encodeURIComponent(
  'Olá, li a carta dos fundadores e gostaria de começar meu cuidado na ecooa'
)}`;
---

<BaseLayout
  title="Quem Somos"
  description="Conheça a ecooa: a clínica de Moinhos de Vento onde médico, nutricionista e psicóloga cuidam de você juntos. Emagrecimento, pele, cabelo e saúde mental em um só lugar."
  currentPage="quem-somos"
  ogImage="/clinic/recepcao.webp"
  breadcrumbs={[{ name: 'Quem Somos', url: '/quem-somos' }]}
>
  <HeroEditorial
    label="nossa história"
    title="Somos a ecooa.<br />Saúde, inovação e<br />cuidado <em>genuíno.</em>"
    sub="Fundada em 2021 em Moinhos de Vento, nascemos com um propósito claro: transformar a forma como a saúde é vivida em Porto Alegre. Um lugar onde o cuidado pode ecooar além dos consultórios."
    stars={true}
    ctaHref={WA_DEFAULT}
    ctaLabel="falar pelo whatsapp"
    ctaIntent="quem-somos-hero"
    secondaryHref="/profissionais"
    secondaryLabel="conhecer a equipe"
    image="/clinic/recepcao.webp"
    imageAlt="Recepção da ecooa em Moinhos de Vento"
    imageCaption="recepção · rua mariante, 180 · 9º andar"
  />

  <!-- Carta dos fundadores -->
  <section
    style="background:var(--color-cream);padding:112px var(--section-px)"
    aria-label="Carta dos fundadores"
  >
    <div style="max-width:720px;margin:0 auto">
      <div class="lbl r" style="margin-bottom:14px">dos fundadores</div>
      <h2 class="h2 r d1" style="margin-bottom:44px">uma carta<br />para <em>você.</em></h2>
      <div
        class="carta r d2"
        style="background:#fff;border:1px solid var(--color-stone);padding:clamp(32px,5vw,56px) clamp(28px,5vw,52px);position:relative;overflow:hidden"
      >
        <svg
          style="position:absolute;top:0;right:0;width:200px;height:200px;opacity:.08"
          viewBox="0 0 200 200"
          preserveAspectRatio="xMidYMid slice"
          aria-hidden="true"
          ><g fill="none" stroke="#cac7b8" stroke-width="1"
            ><WavePattern count={5} x0={-20} y0={20} step={40} width={240} /></g
          ></svg
        >
        <p>Quando começamos a ecooa, prometemos uma coisa: ouvir antes de prescrever.</p>
        <p>
          Cada pessoa que entra aqui traz uma história, e é essa história que guia o cuidado. Não
          acreditamos em protocolos genéricos. Acreditamos em pessoas.
        </p>
        <p>
          Nosso compromisso é simples: que você saia daqui sentindo que foi visto, ouvido e cuidado
          de verdade.
        </p>
        <p class="carta-sig">Gustavo e Jessica, sócios da ecooa</p>
      </div>
      <div class="r d3" style="margin-top:30px">
        <a
          href={WA_CARTA}
          target="_blank"
          rel="noopener noreferrer"
          class="ghost"
          data-intent="quem-somos-carta"
          >começar pela primeira conversa <span aria-hidden="true">→</span></a
        >
      </div>
    </div>
  </section>

  <!-- Como a ecooa nasceu -->
  <section
    style="background:var(--color-warm);padding:112px var(--section-px)"
    aria-label="Como a ecooa nasceu"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="g2 g2c">
        <div>
          <div class="lbl r">nossa origem</div>
          <h2 class="h2 r d1 u-mt-15">como a ecooa<br /><em>nasceu.</em></h2>
        </div>
        <div class="r d2">
          <p class="body u-mb-16">
            A ecooa nasceu de uma pergunta simples: por que medicina, nutrição, estética e
            psicologia não conversam entre si?
          </p>
          <p class="body u-mb-16">
            Em 2021, os sócios fundadores Gustavo Gehrke, médico, Jessica Stein, nutricionista, e
            Scheila Andrzejewski, médica, decidiram construir um espaço onde os profissionais
            trabalham juntos, e não em silos. Um lugar em que o paciente não precisa repetir sua
            história a cada consulta, porque a equipe já se conhece, já se comunica e já cuida de
            forma integrada.
          </p>
          <p class="body u-mb-16">
            O nome veio dessa ideia: o cuidado que <em
              style="font-family:var(--font-serif);font-style:italic;font-weight:300;color:var(--color-brand-accent)"
              >ecoa</em
            >. Um cuidado que não termina na porta do consultório e que se multiplica entre
            profissionais, entre áreas e entre pessoas.
          </p>
          <p class="body">
            Hoje, sob a liderança de Gustavo e Jessica, a ecooa é uma clínica multidisciplinar em
            Moinhos de Vento, com mais de 30 profissionais. O princípio permanece o mesmo: saúde de
            verdade acontece quando há conexão entre as pessoas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Nosso espaço: pontuação escura -->
  <section
    style="background:var(--color-ink);padding:112px var(--section-px)"
    aria-label="Nosso espaço"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl lbl-lt r" style="margin-bottom:14px">nosso espaço</div>
      <h2 class="h2 h2-w r d1" style="margin-bottom:18px">
        Projetado para<br /><em>acolher.</em>
      </h2>
      <p class="body body-lt r d2" style="max-width:520px;margin-bottom:48px">
        Cada detalhe do 9º andar foi pensado para transmitir conforto, sofisticação e cuidado. Rua
        Mariante, 180, Moinhos de Vento, Porto Alegre.
      </p>
      <div
        class="r d2"
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:26px"
      >
        <figure class="lux-frame" style="margin:0">
          <OptimizedImage
            src="/clinic/detalhes.webp"
            alt="Detalhes do espaço da ecooa"
            width={945}
            height={792}
            class="lux-frame-img"
          />
        </figure>
        <figure class="lux-frame" style="margin:0">
          <OptimizedImage
            src="/clinic/mind.webp"
            alt="Sala ecooa.mind"
            width={1200}
            height={798}
            class="lux-frame-img"
          />
        </figure>
        <figure class="lux-frame" style="margin:0">
          <OptimizedImage
            src="/clinic/mentorias.webp"
            alt="Espaço de mentorias da ecooa"
            width={1000}
            height={1233}
            class="lux-frame-img"
          />
        </figure>
      </div>
    </div>
  </section>

  <!-- Liderança -->
  <section
    style="background:var(--color-cream);padding:112px var(--section-px)"
    aria-label="Liderança"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl r" style="margin-bottom:14px">quem lidera</div>
      <h2 class="h2 r d1" style="margin-bottom:12px">Quem faz a ecooa<br /><em>existir.</em></h2>
      <p class="body r d2" style="max-width:480px;margin-bottom:44px">
        As pessoas por trás do ecossistema, com um mesmo compromisso: que você seja cuidada de
        verdade.
      </p>
      <div
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;max-width:860px"
      >
        {
          gustavo && (
            <GuiaCard
              name={gustavo.name}
              role="Médico · Fundador"
              photo={gustavo.photo}
              slug={gustavo.slug}
              registration={gustavo.registration}
              personalTouch={gustavo.personalTouch}
            />
          )
        }
        {
          jessica && (
            <GuiaCard
              name={jessica.name}
              role="Nutricionista · Fundadora"
              photo={jessica.photo}
              slug={jessica.slug}
              registration={jessica.registration}
              personalTouch={jessica.personalTouch}
              delay="d1"
            />
          )
        }
      </div>
    </div>
  </section>

  <CtaSection
    heading="Venha conhecer a<br><em>ecooa.</em>"
    subtext="A primeira conversa é o passo mais importante. Estamos prontos para te receber."
  />
</BaseLayout>

<style>
  .carta p {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(16px, 1.8vw, 20px);
    font-weight: 300;
    color: var(--color-ink);
    line-height: 1.75;
    position: relative;
    z-index: 1;
    margin-bottom: 18px;
  }
  .carta .carta-sig {
    font-family: var(--font-primary);
    font-style: normal;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--color-brand-text);
    margin: 28px 0 0;
  }
</style>
