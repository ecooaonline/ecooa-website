---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import HeroEditorial from '../components/HeroEditorial.astro';
import CtaSection from '../components/CtaSection.astro';
import { WA_DEFAULT, WA_BASE } from '../data/constants';

const WA = WA_DEFAULT;

// Formações consolidadas em grade editorial 3x2: seis células, nenhuma vazia.
const formacoes = [
  {
    sub: 'ecooa.cademy',
    nome: 'Cursos com Jessica Stein',
    desc: 'Nutrição clínica, esportiva, estética, comportamental, vegana e vegetariana, com profundidade acadêmica e olhar de consultório. Inclui análise de exames bioquímicos, suplementação e mentoria para nutricionistas que querem se posicionar no mercado premium de saúde.',
    waText: 'Olá, gostaria de saber mais sobre os cursos com a Jessica Stein',
    intent: 'cademy-cursos-jessica',
  },
  {
    sub: 'ecooa.esthetic · especialização',
    nome: 'Mentoria em Tricologia',
    desc: 'Para profissionais que desejam dominar o diagnóstico e o tratamento de queda capilar, alopecia e doenças do couro cabeludo. Do raciocínio clínico ao protocolo aplicado.',
    waText: 'Olá, gostaria de saber mais sobre a Mentoria em Tricologia',
    intent: 'cademy-tricologia',
  },
  {
    sub: 'ecooa.esthetic · vip',
    nome: 'Mentoria VIP em Transplante Capilar',
    desc: 'Formação exclusiva e intensiva em transplante capilar FUE e FUE Safira. Teoria, prática supervisionada, posicionamento de marca e gestão de pacientes no segmento de alta complexidade.',
    waText: 'Olá, gostaria de saber mais sobre a Mentoria VIP em Transplante Capilar',
    intent: 'cademy-vip-transplante',
  },
  {
    sub: 'ecooa.esthetic · especialização',
    nome: 'Mentoria em Harmonização Facial e Corporal',
    desc: 'Formação prática em injetáveis, preenchedores, bioestimuladores e procedimentos corporais. Com foco em técnica segura, indicação precisa e resultado natural.',
    waText: 'Olá, gostaria de saber mais sobre a Mentoria em Harmonização Facial e Corporal',
    intent: 'cademy-harmonizacao',
  },
  {
    sub: 'ecooa.esthetic · vip',
    nome: 'Mentoria VIP Estética',
    desc: 'Formato exclusivo e intensivo para profissionais da estética que querem elevar o padrão de atendimento, construir marca pessoal e posicionar a carreira no segmento premium.',
    waText: 'Olá, gostaria de saber mais sobre a Mentoria VIP Estética',
    intent: 'cademy-vip-estetica',
  },
  {
    sub: 'ecooa · comunidade',
    nome: 'Palestras e Eventos Científicos',
    desc: 'Encontros de atualização, networking e troca entre profissionais de saúde, com palestrantes convidados e auditório próprio no edifício da ecooa.',
    waText: 'Olá, gostaria de participar das palestras e eventos científicos da ecooa',
    intent: 'cademy-eventos',
  },
];
---

<BaseLayout
  title="ecooa.cademy, Mentorias e Cursos"
  description="Mentorias e cursos para profissionais de saúde. Formação de alto nível ministrada por quem está na prática diária. ecooa.cademy, Porto Alegre."
  currentPage="mentorias"
  ogImage="/clinic/mentorias.webp"
  breadcrumbs={[{ name: 'Mentorias', url: '/mentorias' }]}
>
  <HeroEditorial
    label="ecooa.cademy · educação"
    title="Formação de alto nível<br />para profissionais<br />que querem <em>mais.</em>"
    sub="Mentorias, cursos e eventos científicos ministrados por quem está na prática clínica todos os dias. Para quem quer se especializar, se diferenciar e construir uma carreira de referência."
    ctaHref={WA}
    ctaLabel="falar com a equipe"
    ctaIntent="cademy-hero"
    secondaryHref="#mentorias"
    secondaryLabel="ver mentorias e cursos"
    image="/clinic/mentorias.webp"
    imageAlt="Espaço de ensino da ecooa.cademy em Moinhos de Vento"
    imageCaption="ecooa.cademy · moinhos de vento"
    vertical="educação que ecooa"
  />

  <!-- Mentorias e cursos: grade editorial 3x2 -->
  <section
    style="background:var(--color-warm);padding:104px var(--section-px)"
    aria-label="Cursos e especializações"
    id="mentorias"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="lbl r" style="margin-bottom:16px">cursos e especializações</div>
      <h2 class="h2 r d1" style="margin-bottom:18px">O que a ecooa<br /><em>ensina.</em></h2>
      <p class="body r d2" style="max-width:520px;margin-bottom:56px">
        Seis caminhos de formação, um mesmo padrão: conteúdo de alto nível, aplicação prática e a
        experiência de quem atende todos os dias.
      </p>
      <div class="cad-grid r d2">
        {
          formacoes.map((f) => (
            <a
              href={`${WA_BASE}?text=${encodeURIComponent(f.waText)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="cad-cell"
              data-intent={f.intent}
              aria-label={`Saber mais sobre ${f.nome}`}
            >
              <span class="cad-sub">{f.sub}</span>
              <span class="cad-name">{f.nome}</span>
              <span class="cad-desc">{f.desc}</span>
              <span class="cad-go" aria-hidden="true">
                →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Diretora de ensino -->
  <section
    style="background:var(--color-cream);padding:104px var(--section-px)"
    aria-label="Diretora de ensino"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="g2 g2c">
        <div>
          <div class="lbl r">diretora de ensino</div>
          <h2 class="h2 r d1" style="margin-top:15px">Jessica <em>Stein.</em></h2>
          <p class="body r d2" style="margin-top:18px">
            Nutricionista, sócia da ecooa e professora de pós-graduação com vasta experiência
            clínica e acadêmica. Jessica lidera o braço educacional da ecooa com o mesmo padrão de
            excelência que orienta toda a clínica: conteúdo de alto nível, aplicação prática e uma
            visão que forma profissionais prontos para o mercado premium de saúde.
          </p>
          <p class="body r d3" style="margin-top:13px">
            Cada mentoria e curso foi construído com base na prática real, nos desafios que aparecem
            no consultório e nas lacunas que a formação acadêmica convencional não preenche.
          </p>
        </div>
        <figure class="lux-frame r d2" style="margin:0;max-width:420px">
          <OptimizedImage
            src="/team/jessica-mentoria.webp"
            alt="Jessica Stein, Diretora de Ensino da ecooa"
            width={700}
            height={1050}
            class="lux-frame-img"
          />
          <figcaption class="lux-caption">jessica stein · sócia e diretora de ensino</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- Comunidade: pontuação escura -->
  <section
    style="background:var(--color-ink);padding:104px var(--section-px)"
    aria-label="Comunidade e eventos científicos"
  >
    <div style="max-width:1280px;margin:0 auto">
      <div class="g2 g2c">
        <div>
          <div class="lbl lbl-lt r">comunidade</div>
          <h2 class="h2 h2-w r d1" style="margin-top:15px">
            Uma comunidade que<br />aprende e cresce <em>junta.</em>
          </h2>
          <p class="body body-lt r d2" style="margin-top:18px;max-width:520px">
            A ecooa reúne profissionais de saúde para eventos de networking, atualização e troca de
            experiências. Contamos com auditório próprio no edifício, com capacidade para até 25
            convidados. Palestrantes convidados, conteúdo de ponta e um ambiente exclusivo para quem
            quer estar sempre à frente.
          </p>
          <a
            href={WA}
            target="_blank"
            rel="noopener noreferrer"
            class="bw r d3 u-cta"
            data-intent="cademy-comunidade">quero participar</a
          >
        </div>
        <figure class="lux-frame r d2" style="margin:0">
          <OptimizedImage
            src="/clinic/reuniao.webp"
            alt="Auditório da ecooa, espaço para mentorias e eventos científicos"
            width={1000}
            height={666}
            class="lux-frame-img"
          />
          <figcaption class="lux-caption">auditório ecooa · 9º andar</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <CtaSection
    heading="Quer fazer parte da<br>comunidade <em>ecooa?</em>"
    subtext="Fale com a nossa equipe e descubra a mentoria ou evento certo para o seu momento de carreira."
    showAgendar={false}
  />
</BaseLayout>

<style>
  /* Grade editorial de formações: papel pautado por hairlines, sem vitrine.
     Colunas 3/2/1: seis células dividem exato em qualquer largura. */
  .cad-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--color-stone);
    border-left: 1px solid var(--color-stone);
  }
  .cad-cell {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--color-stone);
    border-bottom: 1px solid var(--color-stone);
    padding: 40px 34px 32px;
    text-decoration: none;
    transition: background 0.25s ease;
  }
  .cad-cell:hover {
    background: var(--color-cream);
  }
  .cad-sub {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brand-text);
    margin-bottom: 14px;
  }
  .cad-name {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(20px, 1.9vw, 24px);
    font-weight: 400;
    color: var(--color-ink);
    line-height: 1.3;
    margin-bottom: 12px;
    transition: color 0.2s ease;
  }
  .cad-desc {
    font-size: 12.5px;
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-ink-soft);
  }
  .cad-go {
    margin-top: auto;
    padding-top: 24px;
    font-size: 15px;
    color: var(--color-brand-text);
    opacity: 0.5;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }
  .cad-cell:hover .cad-name {
    color: var(--color-brand-text);
  }
  .cad-cell:hover .cad-go {
    opacity: 1;
    transform: translateX(4px);
  }
  @media (max-width: 1080px) {
    .cad-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .cad-grid {
      grid-template-columns: 1fr;
    }
    .cad-cell {
      padding: 30px 24px 26px;
    }
  }
</style>
