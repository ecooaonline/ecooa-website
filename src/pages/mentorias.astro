---
import BaseLayout from '../layouts/BaseLayout.astro';
import WavePattern from '../components/WavePattern.astro';
import Marquee from '../components/Marquee.astro';
import CtaSection from '../components/CtaSection.astro';

const WA = 'https://wa.me/5551991460909';
---

<BaseLayout
  title="ecooa.cademy — Mentorias e Cursos | ecooa"
  description="Mentorias e cursos para profissionais de saúde. Formação de alto nível ministrada por quem está na prática diária. ecooa.cademy, Porto Alegre."
  currentPage="mentorias"
>

<!-- Hero -->
<div class="ph" style="background:var(--color-ink)">
  <svg class="wsv" style="opacity:.05" viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" aria-hidden="true"><g fill="none" stroke="white" stroke-width="1"><WavePattern count={8} x0={-100} y0={80} step={55} width={1600} /></g></svg>
  <div class="ph-c">
    <div class="lbl lbl-lt r">ecooa.cademy</div>
    <h1 class="h1 h1-w r d1" style="margin-top:18px">Mentorias e cursos<br>para profissionais<br>que querem <em>mais.</em></h1>
    <p class="body body-lt r d2" style="margin-top:16px;max-width:500px">Formação de alto nível ministrada por quem está na prática diária. Para profissionais que querem se especializar, se diferenciar e construir uma carreira de referência.</p>
    <a href={WA} target="_blank" rel="noopener noreferrer" class="bw r d3" style="margin-top:28px;display:inline-block">falar pelo whatsapp</a>
  </div>
</div>

<Marquee />

<!-- Diretora de Ensino -->
<section style="background:var(--color-cream)" aria-label="Diretora de ensino">
  <div class="w">
    <div class="g2 g2c">
      <div>
        <div class="lbl r">diretora de ensino</div>
        <h2 class="h2 r d1" style="margin-top:15px">Jessica Stein.</h2>
        <p class="body r d2" style="margin-top:16px">Nutricionista, sócia da ecooa e professora de pós-graduação com vasta experiência clínica e acadêmica. Jessica lidera o braço educacional da ecooa com o mesmo padrão de excelência que orienta toda a clínica: conteúdo de alto nível, aplicação prática e uma visão que forma profissionais prontos para o mercado premium de saúde.</p>
        <p class="body r d3" style="margin-top:13px">Cada mentoria e curso foi construído com base na prática real, nos desafios que aparecem no consultório e nas lacunas que a formação acadêmica convencional não preenche.</p>
        <a href={WA} target="_blank" rel="noopener noreferrer" class="bo r d4" style="margin-top:28px;display:inline-block">falar com a equipe</a>
      </div>
      <div class="r d2">
        <div class="pc" style="max-width:320px">
          <div class="pc-ph" style="aspect-ratio:1/1.2">
            <img src="/team/jessica-mentoria.webp" alt="Jessica Stein — Diretora de Ensino da ecooa" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;display:block" />
          </div>
          <div class="pc-i">
            <p class="pc-n">Jessica Stein</p>
            <p class="pc-r">Sócia · Diretora de Ensino · Nutricionista · Professora de Pós-Graduação</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Cursos e Especializações -->
<section style="background:var(--color-warm)" aria-label="Cursos e especializações">
  <div class="w">
    <div class="lbl r" style="margin-bottom:15px">cursos e especializações</div>
    <h2 class="h2 r d1" style="margin-bottom:44px">O que a ecooa<br><em>ensina.</em></h2>
    <div style="display:grid;grid-template-columns:repeat(2,1fr);border-top:1px solid var(--color-stone);border-left:1px solid var(--color-stone)" class="r">
      <div style="border-right:1px solid var(--color-stone);border-bottom:1px solid var(--color-stone);padding:36px 30px;position:relative">
        <p style="font-size:9px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:12px">ecooa.cademy</p>
        <h3 style="font-size:18px;font-weight:400;color:var(--color-ink);margin-bottom:10px;line-height:1.3">Cursos com Jessica Stein</h3>
        <p style="font-size:13px;font-weight:300;line-height:1.8;color:var(--color-ink-soft)">Nutrição clínica, esportiva, estética, comportamental, vegana e vegetariana — com profundidade acadêmica e olhar prático de consultório. Inclui cursos de análise de exames bioquímicos e suplementação, mentoria para a prática no consultório e conteúdos desenvolvidos para nutricionistas que querem se posicionar no mercado premium de saúde.</p>
        <a href={WA} target="_blank" rel="noopener noreferrer" style="margin-top:18px;display:inline-flex;align-items:center;gap:7px;font-size:10px;font-weight:500;letter-spacing:.08em;color:var(--color-brand-text);text-decoration:none">saber mais <span aria-hidden="true">→</span></a>
      </div>
      <div style="border-right:1px solid var(--color-stone);border-bottom:1px solid var(--color-stone);padding:36px 30px;position:relative">
        <p style="font-size:9px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:12px">ecooa.esthetic · especialização</p>
        <h3 style="font-size:18px;font-weight:400;color:var(--color-ink);margin-bottom:10px;line-height:1.3">Mentoria em Tricologia</h3>
        <p style="font-size:13px;font-weight:300;line-height:1.8;color:var(--color-ink-soft)">Para profissionais que desejam dominar o diagnóstico e tratamento de queda capilar, alopecia e doenças do couro cabeludo. Do raciocínio clínico ao protocolo aplicado.</p>
        <a href={WA} target="_blank" rel="noopener noreferrer" style="margin-top:18px;display:inline-flex;align-items:center;gap:7px;font-size:10px;font-weight:500;letter-spacing:.08em;color:var(--color-brand-text);text-decoration:none">saber mais <span aria-hidden="true">→</span></a>
      </div>
      <div style="border-right:1px solid var(--color-stone);border-bottom:1px solid var(--color-stone);padding:36px 30px;position:relative">
        <p style="font-size:9px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:12px">ecooa.esthetic · vip</p>
        <h3 style="font-size:18px;font-weight:400;color:var(--color-ink);margin-bottom:10px;line-height:1.3">Mentoria VIP em Transplante Capilar</h3>
        <p style="font-size:13px;font-weight:300;line-height:1.8;color:var(--color-ink-soft)">Formação exclusiva e intensiva voltada a profissionais que querem se especializar em transplante capilar FUE e FUE Safira. Teoria, prática supervisionada, posicionamento de marca e gestão de pacientes no segmento de alta complexidade.</p>
        <a href={WA} target="_blank" rel="noopener noreferrer" style="margin-top:18px;display:inline-flex;align-items:center;gap:7px;font-size:10px;font-weight:500;letter-spacing:.08em;color:var(--color-brand-text);text-decoration:none">saber mais <span aria-hidden="true">→</span></a>
      </div>
      <div style="border-right:1px solid var(--color-stone);border-bottom:1px solid var(--color-stone);padding:36px 30px;position:relative">
        <p style="font-size:9px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:12px">ecooa.esthetic · especialização</p>
        <h3 style="font-size:18px;font-weight:400;color:var(--color-ink);margin-bottom:10px;line-height:1.3">Mentoria em Harmonização Facial e Corporal</h3>
        <p style="font-size:13px;font-weight:300;line-height:1.8;color:var(--color-ink-soft)">Formação prática em injetáveis, preenchedores, bioestimuladores e procedimentos corporais. Com foco em técnica segura, indicação precisa e resultado natural.</p>
        <a href={WA} target="_blank" rel="noopener noreferrer" style="margin-top:18px;display:inline-flex;align-items:center;gap:7px;font-size:10px;font-weight:500;letter-spacing:.08em;color:var(--color-brand-text);text-decoration:none">saber mais <span aria-hidden="true">→</span></a>
      </div>
      <div style="border-right:1px solid var(--color-stone);border-bottom:1px solid var(--color-stone);padding:36px 30px;position:relative">
        <p style="font-size:9px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:12px">ecooa.esthetic · vip</p>
        <h3 style="font-size:18px;font-weight:400;color:var(--color-ink);margin-bottom:10px;line-height:1.3">Mentoria VIP Estética</h3>
        <p style="font-size:13px;font-weight:300;line-height:1.8;color:var(--color-ink-soft)">Formato exclusivo e intensivo para profissionais da estética que querem elevar o padrão de atendimento, construir marca pessoal e posicionar a carreira no segmento premium.</p>
        <a href={WA} target="_blank" rel="noopener noreferrer" style="margin-top:18px;display:inline-flex;align-items:center;gap:7px;font-size:10px;font-weight:500;letter-spacing:.08em;color:var(--color-brand-text);text-decoration:none">saber mais <span aria-hidden="true">→</span></a>
      </div>
      <div style="border-right:1px solid var(--color-stone);border-bottom:1px solid var(--color-stone);padding:36px 30px;position:relative">
        <p style="font-size:9px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:var(--color-brand-text);margin-bottom:12px">ecooa · comunidade</p>
        <h3 style="font-size:18px;font-weight:400;color:var(--color-ink);margin-bottom:10px;line-height:1.3">Palestras e Eventos Científicos</h3>
        <p style="font-size:13px;font-weight:300;line-height:1.8;color:var(--color-ink-soft)">A ecooa reúne profissionais de saúde para eventos de networking, atualização e troca de experiências. Contamos com auditório próprio no edifício com capacidade para até 25 convidados. Palestrantes convidados, conteúdo de ponta e um ambiente exclusivo para quem quer estar sempre à frente.</p>
        <a href={WA} target="_blank" rel="noopener noreferrer" style="margin-top:18px;display:inline-flex;align-items:center;gap:7px;font-size:10px;font-weight:500;letter-spacing:.08em;color:var(--color-brand-text);text-decoration:none">saber mais <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </div>
</section>

<!-- Foto do espaço -->
<section style="background:var(--color-cream);padding:0;overflow:hidden" aria-label="Nosso espaço de ensino">
  <div style="position:relative;width:100%;aspect-ratio:16/7;overflow:hidden">
    <img src="/clinic/reuniao.webp" alt="Auditório e sala de reuniões da ecooa — espaço para mentorias e eventos" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;display:block" />
  </div>
</section>

<!-- Eventos Científicos -->
<section style="background:var(--color-brand);padding:86px 60px;position:relative;overflow:hidden" aria-label="Eventos científicos">
  <svg class="wsv" style="opacity:.13" viewBox="0 0 1440 400" preserveAspectRatio="xMidYMid slice" aria-hidden="true"><g fill="none" stroke="white" stroke-width="1"><WavePattern count={7} x0={-100} y0={80} step={55} width={1600} /></g></svg>
  <div style="position:relative;z-index:2;max-width:680px">
    <div class="lbl lbl-br r" style="margin-bottom:18px">eventos científicos</div>
    <h2 style="font-size:clamp(28px,3.4vw,50px);font-weight:200;color:white;line-height:1.08;letter-spacing:-.025em;margin-bottom:20px" class="r d1">Uma comunidade que<br>aprende e cresce <em>junta.</em></h2>
    <p style="font-size:14px;font-weight:300;line-height:1.9;color:rgba(255,255,255,.56);max-width:540px" class="r d2">A ecooa reúne profissionais de saúde para eventos de networking, atualização e troca de experiências. Contamos com auditório próprio no edifício com capacidade para até 25 convidados. Um ambiente exclusivo para quem quer estar sempre à frente.</p>
    <a href={WA} target="_blank" rel="noopener noreferrer" class="bw r d3" style="margin-top:32px;display:inline-block">quero participar</a>
  </div>
</section>

<CtaSection heading='Quer fazer parte da<br>comunidade <em>ecooa?</em>' subtext="Fale com a nossa equipe e descubra a mentoria ou evento certo para o seu momento de carreira." />

</BaseLayout>
