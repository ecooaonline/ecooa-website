# Variáveis de ambiente da ecooa
# Copie este arquivo para .env e preencha os valores reais (nunca commite .env)

# Google Tag Manager
PUBLIC_GTM_ID=GTM-XXXXXXX

# Meta Pixel (Facebook/Instagram Ads)
PUBLIC_META_PIXEL_ID=000000000000000

# Google Apps Script — endpoint do formulário
# Obtenha o URL ao publicar o GAS como Web App (Execute as: Anyone)
FORM_ACTION=https://script.google.com/macros/s/XXXXX/exec

# Sentry (monitoramento de erros JS em produção)
# Opcional — deixe em branco para desabilitar
PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
